---
// お問い合わせ送信完了ページ。フォーム (AJAX) 成功後にここへ遷移する。
import SmysteryLayout from '../../../layouts/SmysteryLayout.astro';
---

<SmysteryLayout
  title="送信完了｜Smystery"
  description="お問い合わせありがとうございます。内容を確認のうえ、担当者よりご連絡いたします。"
>
  <meta name="robots" content="noindex" slot="head" />
  <section class="sec" style="padding-top:190px;min-height:64vh">
    <div class="wrap tc">
      <span class="eyebrow" style="display:block;margin-bottom:14px">Thank you</span>
      <h2 class="sec-title">送信完了</h2>
      <div class="thanks">
        <p class="tk mincho">お問い合わせありがとうございます。</p>
        <p class="tkd">内容を確認のうえ、担当者より折り返しご連絡いたします。<br>今しばらくお待ちくださいませ。</p>
      </div>
      <div style="margin-top:48px"><a class="btn-ghost" href="/smystery/">トップページへ戻る</a></div>
    </div>
  </section>

  <style>
    .thanks{max-width:560px;margin:52px auto 0;border:1px solid rgba(201,162,75,.25);padding:52px 36px;background:rgba(16,9,11,.5)}
    .thanks .tk{font-size:19px;letter-spacing:.1em;color:#f2e9e5;margin:0 0 16px}
    .thanks .tkd{font-size:14px;line-height:2.1;color:#c3b6b1;letter-spacing:.05em;margin:0}
  </style>
</SmysteryLayout>
