---
// Smystery トップページ。
// Claude Design のハンドオフ (Smystery.dc.html) を Astro に移植したもの。
import SmysteryLayout from '../../layouts/SmysteryLayout.astro';
import SmysteryContactForm from '../../components/SmysteryContactForm.astro';

const TICKET_URL = 'https://escape.id/smystery-org/e-shimokita/';
const LP_URL = 'https://smystery.studio.site/';
const WAKA_STORE = 'https://store.wakajapan.com/';
const assets = '/assets/smystery';

const news = [
  { date: '2026.07.08', cat: 'EVENT', text: '「紅漂う街角で 〜ある香水ブランドの秘密〜」の情報を公開しました。' },
  { date: '2026.07.08', cat: 'COLLABO', text: '香水ブランド「WAKA / FRAGRANCE OF JAPAN」とのコラボレーションが決定しました。' },
  { date: '2026.07.01', cat: 'INFO', text: 'イマーシブ体験レーベル「Smystery」を始動しました。' },
];
---

<SmysteryLayout>

<section class="hero" id="top">
  <div class="hero-scrim"></div>
  <div class="hero-glow"></div>
  <div class="parts" aria-hidden="true"><span class="part p1"></span><span class="part p2"></span><span class="part p3"></span><span class="part p4"></span><span class="part p5"></span><span class="part p6"></span><span class="part p7"></span></div>
  <div class="hero-in">
    <img class="hero-logo" src={`${assets}/smystery-logo.webp`} alt="Smystery" width="520" height="306">
    <p class="hero-tag">SMELL<span class="x">×</span>MYSTERY</p>
    <h1 class="hero-jp mincho"><span class="nobr">匂いとミステリーが</span><wbr><span class="nobr">融合する、没入体験。</span></h1>
    <p class="hero-sub">街を歩き、香りを纏い、物語の当事者になる。Smysteryは、実在する香水と物語を掛け合わせた唯一無二のイマーシブ体験を創り出すレーベルです。</p>
    <div class="hero-cta"><a class="btn" href="#event">開催中のイベントを見る<span class="ar">→</span></a></div>
  </div>
  <a class="scrollcue" href="#concept">SCROLL<i></i></a>
</section>

<section class="sec concept" id="concept">
  <div class="wrap">
    <div class="sec-head rv"><span class="eyebrow">Concept</span><h2 class="sec-title">Smystery とは</h2></div>
    <p class="concept-lead mincho rv"><span class="nobr">Smell（匂い）</span><wbr><span class="nobr">× Mystery（謎）。</span><br><span class="nobr">五感で味わう、</span><wbr><span class="nobr">もうひとつの物語へ。</span></p>
    <p class="concept-body rv">香りには、記憶を呼び起こし、感情を揺さぶる力があります。Smysteryは、その香りとミステリーを掛け合わせ、あなた自身が物語の登場人物となる没入型（イマーシブ）体験を創出するレーベルです。実在する街を舞台に、実在する香水を纏いながら、選択を重ね、真実へと近づいていく——観るでも、演じるでもない、体験としての物語をお届けします。</p>
    <div class="pillars">
      <div class="pillar rv"><div class="pillar-no">01</div><div class="pillar-t mincho">香りで没入する</div><p class="pillar-d">実在する香水ブランドの香りを実際に体感。嗅覚から物語の世界へ引き込まれる、Smysteryならではの体験設計です。</p></div>
      <div class="pillar rv d1"><div class="pillar-no">02</div><div class="pillar-t mincho">街が舞台になる</div><p class="pillar-d">実在の街を歩きながら、そこで起こる出来事やキャストとの交流が、あなただけの物語を紡いでいきます。</p></div>
      <div class="pillar rv d2"><div class="pillar-no">03</div><div class="pillar-t mincho">選択で変わる結末</div><p class="pillar-d">あなたの選択が物語を動かす。複数のエンディングが用意され、何度でも新たな真実に出会えます。</p></div>
    </div>
  </div>
</section>

<section class="sec event" id="event">
  <div class="wrap">
    <div class="sec-head rv"><span class="eyebrow">Now Showing</span><h2 class="sec-title">開催中のイベント</h2></div>
    <div class="ev-grid">
      <div class="ev-visual rv"><span class="ev-badge">NOW</span><img src={`${assets}/event-waka.webp`} alt="紅漂う街角で ─ ある香水ブランドの秘密" width="595" height="842"></div>
      <div class="ev-info rv d1">
        <span class="ev-tag">Smystery × WAKA ／ イマーシブミステリー</span>
        <h3 class="ev-title mincho">紅漂う街角で<span class="sm">— ある香水ブランドの秘密 —</span></h3>
        <div class="ev-meta"><span><b>VENUE</b>下北沢の街</span><span><b>SCENT</b>WAKA FRAGRANCE OF JAPAN</span><span><b>STYLE</b>街歩き型イマーシブ</span></div>
        <p class="ev-desc">大人気の香水ブランド「WAKA」から、待望の新シリーズが発売される。発売に合わせて下北沢の街で募集された、期間限定の訪問販売スタッフ——そのアルバイトに応募したあなたは、ただ香水を届けるだけではない、ある事件へと巻き込まれていく。この事件、何かが匂う。</p>
        <div class="cta-row"><a class="btn" href={TICKET_URL} target="_blank" rel="noopener">チケット・詳細を見る<span class="ar">→</span></a><a class="btn-ghost" href={LP_URL} target="_blank" rel="noopener">特設サイト（LP）を見る →</a></div>
      </div>
    </div>
    <div class="story rv">
      <div class="story-label">STORY<small>ストーリー</small></div>
      <div class="story-body mincho">
        <p>大人気の香水ブランド「WAKA」。このたび、WAKAから待望の新シリーズが発売されることとなった。発売に合わせて、下北沢の街では新シリーズをお客様へ直接届ける、期間限定の訪問販売スタッフが募集されている。</p>
        <p>偶然ウェブ広告でその募集を目にしたあなたは、内容に興味を惹かれ、短期アルバイトへ応募することにした。しかし、その仕事はただ香水を届けるだけではなかった。</p>
        <p><span class="em">ブランドの新商品。それを求める人々。下北沢の街で次々と出会うさまざまな出来事。</span>そして——あなたは、ある事件へと巻き込まれていく。</p>
        <p class="last">この事件、何かが匂う。</p>
      </div>
    </div>
    <div class="feat3">
      <div class="fcard rv"><div class="fno">Feature 01</div><h4 class="mincho">香水ブランド『WAKA』が登場</h4><p>参加者は香水の匂いを実際に体感し、キャストと交流をしながら物語を体験していただきます。</p></div>
      <div class="fcard rv d1"><div class="fno">Feature 02</div><h4 class="mincho">初めての方でも安心</h4><p>イマーシブ体験が未経験の方でも楽しんでいただけるよう、しっかりと補助が入ります。</p></div>
      <div class="fcard rv d2"><div class="fno">Feature 03</div><h4 class="mincho">何度でもリプレイ可能</h4><p>複数のエンディングを用意。一度体験した方も、初めての方を誘って何度でもお楽しみいただけます。</p></div>
    </div>
    <div class="tc" style="margin-top:56px"><a class="navcta" href="/smystery/events/" style="padding:15px 34px">EVENT ARCHIVE ／ イベント一覧 →</a></div>
  </div>
</section>

<section class="sec" id="partner">
  <div class="wrap">
    <div class="sec-head rv"><span class="eyebrow">Fragrance Partner</span><h2 class="sec-title">登場する香水ブランド</h2></div>
    <div class="partner-card rv">
      <div class="waka-mark"><div class="w latin">WAKA</div><div class="s">FRAGRANCE OF JAPAN</div></div>
      <p class="pt mincho">和歌から着想を得た、平和の香りをあなたへ。</p>
      <p class="pd">本公演「紅漂う街角で」に登場する香水ブランド「WAKA」。和歌の世界観から生まれた12種類の香りを展開する日本のフレグランスブランドです。物語の中で、実際にその香りを纏いながら体験をお楽しみいただけます。</p>
      <a class="btn-ghost" href={WAKA_STORE} target="_blank" rel="noopener">WAKA オンラインストア →</a>
    </div>
  </div>
</section>

<section class="sec" id="news">
  <div class="wrap">
    <div class="sec-head rv"><span class="eyebrow">News</span><h2 class="sec-title">お知らせ</h2></div>
    <div class="news-list rv">
      {news.map((n) => (
        <div class="news-item"><span class="news-date latin">{n.date}</span><span class="news-cat">{n.cat}</span><span class="news-txt">{n.text}</span></div>
      ))}
    </div>
  </div>
</section>

<section class="sec foot-cta" id="company">
  <div class="wrap">
    <div class="sec-head rv"><span class="eyebrow">Company</span><h2 class="sec-title">会社概要</h2></div>
    <div class="company-grid rv">
      <div class="cr-k latin">会社名</div><div class="cr-v">株式会社ex Labs</div>
      <div class="cr-k latin">事業内容</div><div class="cr-v">イマーシブ体験の企画・制作／香りとエンターテインメントの融合事業</div>
      <div class="cr-k latin">レーベル</div><div class="cr-v">Smystery（スミステリー）</div>
      <div class="cr-k latin">Web</div><div class="cr-v"><a href="https://kabuexlabs.com/" target="_blank" rel="noopener">https://kabuexlabs.com/</a></div>
    </div>
    <div class="tc" style="margin-top:44px"><a class="navcta" href="/smystery/company/" style="padding:15px 34px">COMPANY DETAIL ／ 詳しい会社概要 →</a></div>
  </div>
</section>

<section class="sec foot-cta" id="contact">
  <div class="wrap">
    <div class="contact-intro rv"><span class="eyebrow">Contact</span><p class="contact-lead mincho">物語は、まだ続いていく。</p><p class="dim contact-note"><span class="nobr">公演・コラボレーション・取材に関する</span><wbr><span class="nobr">お問い合わせは、下記フォームより</span><wbr><span class="nobr">お気軽にお寄せください。</span></p></div>
    <div class="rv"><SmysteryContactForm /></div>
  </div>
</section>

<style>
/* hero */
.hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;padding:130px 0 110px;box-sizing:border-box;background:radial-gradient(120% 90% at 50% 24%,rgba(90,15,24,.34),transparent 58%),linear-gradient(180deg,#0d0809 0%,#0a0708 60%,#0a0708 100%)}
.hero-scrim{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(10,7,8,.2) 0%,rgba(10,7,8,0) 40%,rgba(10,7,8,.6) 100%);pointer-events:none}
.hero-glow{position:absolute;left:50%;top:42%;transform:translate(-50%,-50%);width:min(640px,90vw);height:min(640px,90vw);border-radius:50%;background:radial-gradient(circle,rgba(155,26,92,.3),transparent 62%);filter:blur(20px);z-index:1;pointer-events:none}
.hero-in{position:relative;z-index:3;text-align:center;padding:0 24px}
.hero-logo{width:min(460px,72vw);height:auto;filter:drop-shadow(0 8px 40px rgba(155,26,92,.45));margin:0 auto 26px}
.hero-tag{font-family:'Cormorant Garamond',serif;font-size:clamp(18px,3vw,28px);letter-spacing:.32em;color:#eadfd9;margin:0 0 22px}
.hero-tag .x{color:#c9a24b;margin:0 .28em}
.hero-jp{font-weight:500;font-size:clamp(24px,4vw,40px);line-height:1.65;letter-spacing:.12em;color:#f2e9e5;margin:0}
.hero-sub{margin:24px auto 0;max-width:600px;font-size:14px;line-height:2.2;letter-spacing:.08em;color:#c3b6b1}
.hero-cta{margin-top:34px}
.scrollcue{position:absolute;bottom:30px;left:50%;transform:translateX(-50%);z-index:3;display:flex;flex-direction:column;align-items:center;gap:10px;color:#9c8f8a;font-family:'Cormorant Garamond',serif;font-size:12px;letter-spacing:.3em}
.scrollcue i{width:1px;height:48px;background:linear-gradient(#c9a24b,transparent);animation:cue 2.2s ease-in-out infinite}
@keyframes cue{0%,100%{transform:scaleY(.4);transform-origin:top;opacity:.4}50%{transform:scaleY(1);opacity:1}}
/* scent particles */
.parts{position:absolute;inset:0;z-index:2;pointer-events:none}
.part{position:absolute;bottom:-10px;width:5px;height:5px;border-radius:50%;background:radial-gradient(circle,rgba(217,140,174,.9),rgba(217,140,174,0));animation:rise linear infinite}
@keyframes rise{0%{transform:translateY(0) translateX(0);opacity:0}12%{opacity:.8}90%{opacity:.5}100%{transform:translateY(-104vh) translateX(40px);opacity:0}}
.part.p1{left:12%;animation-duration:15s;animation-delay:0s}
.part.p2{left:24%;animation-duration:19s;animation-delay:3s;width:3px}
.part.p3{left:38%;animation-duration:13s;animation-delay:6s}
.part.p4{left:52%;animation-duration:21s;animation-delay:1s;width:4px}
.part.p5{left:66%;animation-duration:16s;animation-delay:4s}
.part.p6{left:78%;animation-duration:18s;animation-delay:7s;width:3px}
.part.p7{left:88%;animation-duration:14s;animation-delay:2.5s}
@media (prefers-reduced-motion:reduce){.part,.scrollcue i{animation:none}}
/* concept */
.concept{background:linear-gradient(180deg,#0a0708,#0d0809)}
.concept-lead{font-weight:500;font-size:clamp(20px,2.8vw,30px);line-height:2;letter-spacing:.1em;text-align:center;color:#f2e9e5;max-width:820px;margin:0 auto 30px}
.concept-body{max-width:640px;margin:0 auto;text-align:center;font-size:15px;line-height:2.3;letter-spacing:.08em;color:#c3b6b1}
.pillars{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:76px}
.pillar{border:1px solid rgba(201,162,75,.2);padding:44px 30px;text-align:center;background:rgba(20,12,14,.5);transition:border-color .4s,transform .4s}
.pillar:hover{border-color:rgba(201,162,75,.55);transform:translateY(-6px)}
.pillar-no{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:40px;color:#7a1226;line-height:1}
.pillar-t{font-weight:600;font-size:20px;letter-spacing:.08em;color:#f2e9e5;margin:18px 0 14px}
.pillar-d{font-size:13.5px;line-height:2;letter-spacing:.06em;color:#b3a6a1}
/* event */
.event{background:radial-gradient(120% 80% at 80% 0%,rgba(74,15,24,.5),transparent 60%),#0a0708}
.ev-grid{display:grid;grid-template-columns:0.9fr 1.1fr;gap:56px;align-items:center}
.ev-visual{position:relative}
.ev-visual img{width:100%;border:1px solid rgba(201,162,75,.25);box-shadow:0 30px 80px rgba(0,0,0,.6)}
.ev-badge{position:absolute;top:-14px;left:-14px;background:#7a1226;color:#f2e9e5;font-family:'Cormorant Garamond',serif;font-size:14px;letter-spacing:.2em;padding:8px 18px;border:1px solid #c9a24b}
.ev-tag{font-family:'Cormorant Garamond',serif;font-style:italic;letter-spacing:.22em;color:#c9a24b;font-size:17px}
.ev-title{font-weight:700;font-size:clamp(28px,4.2vw,50px);line-height:1.35;letter-spacing:.06em;color:#f2e9e5;margin:14px 0 8px}
.ev-title .sm{display:block;font-size:.5em;font-weight:500;letter-spacing:.14em;color:#d98cae;margin-top:14px}
.ev-meta{display:flex;flex-wrap:wrap;gap:10px 26px;margin:26px 0 24px;font-size:13px;letter-spacing:.08em;color:#c3b6b1}
.ev-meta b{color:#c9a24b;font-weight:500;margin-right:10px;font-family:'Cormorant Garamond',serif;letter-spacing:.18em}
.ev-desc{font-size:14.5px;line-height:2.2;letter-spacing:.06em;color:#c9bdb8;margin:0 0 30px}
.cta-row{display:flex;gap:16px;flex-wrap:wrap;align-items:center}
.story{margin-top:96px;border-top:1px solid rgba(201,162,75,.18);padding-top:66px;display:grid;grid-template-columns:0.7fr 1.3fr;gap:50px}
.story-label{font-family:'Cormorant Garamond',serif;font-style:italic;font-size:34px;color:#7a1226;letter-spacing:.1em}
.story-label small{display:block;font-family:'Zen Kaku Gothic New',sans-serif;font-size:11px;letter-spacing:.4em;color:#9c8f8a;margin-top:8px}
.story-body p{font-size:16px;line-height:2.35;letter-spacing:.08em;color:#d6cac5;margin:0 0 22px}
.story-body .em{color:#e79bbb;font-weight:500}
.story-body .last{color:#c9a24b;font-size:18px;margin:0}
.feat3{display:grid;grid-template-columns:repeat(3,1fr);gap:24px;margin-top:56px}
.fcard{border:1px solid rgba(201,162,75,.18);padding:32px 26px;background:rgba(16,9,11,.6)}
.fcard .fno{font-family:'Cormorant Garamond',serif;font-style:italic;color:#c9a24b;font-size:15px;letter-spacing:.2em}
.fcard h4{font-weight:600;font-size:17px;color:#f2e9e5;margin:10px 0 12px;letter-spacing:.05em;line-height:1.6}
.fcard p{font-size:13px;line-height:1.95;color:#b3a6a1;margin:0}
/* partner */
.partner-card{max-width:720px;margin:0 auto;border:1px solid rgba(201,162,75,.22);background:rgba(16,9,11,.55);padding:56px 40px;text-align:center}
.waka-mark .w{font-size:clamp(38px,6vw,60px);letter-spacing:.34em;color:#f2e9e5;line-height:1}
.waka-mark .s{font-family:'Cormorant Garamond',serif;font-size:13px;letter-spacing:.4em;color:#c9a24b;margin-top:12px}
.partner-card .pt{font-size:17px;letter-spacing:.1em;color:#e79bbb;margin:30px 0 0}
.partner-card .pd{font-size:14px;line-height:2.1;letter-spacing:.06em;color:#c3b6b1;max-width:480px;margin:22px auto 26px}
/* news */
.news-list{max-width:760px;margin:0 auto}
.news-item{display:flex;gap:26px;align-items:baseline;padding:24px 4px;border-bottom:1px solid rgba(201,162,75,.14);transition:background .3s}
.news-item:hover{background:rgba(122,18,38,.12)}
.news-date{font-size:17px;letter-spacing:.14em;color:#c9a24b;white-space:nowrap}
.news-cat{font-size:10px;letter-spacing:.2em;border:1px solid rgba(217,140,174,.5);color:#d98cae;padding:3px 10px;white-space:nowrap}
.news-txt{font-size:14.5px;letter-spacing:.05em;color:#d6cac5;line-height:1.7}
/* company + contact */
.foot-cta{background:radial-gradient(100% 120% at 50% 0%,rgba(74,15,24,.42),transparent 60%),#0a0708}
.company-grid{display:grid;grid-template-columns:auto 1fr;border:1px solid rgba(201,162,75,.18);max-width:820px;margin:0 auto}
.cr-k{padding:22px 30px;border-bottom:1px solid rgba(201,162,75,.12);border-right:1px solid rgba(201,162,75,.12);font-family:'Cormorant Garamond',serif;letter-spacing:.16em;color:#c9a24b;font-size:15px;white-space:nowrap}
.cr-v{padding:22px 30px;border-bottom:1px solid rgba(201,162,75,.12);font-size:14px;letter-spacing:.05em;color:#d6cac5;line-height:1.8}
.contact-intro{text-align:center;margin-bottom:46px}
.contact-intro .eyebrow{display:block;margin-bottom:14px}
.contact-lead{font-size:clamp(22px,3vw,32px);letter-spacing:.1em;color:#f2e9e5;margin:0 0 12px}
.contact-note{font-size:14px;letter-spacing:.08em;line-height:2;max-width:560px;margin:0 auto}
@media(max-width:900px){
  .ev-grid,.story,.company-grid{grid-template-columns:1fr;gap:36px}
  .story{gap:26px;margin-top:70px;padding-top:52px}
  .company-grid{gap:0}
  .cr-k{border-right:none;padding-bottom:6px}
  .cr-v{padding-top:6px;padding-bottom:20px}
  .ev-visual{max-width:340px;margin:0 auto}
  .partner-card{padding:40px 24px}
  /* Hero content can run taller than 88vh on narrow phones, which
     pushed the CTA button into the absolutely-positioned scroll cue.
     .hero centers its flex children as a row, so switching to a
     column stacks hero-in above the cue instead of beside it, and
     letting height be content-driven guarantees clearance. */
  .hero{min-height:0;flex-direction:column;padding:112px 0 56px}
  .scrollcue{position:static;transform:none;margin-top:32px}
  /* 01/02/03 numbered blocks: horizontal swipe instead of a long
     vertical stack. */
  .pillars,.feat3{display:flex;grid-template-columns:none;overflow-x:auto;scroll-snap-type:x mandatory;gap:16px;margin-left:-24px;margin-right:-24px;padding:4px 24px 14px;-webkit-overflow-scrolling:touch}
  .pillars{margin-top:44px}
  .pillar,.fcard{flex:0 0 82%;scroll-snap-align:center}
  /* Poster art shouldn't dominate the whole viewport height. */
  .ev-visual img{max-height:56vh;width:auto;margin:0 auto;object-fit:contain}
  /* Date + category badge share a line; the headline text always
     gets its own full-width line below, instead of being squeezed
     into a narrow third column. */
  .news-item{flex-wrap:wrap;gap:8px 14px;padding:20px 4px}
  .news-txt{flex-basis:100%}
}
@media(max-width:640px){
  .sec{padding:64px 0}
  .pillar,.fcard{flex-basis:86%}
}
</style>

</SmysteryLayout>
