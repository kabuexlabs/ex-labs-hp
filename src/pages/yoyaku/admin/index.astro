---
// 日程調整の管理ページ（社内用）。複数イベントを同時に管理できる。
//   /yoyaku/admin/            … イベント一覧＋新規作成
//   /yoyaku/admin/?event=<id> … 各イベントの管理（タイトル・候補日・予約）
// YOYAKU_ADMIN_KEY を知っている人だけが操作できる。合言葉は POST でのみ
// 受け取り、以降は HttpOnly なセッション Cookie で認証する — URL に載せると
// ブラウザ履歴・ブックマーク・ホスティングのアクセスログに残ってしまうため、
// クエリでは絶対に受けない。
// 静的セグメントは動的な [token] より優先されるので、/yoyaku/admin/ が
// 予約ページとして解決されることはない。
export const prerender = false;

import YoyakuLayout from '../../../layouts/YoyakuLayout.astro';
import {
  checkAdminKey,
  isKvConfigured,
  migrateLegacy,
  getEvents,
  getEvent,
  createEvent,
  saveEvent,
  deleteEvent,
  getEventStats,
  getSlots,
  getBookings,
  getSlot,
  addSlot,
  deleteSlot,
  saveSlot,
  cancelBooking,
  formatSlotJa,
  jstToday,
  type Booking,
  type EventInfo,
} from '../../../lib/yoyaku';
import { randomBytes } from 'node:crypto';

Astro.response.headers.set('Cache-Control', 'no-store');
Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow, noarchive');

const COOKIE = 'yoyaku_admin';
let error = '';
let loginFailed = false;
let message = Astro.url.searchParams.get('msg') ?? '';
let eventId = Astro.url.searchParams.get('event') ?? '';

// 認証はセッション Cookie（ブラウザを閉じると消える）。値は合言葉そのもの
// ではなくても良いが、サーバ側に状態を持たない構成なので毎回照合する。
let key = Astro.cookies.get(COOKIE)?.value ?? '';

const configured = isKvConfigured();

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const action = String(form.get('action') ?? '');
  if (action === 'login') {
    // 合言葉はコピペ由来の前後空白で弾かれやすいので trim して照合する
    const entered = String(form.get('key') ?? '').trim();
    if (checkAdminKey(entered)) {
      Astro.cookies.set(COOKIE, entered, {
        httpOnly: true,
        secure: true,
        sameSite: 'lax',
        path: '/yoyaku/admin',
      });
      return Astro.redirect(Astro.url.pathname, 303);
    }
    loginFailed = true;
  } else if (checkAdminKey(key) && configured) {
    await migrateLegacy();
    let msg = '';
    let redirectEvent = String(form.get('event') ?? '');

    if (action === 'create') {
      const title = String(form.get('title') ?? '').trim();
      if (!title) error = 'イベント名を入力してください。';
      else {
        const ev = await createEvent(title);
        redirectEvent = ev.id;
        msg = 'イベントを作成しました。下のURLをお客様に共有してください。';
      }
    } else {
      const ev = redirectEvent ? await getEvent(redirectEvent) : null;
      if (!ev) {
        error = 'イベントが見つかりません。';
      } else if (action === 'delevent') {
        const bookings = await getBookings(ev.id);
        if (bookings.size > 0) {
          error = 'このイベントには予約が入っています。先にすべての予約をキャンセルしてください。';
        } else {
          await deleteEvent(ev.id);
          redirectEvent = '';
          msg = `イベント「${ev.title}」を削除しました。`;
        }
      } else if (action === 'retoken') {
        await saveEvent({ ...ev, token: randomBytes(12).toString('hex') });
        msg = '共有URLを再発行しました。古いURLは無効になりました。';
      } else if (action === 'title') {
        const title = String(form.get('title') ?? '').trim();
        if (!title) error = 'タイトルを入力してください。';
        else {
          await saveEvent({ ...ev, title: title.slice(0, 80) });
          msg = '予約ページのタイトルを変更しました。';
        }
      } else if (action === 'notes') {
        const notes = String(form.get('notes') ?? '').trim().slice(0, 2000);
        await saveEvent({ ...ev, notes: notes || undefined });
        msg = notes
          ? 'ご案内文を保存しました。予約完了画面と確認・リマインドメールに表示されます。'
          : 'ご案内文を削除しました。';
      } else if (action === 'add') {
        const date = String(form.get('date') ?? '');
        const time = String(form.get('time') ?? '').trim().slice(0, 40);
        if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) error = '日付を選択してください。';
        else if (!time) error = '時間帯を入力してください（例：14:00〜16:00）。';
        else {
          await addSlot(ev.id, date, time);
          msg = '候補日を追加しました。';
        }
      } else if (action === 'bulkadd') {
        // 1行1枠「YYYY-MM-DD 時間帯」形式。公演のように枠が多いときに使う。
        const lines = String(form.get('lines') ?? '')
          .split('\n')
          .map((l) => l.trim())
          .filter(Boolean);
        let added = 0;
        const bad: string[] = [];
        for (const line of lines.slice(0, 100)) {
          const m = line.match(/^(\d{4}-\d{2}-\d{2})\s+(.+)$/);
          if (m) {
            await addSlot(ev.id, m[1], m[2].trim().slice(0, 40));
            added++;
          } else {
            bad.push(line);
          }
        }
        if (bad.length) error = `形式が読めない行があります（例：2026-09-02 18:00〜）：${bad[0]}`;
        else msg = `候補日を${added}件追加しました。`;
      } else if (action === 'close' || action === 'reopen') {
        const slot = await getSlot(ev.id, String(form.get('id') ?? ''));
        if (slot) {
          await saveSlot(ev.id, { ...slot, closed: action === 'close' });
          msg = action === 'close' ? '受付を停止しました。お客様の画面では「予約済み」と表示されます。' : '受付を再開しました。';
        }
      } else if (action === 'delslot') {
        const id = String(form.get('id') ?? '');
        const bookings = await getBookings(ev.id);
        if (bookings.has(id)) error = 'この枠には予約が入っています。先に予約をキャンセルしてください。';
        else {
          await deleteSlot(ev.id, id);
          msg = '候補日を削除しました。';
        }
      } else if (action === 'cancel') {
        await cancelBooking(ev.id, String(form.get('id') ?? ''));
        msg = '予約をキャンセルしました。枠は再び予約可能になります。';
      }
    }

    if (!error) {
      // PRG: リロードで同じ操作が再実行されないようリダイレクト
      const q = new URLSearchParams();
      if (redirectEvent) q.set('event', redirectEvent);
      if (msg) q.set('msg', msg);
      return Astro.redirect(`${Astro.url.pathname}?${q.toString()}`, 303);
    }
    eventId = redirectEvent || eventId;
  }
}

const authed = checkAdminKey(key);

if (authed && configured) await migrateLegacy();

// 一覧画面用データ
let events: (EventInfo & { stats: { slots: number; bookings: number } })[] = [];
// 個別イベント画面用データ
let ev: EventInfo | null = null;
let slots: Awaited<ReturnType<typeof getSlots>> = [];
let bookings = new Map<string, Booking>();

if (authed && configured) {
  if (eventId) {
    ev = await getEvent(eventId);
    if (ev) {
      [slots, bookings] = await Promise.all([getSlots(ev.id), getBookings(ev.id)]);
    }
  }
  if (!ev) {
    const list = await getEvents();
    events = await Promise.all(list.map(async (e) => ({ ...e, stats: await getEventStats(e.id) })));
  }
}

const today = jstToday();
const bookingList = [...bookings.values()].sort((a, b) => (a.date + a.time).localeCompare(b.date + b.time));
const shareUrl = ev ? new URL(`/yoyaku/${ev.token}/`, Astro.site ?? Astro.url).toString() : '';
---
<YoyakuLayout title="日程調整 管理｜株式会社 ex Labs">
<h1>日程調整 管理ページ</h1>

{!authed ? (
  <>
  {loginFailed && <p class="yk-error">合言葉が違います。</p>}
  <form method="POST" action={Astro.url.pathname}>
    <input type="hidden" name="action" value="login">
    <div class="yk-card">
      <label class="yk-field">管理用の合言葉
        <input type="password" name="key" required autocomplete="current-password">
      </label>
      <button class="yk-btn" type="submit">ログイン</button>
    </div>
  </form>
  </>
) : !configured ? (
  <p class="yk-error">データベース（Upstash Redis）が未接続です。Vercel の Storage 設定を確認してください（docs/yoyaku-setup.md 参照）。</p>
) : !ev ? (
  <>
  {message && <p class="yk-done">{message}</p>}
  {error && <p class="yk-error">{error}</p>}

  <h2>イベント一覧</h2>
  <div class="yk-card">
    {events.length === 0 ? (
      <p style="font-size:14px;color:#8a8378;margin:6px 0">イベントはまだありません。下のフォームから作成してください。</p>
    ) : (
      <table class="yk-table">
        <thead><tr><th>イベント</th><th>枠</th><th>予約</th><th></th></tr></thead>
        <tbody>
        {events.map((e) => (
          <tr>
            <td>{e.title}</td>
            <td>{e.stats.slots}</td>
            <td>{e.stats.bookings}</td>
            <td><a class="yk-btn small ghost" href={`${Astro.url.pathname}?event=${e.id}`}>管理する</a></td>
          </tr>
        ))}
        </tbody>
      </table>
    )}
  </div>

  <h2>新しいイベントを作成</h2>
  <form method="POST" action={Astro.url.pathname}>
    <input type="hidden" name="action" value="create">
    <div class="yk-card" style="padding-top:6px">
      <label class="yk-field">イベント名<small>お客様の画面の見出しになります</small>
        <input type="text" name="title" required maxlength="80" placeholder="〇〇公演 日程調整">
      </label>
      <button class="yk-btn" type="submit">作成する（共有URLが自動発行されます）</button>
    </div>
  </form>
  </>
) : (
  <>
  <p style="margin:0 0 8px"><a href={Astro.url.pathname} style="font-size:13px;color:#8a8378;text-decoration:underline">← イベント一覧に戻る</a></p>
  {message && <p class="yk-done">{message}</p>}
  {error && <p class="yk-error">{error}</p>}

  <h2>お客様に共有するURL</h2>
  <p class="yk-copy">{shareUrl}</p>
  <form method="POST" action={Astro.url.pathname} style="margin-top:8px" onsubmit="return confirm('共有URLを再発行すると、今までのURLは使えなくなります。よろしいですか？')">
    <input type="hidden" name="action" value="retoken">
    <input type="hidden" name="event" value={ev.id}>
    <button class="yk-del" type="submit">URLを再発行する（漏れてしまったとき用）</button>
  </form>

  <h2>予約ページのタイトル</h2>
  <form method="POST" action={Astro.url.pathname}>
    <input type="hidden" name="action" value="title">
    <input type="hidden" name="event" value={ev.id}>
    <div class="yk-card" style="padding-top:6px">
      <label class="yk-field">タイトル<small>お客様の画面の見出しになります</small>
        <input type="text" name="title" required maxlength="80" value={ev.title}>
      </label>
      <button class="yk-btn small ghost" type="submit" style="margin-top:16px">変更する</button>
    </div>
  </form>

  <h2>ご案内文（集合場所・注意事項など）</h2>
  <form method="POST" action={Astro.url.pathname}>
    <input type="hidden" name="action" value="notes">
    <input type="hidden" name="event" value={ev.id}>
    <div class="yk-card" style="padding-top:6px">
      <label class="yk-field">予約ページ・予約完了画面・確認/リマインドメールに表示されます<small>空にして保存すると非表示になります</small>
        <textarea name="notes" rows="6" maxlength="2000" placeholder={`【集合場所】\n〇〇ビル 2F 受付前（西新宿駅 徒歩3分）\n\n【注意事項】\n・開始10分前までにお越しください\n・キャンセルは前日までにご連絡ください`}>{ev.notes ?? ''}</textarea>
      </label>
      <button class="yk-btn small ghost" type="submit" style="margin-top:16px">保存する</button>
    </div>
  </form>

  <h2>候補日を追加</h2>
  <form method="POST" action={Astro.url.pathname}>
    <input type="hidden" name="action" value="add">
    <input type="hidden" name="event" value={ev.id}>
    <div class="yk-card" style="padding-top:6px">
      <div class="yk-row">
        <label class="yk-field">日付
          <input type="date" name="date" required min={today}>
        </label>
        <label class="yk-field">時間帯<small>例：14:00〜16:00</small>
          <input type="text" name="time" required maxlength="40" placeholder="14:00〜16:00">
        </label>
      </div>
      <button class="yk-btn" type="submit">追加する</button>
    </div>
  </form>

  <h2>候補日を一括追加</h2>
  <form method="POST" action={Astro.url.pathname}>
    <input type="hidden" name="action" value="bulkadd">
    <input type="hidden" name="event" value={ev.id}>
    <div class="yk-card" style="padding-top:6px">
      <label class="yk-field">1行に1枠、「日付（西暦-月-日） 時間帯」の形式で貼り付け
        <textarea name="lines" rows="6" placeholder={`2026-09-02 18:00〜\n2026-09-02 18:15〜\n2026-09-04 18:00〜`}></textarea>
      </label>
      <button class="yk-btn small ghost" type="submit" style="margin-top:16px">まとめて追加する</button>
    </div>
  </form>

  <h2>候補日と空き状況</h2>
  <div class="yk-card">
    {slots.length === 0 ? (
      <p style="font-size:14px;color:#8a8378;margin:6px 0">候補日はまだありません。上のフォームから追加してください。</p>
    ) : (
      <table class="yk-table">
        <thead><tr><th>日程</th><th>状態</th><th></th></tr></thead>
        <tbody>
        {slots.map((s) => {
          const b = bookings.get(s.id);
          return (
            <tr style={s.date < today ? 'opacity:.5' : ''}>
              <td>{formatSlotJa(s.date, s.time)}{s.date < today && '（過去）'}</td>
              <td>
                {b ? <span class="yk-status-booked">予約済み</span>
                  : s.closed ? <span class="yk-status-closed">停止中</span>
                  : <span class="yk-status-open">空き</span>}
              </td>
              <td style="white-space:nowrap">
                {!b && (
                  <>
                  <form class="yk-inline-form" method="POST" action={Astro.url.pathname}>
                    <input type="hidden" name="action" value={s.closed ? 'reopen' : 'close'}>
                    <input type="hidden" name="event" value={ev.id}>
                    <input type="hidden" name="id" value={s.id}>
                    <button class="yk-del" type="submit" style="color:#7a5d00">{s.closed ? '再開' : '受付停止'}</button>
                  </form>
                  {' '}
                  <form class="yk-inline-form" method="POST" action={Astro.url.pathname}>
                    <input type="hidden" name="action" value="delslot">
                    <input type="hidden" name="event" value={ev.id}>
                    <input type="hidden" name="id" value={s.id}>
                    <button class="yk-del" type="submit">削除</button>
                  </form>
                  </>
                )}
              </td>
            </tr>
          );
        })}
        </tbody>
      </table>
    )}
  </div>

  <h2>予約一覧</h2>
  <div class="yk-card">
    {bookingList.length === 0 ? (
      <p style="font-size:14px;color:#8a8378;margin:6px 0">予約はまだありません。</p>
    ) : (
      <table class="yk-table">
        <thead><tr><th>日程</th><th>お客様</th><th>連絡先</th><th>リマインド</th><th></th></tr></thead>
        <tbody>
        {bookingList.map((b) => (
          <tr>
            <td>{formatSlotJa(b.date, b.time)}</td>
            <td>{b.name}</td>
            <td>{b.phone}<br>{b.email}</td>
            <td>{b.remindedAt ? '送信済み' : '未送信'}</td>
            <td>
              <form class="yk-inline-form" method="POST" action={Astro.url.pathname}>
                <input type="hidden" name="action" value="cancel">
                <input type="hidden" name="event" value={ev.id}>
                <input type="hidden" name="id" value={b.slotId}>
                <button class="yk-del" type="submit">キャンセル</button>
              </form>
            </td>
          </tr>
        ))}
        </tbody>
      </table>
    )}
  </div>

  <h2>イベントの削除</h2>
  <div class="yk-card">
    <p style="font-size:13.5px;color:#8a8378;margin:4px 0 12px">イベントと候補日をすべて削除します。予約が1件でも入っている間は削除できません（先に予約一覧からキャンセルしてください）。</p>
    <form method="POST" action={Astro.url.pathname} onsubmit="return confirm('このイベントを削除します。共有URLも使えなくなります。よろしいですか？')">
      <input type="hidden" name="action" value="delevent">
      <input type="hidden" name="event" value={ev.id}>
      <button class="yk-del" type="submit">このイベントを削除する</button>
    </form>
  </div>
  </>
)}
</YoyakuLayout>
