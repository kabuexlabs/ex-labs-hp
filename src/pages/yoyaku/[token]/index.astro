---
// リンク共有したときだけ見える非公開の日程調整ページ。
// URL の [token] が BOOKING_PAGE_TOKEN と一致しなければ 404 を返すので、
// リンクを知らない人・クローラーからは存在ごと見えない。
export const prerender = false;

import YoyakuLayout from '../../../layouts/YoyakuLayout.astro';
import {
  checkPageToken,
  isKvConfigured,
  getSlots,
  getBookings,
  getSlot,
  getPageTitle,
  reserve,
  sendMail,
  adminEmail,
  formatSlotJa,
  jstToday,
  normalizePhone,
  validPhone,
  validEmail,
} from '../../../lib/yoyaku';

if (!checkPageToken(Astro.params.token)) {
  return new Response('Not Found', { status: 404, headers: { 'Content-Type': 'text/plain' } });
}

Astro.response.headers.set('Cache-Control', 'no-store');
Astro.response.headers.set('X-Robots-Tag', 'noindex, nofollow, noarchive');

const configured = isKvConfigured();

let error = '';
let prev = { name: '', phone: '', email: '', slotId: '' };

if (configured && Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const name = String(form.get('name') ?? '').trim().slice(0, 50);
  const phone = normalizePhone(String(form.get('phone') ?? ''));
  const email = String(form.get('email') ?? '').trim();
  const slotId = String(form.get('slot') ?? '');
  prev = { name, phone, email, slotId };

  if (!name) error = 'ハンドルネームを入力してください。';
  else if (!validPhone(phone)) error = '電話番号の形式をご確認ください（例：090-1234-5678）。';
  else if (!validEmail(email)) error = 'メールアドレスの形式をご確認ください。';
  else if (!slotId) error = 'ご希望の日程を選択してください。';
  else {
    const slot = await getSlot(slotId);
    if (!slot || slot.closed || slot.date < jstToday()) {
      error = '選択された日程は現在ご予約いただけません。別の日程をお選びください。';
    } else if (!(await reserve(slot, { name, phone, email }))) {
      // HSETNX が負けた = 直前に他の方が同じ枠を確保した
      error = '申し訳ありません、この日程はたった今埋まってしまいました。別の日程をお選びください。';
    } else {
      const when = formatSlotJa(slot.date, slot.time);
      await Promise.all([
        sendMail(
          email,
          '【ex Labs】ご予約を承りました',
          `${name} 様\n\nご予約ありがとうございます。以下の内容で承りました。\n\n` +
            `■ 日程\n${when}\n\n■ ご入力内容\nハンドルネーム：${name}\n電話番号：${phone}\nメールアドレス：${email}\n\n` +
            `前日にリマインドメールをお送りします。\n変更・キャンセルはこのメールへの返信、または ${adminEmail()} までご連絡ください。\n\n株式会社 ex Labs`,
        ),
        sendMail(
          adminEmail(),
          `【予約】新規予約が入りました：${when}`,
          `予約ページから新しい予約が入りました。\n\n■ 日程\n${when}\n\n` +
            `■ お客様情報\nハンドルネーム：${name}\n電話番号：${phone}\nメールアドレス：${email}\n\n` +
            `管理ページ：${new URL('/yoyaku/admin/', Astro.site ?? Astro.url).toString()}`,
        ),
      ]);
      // PRG: リロードによる二重送信を防ぐため、完了画面へリダイレクト
      return Astro.redirect(`${Astro.url.pathname}?done=${encodeURIComponent(slotId)}`, 303);
    }
  }
}

const doneId = Astro.url.searchParams.get('done');
const today = jstToday();

const [slots, bookings, pageTitle] = configured
  ? await Promise.all([getSlots(), getBookings(), getPageTitle()])
  : [[], new Map(), '日程調整のご案内'];
// 過去の日付は出さない。予約済み・受付停止の枠は「予約済み」表示で残す
// （埋まり具合が伝わる）。
const visible = slots.filter((s) => s.date >= today);
const doneSlot = doneId ? slots.find((s) => s.id === doneId) : undefined;
const hasOpen = visible.some((s) => !bookings.has(s.id) && !s.closed);
---
<YoyakuLayout title={`${pageTitle}｜株式会社 ex Labs`}>
<h1>{pageTitle}</h1>
<p class="yk-lede">下記の候補からご希望の日程をお選びのうえ、必要事項をご入力ください。ご予約いただいた日程は他の方は選べなくなります。前日にリマインドメールをお送りします。</p>

{doneSlot ? (
  <div class="yk-done">
    <strong>ご予約を承りました</strong>
    日程：{formatSlotJa(doneSlot.date, doneSlot.time)}<br>
    確認メールをお送りしました。前日にもリマインドメールが届きます。<br>
    変更・キャンセルは {adminEmail()} までご連絡ください。
  </div>
) : !configured ? (
  <p class="yk-notice">現在このページは準備中です。恐れ入りますが、しばらく経ってから再度アクセスしてください。</p>
) : (
  <>
  {error && <p class="yk-error">{error}</p>}
  {!hasOpen ? (
    <p class="yk-notice">現在ご予約いただける日程がありません。恐れ入りますが、担当者までお問い合わせください（{adminEmail()}）。</p>
  ) : (
    <form method="POST" action={Astro.url.pathname}>
      <h2>1. ご希望の日程</h2>
      <div class="yk-card">
        {visible.map((s) => {
          const full = bookings.has(s.id) || s.closed;
          return full ? (
            <p class="yk-slot is-full">{formatSlotJa(s.date, s.time)}<span class="yk-full-tag">予約済み</span></p>
          ) : (
            <label class="yk-slot">
              <input type="radio" name="slot" value={s.id} required checked={prev.slotId === s.id}>
              {formatSlotJa(s.date, s.time)}
            </label>
          );
        })}
      </div>

      <h2>2. お客様情報</h2>
      <div class="yk-card" style="padding-top:6px">
        <label class="yk-field">ハンドルネーム
          <input type="text" name="name" required maxlength="50" autocomplete="nickname" value={prev.name}>
        </label>
        <label class="yk-field">電話番号<small>当日ご連絡が取れる番号</small>
          <input type="tel" name="phone" required autocomplete="tel" placeholder="090-1234-5678" value={prev.phone}>
        </label>
        <label class="yk-field">メールアドレス<small>確認・リマインドメールが届きます</small>
          <input type="email" name="email" required autocomplete="email" placeholder="example@example.com" value={prev.email}>
        </label>
      </div>

      <button class="yk-btn" type="submit">この内容で予約する</button>
    </form>
  )}
  </>
)}
</YoyakuLayout>
