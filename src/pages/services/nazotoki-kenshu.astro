---
// Rendered on request so newly published blog posts appear in the
// related-articles section without a redeploy.
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import LatestPosts from '../../components/LatestPosts.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import HeroWorksMarquee from '../../components/HeroWorksMarquee.astro';

const faqs = [
  {
    q: '謎解き研修は何人から実施できますか？',
    a: '少人数のチーム単位から数百名規模の全社イベントまで、人数に応じてプログラムを設計します。まずは想定人数をお知らせください。',
  },
  {
    q: '会場はどこで実施できますか？',
    a: '貴社の会議室・研修施設・宴会場など、既存のスペースを活用して実施できます。会場選びの段階からのご相談も可能です。',
  },
  {
    q: '費用はどのくらいかかりますか？',
    a: '人数・内容・オリジナル制作の有無により異なります。ご予算に応じたご提案をいたしますので、お問い合わせフォームよりお気軽にご相談ください。',
  },
  {
    q: '既存の研修プログラムはありますか？それとも完全オリジナルですか？',
    a: '目的（チームビルディング・相互理解・理念浸透・懇親など）に合わせて、既存コンテンツの活用からフルオリジナル制作まで柔軟に対応します。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: '謎解き研修',
  name: '謎解き研修',
  description: '謎解きを活用した体験型の社内研修・チームビルディングプログラムの企画・制作',
  provider: { '@type': 'Organization', name: '株式会社ex Labs', url: new URL('/', Astro.site).toString() },
  areaServed: 'JP',
  url: new URL('/services/nazotoki-kenshu/', Astro.site).toString(),
};
---
<BaseLayout
  title="謎解き研修｜体験型チームビルディング研修の企画・制作 - 株式会社ex Labs"
  description="謎解き研修・体験型チームビルディングの企画・制作なら株式会社ex Labs。商業イベントで培ったシナリオ制作力で、貴社の目的に合わせたオリジナル研修プログラムを設計。企画から当日運営まで一貫対応します。"
>
<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceLd)} />
<Breadcrumb items={[
  { name: 'ホーム', href: '/' },
  { name: 'サービス', href: '/services/' },
  { name: '謎解き研修' },
]} />

<section class="hero">
<div class="hero-overlay"></div>
<div class="wrap hero-center" style="padding-top:36px;padding-bottom:44px">
<img class="hero-logo" src="/assets/logo.png" alt="株式会社 ex Labs" width="2048" height="520" loading="eager" decoding="async" style="width:min(220px,46vw);margin-bottom:26px">
<h1 class="hero-title serif"><span class="hl">自社の社員研修や採用を</span><br><span class="hl">『面白い』コンテンツにしませんか？</span></h1>
<p class="hero-sub">Team Building Workshop — ex Labs Inc.</p>
<div class="hero-actions">
<a class="btn" href="/#contact">相談してみる</a>
<a class="btn ghost" href="#works">実績を見る</a>
</div>
</div>
<HeroWorksMarquee />
</section>

<section class="section" style="padding-top:56px"><div class="wrap">
<p class="lede">株式会社ex Labsは、謎解きを活用した<strong>体験型の社内研修・チームビルディングプログラム</strong>を企画・制作しています。参加者が自然と協力し合う「体験」を通じて、<strong>コミュニケーションの活性化やチームの相互理解</strong>を促進します。</p>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">ISSUES</p>
<h2 class="h2 serif">こんな課題はありませんか？</h2>
<ul class="bullets">
<li>部署間・拠点間のコミュニケーションが不足している</li>
<li>新入社員・内定者同士の距離を縮めたい</li>
<li>座学中心の研修では参加者が受け身になってしまう</li>
<li>全社イベント・懇親会のコンテンツがマンネリ化している</li>
</ul>
<div class="rule"></div>
<p class="lede">謎解きは「協力しなければ解けない」構造を自然に作れるため、役職や部署を越えたフラットなコミュニケーションが生まれます。楽しみながら取り組むうちに、チームの強み・課題が見えてくるのが体験型研修の特長です。</p>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">FEATURES</p>
<h2 class="h2 serif">ex Labsの謎解き研修が選ばれる理由</h2>
<div class="str-grid tag-nazotoki">
<div class="str-card"><p class="str-num">01</p><h3 class="str-title">商業イベントで培ったシナリオ制作力</h3>
<p class="str-lead">神戸須磨シーワールド様、博報堂×紀伊國屋書店様など、商業施設・大手企業との体験型イベント制作実績。</p>
<ul class="feature-points"><li>「参加者を夢中にさせる」プロのコンテンツ設計力</li><li>研修プログラムにそのまま活かせるノウハウ</li></ul></div>
<div class="str-card"><p class="str-num">02</p><h3 class="str-title">目的に合わせたオリジナル設計</h3>
<p class="str-lead">人数・会場・研修の目的をヒアリングした上で、貴社に合わせたプログラムを設計。</p>
<ul class="feature-points"><li>目的例：チームビルディング・相互理解・理念浸透・懇親</li><li>企画から当日の運営・進行まで一貫してご支援</li></ul></div>
</div>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">SCENE</p>
<h2 class="h2 serif">こんなシーンで活用されています</h2>
<ul class="about-points">
<li>新入社員・内定者研修でのアイスブレイク</li>
<li>部署間・拠点間の交流イベント</li>
<li>経営理念・ビジョンの浸透施策</li>
<li>全社総会・懇親会のコンテンツ</li>
</ul>
</div></section>

<section class="section" id="works"><div class="wrap">
<p class="eyebrow">WORKS</p>
<h2 class="h2 serif">シナリオ制作力の裏付けとなる実績</h2>
<p class="h2sub">謎解き研修のノウハウは、以下の商業イベント制作実績から培われています。</p>
<div class="hero-works" style="max-width:900px;margin:0 auto">
<div class="hero-works-track">
{[...Array(2)].map(() => (
  <>
  <img src="/assets/work-0.webp" alt="神戸須磨シーワールドの謎解きイベント" width="880" height="1254" loading="lazy" decoding="async">
  <img src="/assets/work-1.webp" alt="博報堂×紀伊國屋書店の体験型イベント" width="849" height="1200" loading="lazy" decoding="async">
  </>
))}
</div>
</div>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">FLOW</p>
<h2 class="h2 serif">導入までの流れ</h2>
<div class="flow-row">
<div class="flow-step"><p class="flow-num">01</p><p class="flow-t">ヒアリング</p><p class="flow-d">目的・人数・会場・予算をヒアリング</p></div>
<div class="flow-step"><p class="flow-num">02</p><p class="flow-t">プログラム設計</p><p class="flow-d">目的に合わせた謎解き・進行内容を設計</p></div>
<div class="flow-step"><p class="flow-num">03</p><p class="flow-t">準備・最終調整</p><p class="flow-d">進行台本・配布物・運営体制の確定</p></div>
<div class="flow-step"><p class="flow-num">04</p><p class="flow-t">当日実施</p><p class="flow-d">進行から振り返りまで一貫してサポート</p></div>
</div>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">FAQ</p>
<h2 class="h2 serif">よくあるご質問</h2>
<div class="faq-list tag-nazotoki">
{faqs.map((f) => (
  <div class="faq-item">
    <p class="faq-q">{f.q}</p>
    <p class="faq-a">{f.a}</p>
  </div>
))}
</div>
</div></section>

<section class="section"><div class="wrap">
<div class="cta-mini">
<p class="cta-mini-title serif">謎解き研修のご相談はこちら</p>
<a class="btn" href="/#contact">謎解き研修について相談する</a>
</div>
<p class="vc-line" style="margin-top:48px">関連サービス：<a href="/services/murder-mystery/" style="color:var(--accent)">マーダーミステリー制作</a>／<a href="/services/shisetsu-event/" style="color:var(--accent)">施設活用イベント</a>／<a href="/services/zunousen/" style="color:var(--accent)">頭脳戦制作</a></p>
</div></section>

<LatestPosts category="nazotoki" />

</BaseLayout>
