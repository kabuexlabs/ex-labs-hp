---
// Rendered on request so newly published blog posts appear in the
// related-articles section without a redeploy.
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { jsonLd } from '../../lib/microcms';
import LatestPosts from '../../components/LatestPosts.astro';
import VoiceMarquee from '../../components/VoiceMarquee.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import HeroWorksMarquee from '../../components/HeroWorksMarquee.astro';
import { zunousenVoices } from '../../data/voices';

const faqs = [
  {
    q: '「頭脳戦」とはどのようなコンテンツですか？',
    a: '交渉・心理戦・閃きを軸にした対人ゲーム形式のコンテンツです。ライアーゲームのような、正解が一つに定まらない駆け引きを通じて、参加者同士の腹の探り合いや逆転の展開を楽しんでいただけます。',
  },
  {
    q: '謎解きとは何が違うのですか？',
    a: '謎解きは「参加者全員で協力して謎を解く」形式ですが、頭脳戦は参加者同士が交渉・裏切り・駆け引きを行う対戦形式です。謎解きに特化した制作団体は増えていますが、この対人交渉型ゲームに特化した制作団体は国内でも他に例がなく、ex Labsが唯一の専門集団です。',
  },
  {
    q: '何人から実施できますか？',
    a: '作品によって異なりますが、少人数の卓上ゲーム形式から、東京都頭脳王決定戦のような都内4会場・大人数同時開催の大型企画まで対応可能です。',
  },
  {
    q: 'オリジナル作品の制作も依頼できますか？',
    a: 'はい。プレゼント・ポーカー、人狼定理、ダイスボックスなど複数の頭脳戦コンテンツを制作してきた実績をもとに、貴社のご要望に合わせたオリジナルゲームを企画・制作します。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: '頭脳戦制作・交渉戦制作',
  name: '頭脳戦制作・交渉戦制作',
  description: 'ライアーゲームのような交渉ゲーム・心理戦・閃きのゲームに特化したオリジナル頭脳戦コンテンツの企画・制作',
  provider: { '@type': 'Organization', name: '株式会社ex Labs', url: new URL('/', Astro.site).toString() },
  areaServed: 'JP',
  url: new URL('/services/zunousen/', Astro.site).toString(),
};
---
<BaseLayout
  title="頭脳戦制作・交渉戦制作｜交渉ゲーム・心理戦コンテンツ - 株式会社ex Labs"
  description="頭脳戦制作・交渉戦制作なら株式会社ex Labs。ライアーゲームのような交渉ゲーム・心理戦・閃きのゲームに特化した、日本唯一の専門制作団体。東京都頭脳王決定戦の実績をもとに、オリジナルの頭脳戦・交渉戦コンテンツを企画・制作します。"
>
<script type="application/ld+json" set:html={jsonLd(faqLd)} />
<script type="application/ld+json" set:html={jsonLd(serviceLd)} />
<Breadcrumb items={[
  { name: 'ホーム', href: '/' },
  { name: 'サービス', href: '/services/' },
  { name: '頭脳戦制作' },
]} />

<section class="hero">
<div class="hero-overlay"></div>
<div class="wrap hero-center" style="padding-top:36px;padding-bottom:44px">
<img class="hero-logo" src="/assets/logo.png" alt="株式会社 ex Labs" width="2048" height="520" loading="eager" decoding="async" style="width:min(220px,46vw);margin-bottom:26px">
<h1 class="hero-title serif"><span class="hl">日本で唯一の頭脳戦制作団体に</span><br><span class="hl">頭脳戦を制作依頼しませんか？</span></h1>
<p class="hero-sub">Mind Battle Production — ex Labs Inc.</p>
<div class="hero-actions">
<a class="btn" href="/#contact">相談してみる</a>
<a class="btn ghost" href="#works">実績を見る</a>
</div>
</div>
<HeroWorksMarquee />
</section>

<section class="section" style="padding-top:56px"><div class="wrap">
<p class="eyebrow">SERVICE</p>
<h2 class="h2 serif">頭脳戦制作・交渉戦制作｜交渉ゲーム・心理戦コンテンツ</h2>
<p class="lede">株式会社ex Labsは、<strong>ライアーゲームのような交渉ゲーム・交渉戦・閃きのゲーム</strong>を制作可能な、<strong>日本で唯一の頭脳戦特化制作団体</strong>を保有しています。謎解きに特化した制作団体は複数存在しますが、対人交渉・心理戦を軸にしたこの手のゲームに特化した団体は他に例がありません。</p>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">ISSUES</p>
<h2 class="h2 serif">こんなご要望はありませんか？</h2>
<ul class="bullets">
<li>謎解きとは違う、駆け引きや心理戦を楽しめるコンテンツを探している</li>
<li>参加者同士が本気で盛り上がる対戦形式の企画を実施したい</li>
<li>大人数が同時に参加できる大型の頭脳戦イベントを開催したい</li>
<li>オリジナルの頭脳戦ゲームを一から制作してほしい</li>
</ul>
<div class="rule"></div>
<p class="lede">頭脳戦は「協力すれば解ける」謎解きとは異なり、<strong>読み合い・裏切り・逆転</strong>が生まれる対戦構造が魅力です。正解が一つに定まらないからこそ、プレイするたびに違うドラマが生まれます。</p>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">FEATURES</p>
<h2 class="h2 serif">ex Labsの頭脳戦制作が選ばれる理由</h2>
<div class="str-grid tag-zunou">
<div class="str-card"><p class="str-num">01</p><h3 class="str-title">日本で唯一の頭脳戦特化団体</h3>
<p class="str-lead">交渉・心理戦・閃きを軸にした頭脳戦コンテンツに特化した制作団体は、ex Labs以外に例がありません。</p>
<ul class="feature-points"><li>謎解き団体は数多くあるが、頭脳戦特化は国内唯一</li><li>特化しているからこそのゲームバランス設計力</li></ul></div>
<div class="str-card"><p class="str-num">02</p><h3 class="str-title">大型イベントでの実施実績</h3>
<p class="str-lead">自社主催「東京都頭脳王決定戦」を企画・運営し、ご好評をいただきました。</p>
<ul class="feature-points"><li>東京都内4会場を同時に活用した大型イベント</li><li>「東京都で最も頭の良い人を決める」というコンセプト</li></ul></div>
</div>
</div></section>

<section class="section tinted" id="works"><div class="wrap">
<p class="eyebrow">TITLES</p>
<h2 class="h2 serif">頭脳戦の制作作品例</h2>
<p class="h2sub">これまでに手がけた頭脳戦コンテンツの一部をご紹介します。</p>
<div class="works-grid" style="grid-template-columns:repeat(3,1fr)">
<div class="work-card"><img class="mm-poster" src="/assets/zunousen/present-poker.webp" alt="プレゼント・ポーカー ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">プレゼント・ポーカー</h3>
<p class="work-sub">TIME 240min／PLAYER 6</p>
<p class="work-desc">裏技を見抜き、それを早く行動したプレイヤーが勝利できるゲーム。</p></div>
<div class="work-card"><img class="mm-poster" src="/assets/zunousen/werewolf-theorem.webp" alt="人狼定理 ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">人狼定理</h3>
<p class="work-sub">TIME 240min／PLAYER 8</p>
<p class="work-desc">論理を突き詰めたプレイヤーが勝利できるゲーム。</p></div>
<div class="work-card"><img class="mm-poster" src="/assets/zunousen/dice-box.webp" alt="ダイスボックス ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">ダイスボックス</h3>
<p class="work-sub">TIME 240min／PLAYER 9-12</p>
<p class="work-desc">閃きと論理性の全てが必要になる、高難易度のゲーム。</p></div>
</div>
<p class="vc-line" style="margin-top:32px">自社主催「東京都頭脳王決定戦」の実績はこちら。<a href="/#works" style="color:var(--accent)">実績一覧を見る</a></p>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">FLOW</p>
<h2 class="h2 serif">頭脳戦制作の流れ</h2>
<div class="flow-row">
<div class="flow-step"><p class="flow-num">01</p><p class="flow-t">企画確定</p><p class="flow-d">ルール設計・参加人数・会場規模の決定</p></div>
<div class="flow-step"><p class="flow-num">02</p><p class="flow-t">コンテンツ制作</p><p class="flow-d">ゲームバランス調整・進行台本の制作</p></div>
<div class="flow-step"><p class="flow-num">03</p><p class="flow-t">リリース準備</p><p class="flow-d">進行リハーサル・運営体制の最終調整</p></div>
<div class="flow-step"><p class="flow-num">04</p><p class="flow-t">当日実施</p><p class="flow-d">MC進行、複数会場の同時運営にも対応</p></div>
</div>
</div></section>

<VoiceMarquee voices={zunousenVoices} />

<section class="section tinted"><div class="wrap">
<p class="eyebrow">FAQ</p>
<h2 class="h2 serif">よくあるご質問</h2>
<div class="faq-list tag-zunou">
{faqs.map((f) => (
  <div class="faq-item">
    <p class="faq-q">{f.q}</p>
    <p class="faq-a">{f.a}</p>
  </div>
))}
</div>
</div></section>

<section class="section"><div class="wrap">
<div class="cta-mini">
<p class="cta-mini-title serif">頭脳戦制作のご相談はこちら</p>
<a class="btn" href="/#contact">頭脳戦制作について相談する</a>
</div>
<p class="vc-line" style="margin-top:48px">関連サービス：<a href="/services/nazotoki-kenshu/" style="color:var(--accent)">謎解き研修</a>／<a href="/services/murder-mystery/" style="color:var(--accent)">マーダーミステリー制作</a>／<a href="/services/shisetsu-event/" style="color:var(--accent)">施設活用イベント</a></p>
</div></section>

<LatestPosts category="zunou" />

</BaseLayout>
