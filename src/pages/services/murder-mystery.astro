---
// Rendered on request so newly published blog posts appear in the
// related-articles section without a redeploy.
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import { jsonLd } from '../../lib/microcms';
import LatestPosts from '../../components/LatestPosts.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import HeroWorksMarquee from '../../components/HeroWorksMarquee.astro';

const faqs = [
  {
    q: 'マーダーミステリーの制作期間はどのくらいですか？',
    a: '作品の規模・形式により異なりますが、企画確定からシナリオ制作・デバッグ・リリース準備まで一貫した制作フローで進行します。案件内容によっては短期間での制作にも柔軟に対応しますので、希望時期をご相談ください。',
  },
  {
    q: 'オンライン向けの作品も制作できますか？',
    a: 'はい。オンライン向けのマーダーミステリー作品も複数制作した実績があります。配信企画・オンラインイベントいずれも対応可能です。',
  },
  {
    q: '店舗や施設の集客コンテンツとして依頼できますか？',
    a: '可能です。宿泊施設サーマルクライムスタジオ様向けに宿泊者向けコンテンツを制作し、実施後に新規宿泊予約20件以上の獲得につながった実績があります。',
  },
  {
    q: '費用はどのくらいかかりますか？',
    a: '作品の形式・規模・利用範囲により異なります。案件によっては初期費用を抑えたご提案やレベニューシェア型での実施にも対応しておりますので、まずはご相談ください。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  serviceType: 'マーダーミステリー制作',
  name: 'マーダーミステリー制作',
  description: 'オンライン・オフライン問わず、目的に合わせたオリジナルマーダーミステリー作品の企画・シナリオ制作',
  provider: { '@type': 'Organization', name: '株式会社ex Labs', url: new URL('/', Astro.site).toString() },
  areaServed: 'JP',
  url: new URL('/services/murder-mystery/', Astro.site).toString(),
};
---
<BaseLayout
  title="マーダーミステリー制作のご依頼｜企画・シナリオ制作 - 株式会社ex Labs"
  description="マーダーミステリーの制作依頼なら株式会社ex Labs。動画企画・店舗集客・イベント向けなど、目的に合わせたオリジナル作品の企画からシナリオ制作・運営まで対応します。"
>
<script type="application/ld+json" set:html={jsonLd(faqLd)} />
<script type="application/ld+json" set:html={jsonLd(serviceLd)} />
<Breadcrumb items={[
  { name: 'ホーム', href: '/' },
  { name: 'サービス', href: '/services/' },
  { name: 'マーダーミステリー制作' },
]} />

<section class="hero">
<div class="hero-overlay"></div>
<div class="wrap hero-center" style="padding-top:36px;padding-bottom:44px">
<img class="hero-logo" src="/assets/logo.png" alt="株式会社 ex Labs" width="2048" height="520" loading="eager" decoding="async" style="width:min(220px,46vw);margin-bottom:26px">
<h1 class="hero-title serif"><span class="hl">マーダーミステリーの制作なら</span><br><span class="hl">制作実績のあるex Labsに！</span></h1>
<p class="hero-sub">Murder Mystery Production — ex Labs Inc.</p>
<div class="hero-actions">
<a class="btn" href="/#contact">相談してみる</a>
<a class="btn ghost" href="#works">実績を見る</a>
</div>
</div>
<HeroWorksMarquee />
</section>

<section class="section" style="padding-top:56px"><div class="wrap">
<p class="eyebrow">SERVICE</p>
<h2 class="h2 serif">マーダーミステリー制作のご依頼</h2>
<p class="lede">株式会社ex Labsは、オンライン・オフラインを問わず<strong>マーダーミステリー作品の企画・シナリオ制作</strong>を承っています。物語への没入と推理の面白さを両立させた、<strong>目的に合わせたオリジナル作品</strong>をお届けします。</p>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">USE CASES</p>
<h2 class="h2 serif">マーダーミステリー制作の依頼例</h2>
<ul class="bullets">
<li>動画・配信企画用のマーダーミステリー制作</li>
<li>店舗・宿泊施設の集客コンテンツとしての導入</li>
<li>イベント・プロモーション用オリジナル作品の制作</li>
<li>社内研修・チームビルディング向けプログラム</li>
</ul>
</div></section>

<section class="section" id="works"><div class="wrap">
<p class="eyebrow">WORKS</p>
<h2 class="h2 serif">マーダーミステリーの制作実績</h2>
<div class="str-grid tag-murder" style="grid-template-columns:1fr;max-width:520px;margin:0 auto">
<div class="str-card"><p class="str-num">01</p><h3 class="str-title">サーマルクライムスタジオ様（宿泊施設）</h3>
<p class="str-lead">宿泊者向けマーダーミステリーコンテンツを制作。</p>
<ul class="feature-points"><li>実施後、新規宿泊予約20件以上の獲得につながった実績</li><li>コンテンツによる集客効果を実証</li></ul></div>
</div>
<p class="vc-line" style="margin-top:32px">このほか、<a href="/services/nazotoki-kenshu/" style="color:var(--accent)">謎解き</a>・<a href="/services/zunousen/" style="color:var(--accent)">頭脳戦</a>・イマーシブコンテンツなど複数ジャンルの制作実績があります。<a href="/#works" style="color:var(--accent)">実績一覧を見る</a></p>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">TITLES</p>
<h2 class="h2 serif">マーダーミステリーの制作作品例</h2>
<p class="h2sub">展開団体「東大マーダーミステリーサークル」のレーベルより、代表作品をご紹介します。</p>
<div class="works-grid">
<div class="work-card"><img class="mm-poster" src="/assets/mm/aru-mm.webp" alt="あるマーダーミステリーについて ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">あるマーダーミステリーについて</h3>
<p class="work-desc">評価サイト「毎月マダミスアンケート」で3か月連続1位を達成した作品。</p></div>
<div class="work-card"><img class="mm-poster" src="/assets/mm/frankenstein.webp" alt="フランケンシュタイン城の殺人 ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">フランケンシュタイン城の殺人</h3>
<p class="work-desc">マーダーミステリーでは希少な本格推理作品。オフラインでプレイ可能。</p></div>
<div class="work-card"><img class="mm-poster" src="/assets/mm/blue-diamond.webp" alt="ブルーダイヤの不在証明 ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">ブルーダイヤの不在証明</h3>
<p class="work-desc">オンライン・4人でプレイ可能な作品。プレイヤー全員で協力し、犯人の特定を目指す。</p></div>
</div>
<p class="vc-line" style="margin-top:40px">上記の3作品のほかにも、20作品以上の制作実績がございます。</p>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">FLOW</p>
<h2 class="h2 serif">マーダーミステリー制作の流れ</h2>
<div class="flow-row">
<div class="flow-step"><p class="flow-num">01</p><p class="flow-t">企画確定</p><p class="flow-d">利用目的・プレイ人数・形式（オンライン/オフライン）の決定</p></div>
<div class="flow-step"><p class="flow-num">02</p><p class="flow-t">シナリオ制作</p><p class="flow-d">脚本・トリック設計・デバッグプレイ</p></div>
<div class="flow-step"><p class="flow-num">03</p><p class="flow-t">リリース準備</p><p class="flow-d">進行マニュアル・配布物・告知素材の準備</p></div>
<div class="flow-step"><p class="flow-num">04</p><p class="flow-t">実施・運営</p><p class="flow-d">当日の進行、配信対応など柔軟にサポート</p></div>
</div>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">FAQ</p>
<h2 class="h2 serif">よくあるご質問</h2>
<div class="faq-list tag-murder">
{faqs.map((f) => (
  <div class="faq-item">
    <p class="faq-q">{f.q}</p>
    <p class="faq-a">{f.a}</p>
  </div>
))}
</div>
</div></section>

<section class="section"><div class="wrap">
<div class="cta-mini">
<p class="cta-mini-title serif">マーダーミステリー制作のご相談はこちら</p>
<a class="btn" href="/#contact">マーダーミステリー制作について相談する</a>
</div>
<p class="vc-line" style="margin-top:48px">関連サービス：<a href="/services/nazotoki-kenshu/" style="color:var(--accent)">謎解き研修</a>／<a href="/services/shisetsu-event/" style="color:var(--accent)">施設活用イベント</a>／<a href="/services/zunousen/" style="color:var(--accent)">頭脳戦制作</a></p>
</div></section>

<LatestPosts category="murder" />

</BaseLayout>
