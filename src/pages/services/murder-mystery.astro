---
// Rendered on request so newly published blog posts appear in the
// related-articles section without a redeploy.
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import LatestPosts from '../../components/LatestPosts.astro';

const faqs = [
  {
    q: 'マーダーミステリーの制作期間はどのくらいですか？',
    a: '作品の規模・形式により異なりますが、企画確定からシナリオ制作・デバッグ・リリース準備まで一貫した制作フローで進行します。案件内容によっては短期間での制作にも柔軟に対応しますので、希望時期をご相談ください。',
  },
  {
    q: 'オンライン向けの作品も制作できますか？',
    a: 'はい。YouTuberヒカル様のオンライン向けマーダーミステリー作品を累計3作品制作した実績があります。配信企画・オンラインイベントいずれも対応可能です。',
  },
  {
    q: '店舗や施設の集客コンテンツとして依頼できますか？',
    a: '可能です。宿泊施設サーマルクライムスタジオ様向けに宿泊者向けコンテンツを制作し、実施後に新規宿泊予約20件以上の獲得につながった実績があります。',
  },
  {
    q: '費用はどのくらいかかりますか？',
    a: '作品の形式・規模・利用範囲により異なります。案件によっては初期費用を抑えたご提案やレベニューシェア型での実施にも対応しておりますので、まずはご相談ください。',
  },
];

const faqLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'ホーム', item: new URL('/', Astro.site).toString() },
    { '@type': 'ListItem', position: 2, name: 'サービス', item: new URL('/services/', Astro.site).toString() },
    { '@type': 'ListItem', position: 3, name: 'マーダーミステリー制作' },
  ],
};
---
<BaseLayout
  title="マーダーミステリー制作のご依頼｜企画・シナリオ制作 - 株式会社ex Labs"
  description="マーダーミステリーの制作依頼なら株式会社ex Labs。YouTuberヒカル様のオンライン作品を累計3作品制作。動画企画・店舗集客・イベント向けなど、目的に合わせたオリジナル作品の企画からシナリオ制作・運営まで対応します。"
>
<script type="application/ld+json" set:html={JSON.stringify(faqLd)} />
<script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />

<section class="section" style="padding-top:160px"><div class="wrap">
<p class="eyebrow">SERVICE</p>
<h1 class="h2 serif">マーダーミステリー制作のご依頼</h1>
<p class="lede">株式会社ex Labsは、オンライン・オフラインを問わず<strong>マーダーミステリー作品の企画・シナリオ制作</strong>を承っています。物語への没入と推理の面白さを両立させた、<strong>目的に合わせたオリジナル作品</strong>をお届けします。</p>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">USE CASES</p>
<h2 class="h2 serif">こんなご依頼に対応しています</h2>
<ul class="bullets">
<li>動画・配信企画用のマーダーミステリー制作</li>
<li>店舗・宿泊施設の集客コンテンツとしての導入</li>
<li>イベント・プロモーション用オリジナル作品の制作</li>
<li>社内研修・チームビルディング向けプログラム</li>
</ul>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">WORKS</p>
<h2 class="h2 serif">制作実績</h2>
<div class="str-grid tag-murder">
<div class="str-card"><p class="str-num">01</p><h3 class="str-title">ヒカル様（YouTuber）</h3>
<p class="str-lead">オンライン向けマーダーミステリー作品を累計3作品制作。</p>
<ul class="feature-points"><li>配信企画としての見せ場設計・テンポ感を意識した構成</li><li>映像コンテンツと相性の良い作品づくりが可能</li></ul></div>
<div class="str-card"><p class="str-num">02</p><h3 class="str-title">サーマルクライムスタジオ様（宿泊施設）</h3>
<p class="str-lead">宿泊者向けマーダーミステリーコンテンツを制作。</p>
<ul class="feature-points"><li>実施後、新規宿泊予約20件以上の獲得につながった実績</li><li>コンテンツによる集客効果を実証</li></ul></div>
</div>
<p class="vc-line" style="margin-top:32px">このほか、謎解き・頭脳戦・イマーシブコンテンツなど複数ジャンルの制作実績があります。<a href="/#works" style="color:var(--accent)">実績一覧を見る</a></p>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">TITLES</p>
<h2 class="h2 serif">制作作品例</h2>
<p class="h2sub">展開団体「東大マーダーミステリーサークル」のレーベルより、代表作品をご紹介します。</p>
<div class="works-grid">
<div class="work-card"><img class="mm-poster" src="/assets/mm/aru-mm.webp" alt="あるマーダーミステリーについて ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">あるマーダーミステリーについて</h3>
<p class="work-desc">評価サイト「毎月マダミスアンケート」で3か月連続1位を達成した作品。</p></div>
<div class="work-card"><img class="mm-poster" src="/assets/mm/frankenstein.webp" alt="フランケンシュタイン城の殺人 ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">フランケンシュタイン城の殺人</h3>
<p class="work-desc">マーダーミステリーでは希少な本格推理作品。オフラインでプレイ可能。</p></div>
<div class="work-card"><img class="mm-poster" src="/assets/mm/blue-diamond.webp" alt="ブルーダイヤの不在証明 ポスター" loading="lazy" decoding="async">
<h3 class="work-name" style="margin-top:20px">ブルーダイヤの不在証明</h3>
<p class="work-desc">オンライン・4人でプレイ可能な作品。プレイヤー全員で協力し、犯人の特定を目指す。</p></div>
</div>
<p class="vc-line" style="margin-top:40px">上記の3作品のほかにも、20作品以上の制作実績がございます。</p>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">FAQ</p>
<h2 class="h2 serif">よくあるご質問</h2>
<div class="faq-list tag-murder">
{faqs.map((f) => (
  <div class="faq-item">
    <p class="faq-q">{f.q}</p>
    <p class="faq-a">{f.a}</p>
  </div>
))}
</div>
</div></section>

<section class="section"><div class="wrap">
<div class="cta-mini">
<p class="cta-mini-title serif">マーダーミステリー制作のご相談はこちら</p>
<a class="btn" style="background:#241f1a" href="/#contact">お問い合わせ</a>
</div>
<p class="vc-line" style="margin-top:48px">関連サービス：<a href="/services/nazotoki-kenshu/" style="color:var(--accent)">謎解き研修</a>／<a href="/services/shisetsu-event/" style="color:var(--accent)">施設活用イベント</a>／<a href="/services/zunousen/" style="color:var(--accent)">頭脳戦制作</a></p>
</div></section>

<LatestPosts category="murder" />

</BaseLayout>
