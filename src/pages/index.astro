---
// Rendered on request so the latest-posts section stays current
// without a redeploy.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import LatestPosts from '../components/LatestPosts.astro';
import HeroWorksMarquee from '../components/HeroWorksMarquee.astro';
import { pressItems } from '../data/press';

const latestPress = [...pressItems].sort((a, b) => (a.date < b.date ? 1 : -1)).slice(0, 3);
function pressDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y}.${m}.${d}`;
}

// 現在実施中のイベント — 終了したら配列から消すだけでOK。
const liveEvents = [
  {
    title: 'ロスト・フレーム',
    host: '体験する美術館',
    place: '下北沢',
    desc: '下北沢の街に散らばった絵画を探し、\u200b隠された物語を辿る──\u200b絵画と街が交差する\u200b周遊型アートイマーシブ。',
    url: 'https://taikenbizyutu.studio.site/',
    img: '/assets/events/lost-frame.webp',
    w: 800, h: 1138,
  },
  {
    title: '紅漂う街角で',
    host: 'Smystery × WAKA',
    place: '下北沢',
    desc: '香水ブランドWAKA様と\u200bコラボレーションした、\u200b香りを手がかりに\u200b「ある香水ブランドの秘密」を追う\u200bイマーシブミステリー。',
    url: 'https://smystery.studio.site/',
    img: '/assets/events/beni.webp',
    w: 595, h: 842,
  },
];

// 取引先企業様 — client/partner company logos shown above the 展開団体
// marquee. 数が増えたので2段構成にし、2段目は逆方向に流す。
const partnersRow1: { name: string; logo: string; h?: number }[] = [
  { name: 'Skyland Ventures', logo: '/assets/partners/skylandventures.webp', h: 64 },
  { name: 'COEN', logo: '/assets/partners/coen.webp', h: 40 },
  { name: 'MAISON MARC', logo: '/assets/partners/maisonmarc.webp', h: 46 },
  { name: 'Party', logo: '/assets/partners/party.webp', h: 50 },
  { name: 'Sally', logo: '/assets/partners/sally.webp', h: 44 },
];
const partnersRow2: { name: string; logo: string; h?: number }[] = [
  { name: '東急不動産', logo: '/assets/partners/tokyuland.webp', h: 58 },
  { name: 'Thermal Climb Studio Fuji', logo: '/assets/partners/thermalclimb.webp', h: 60 },
  { name: 'SHINKUKAN', logo: '/assets/partners/shinkukan.webp', h: 70 },
];
// 少ない枚数でも -50% ループが常に画面幅（4Kワイド含む）を超えるよう
// 十分に複製する。2段目は3社しかないため多めに繰り返す。
const partnerRow1Items = Array(4).fill(partnersRow1).flat();
const partnerRow2Items = Array(8).fill(partnersRow2).flat();

// 展開団体 — self-run labels/communities shown in the About marquee.
// Add `logo: '/assets/groups/xxx.png'` to an entry to show an image
// instead of the text name; `h` tunes the display height (px) since
// the logos have very different aspect ratios.
const groups: { name: string; logo?: string; h?: number }[] = [
  { name: 'ANAVKEY（アナアキー）', logo: '/assets/groups/anavkey.webp', h: 44 },
  { name: 'HACKTALE', logo: '/assets/groups/hacktale.png', h: 34 },
  { name: 'Smystery', logo: '/assets/groups/smystery.webp', h: 64 },
  { name: 'UNLIMITED MYSTERY', logo: '/assets/groups/unlimited-mystery.webp', h: 48 },
  { name: '体験する美術館', logo: '/assets/groups/taiken-bijutsukan.png', h: 72 },
  { name: '午前零時の童話集', logo: '/assets/groups/gozen-reiji.webp', h: 76 },
  { name: 'ウワサバナシ調査委員会', logo: '/assets/groups/uwasabanashi.webp', h: 62 },
  { name: '東大マーダーミステリーサークル' },
];
// Repeat the list so the marquee loop has no visible gap on wide
// screens.
const marqueeItems = Array(2).fill(groups).flat();
---
<BaseLayout>

<section class="hero">
<div class="hero-overlay"></div>
<div class="wrap hero-center">
<img class="hero-logo" src="/assets/logo.png" alt="株式会社 ex Labs" width="2048" height="520" loading="eager" fetchpriority="high" decoding="async">
<h1 class="hero-title serif"><span class="hl">初期費用0円で謎解きなどの</span><br><span class="hl">体験型イベントを実施しませんか？</span></h1>
<p class="hero-sub">Experience Entertainment — ex Labs Inc.</p>
<div class="hero-actions">
<a class="btn" href="#contact">相談してみる</a>
<a class="btn ghost" href="#works">実績を見る</a>
</div>
</div>
<HeroWorksMarquee />
</section>

<section class="section" id="about"><div class="wrap">
<p class="eyebrow">ABOUT</p><h2 class="h2 serif">会社概要</h2>
<div class="about-grid" style="grid-template-columns:1fr;max-width:720px;margin-left:auto;margin-right:auto">
<div>
<p class="lede" style="margin-left:0">株式会社ex Labs（イーエックスラボ）は、<strong>体験型エンターテインメント領域</strong>を主軸とするクリエイティブカンパニーです。</p>
<p class="about-label">事業内容</p>
<ul class="about-points"><li>自社主催による体験型イベントの企画・運営</li><li>法人向け体験型コンテンツの企画・制作</li><li>体験型エンターテインメント領域における企画・知見提供</li><li>体験型コンテンツを活用した社内研修プログラムの企画・提供</li></ul>
<div class="rule" style="margin-left:0"></div>
<p class="lede" style="margin-left:0">「<strong>その場所だからこそ体験できる物語</strong>」をコンセプトに、商業施設・文化施設・観光施設・IP・ブランドなどの魅力を活かした体験型コンテンツを企画・制作しています。</p>
<p class="vc-line" style="text-align:left"><span class="nobr">設立からの期間はまだ長くありませんが、</span><span class="nobr">複数の上場企業様との</span><span class="nobr">お取引実績を有しており、</span><span class="nobr">Skyland Ventures様をはじめとする</span><span class="nobr">ベンチャーキャピタル様からの</span><span class="nobr">ご支援もいただいております。</span></p>
</div>
</div>
<div class="marquee-block">
<p class="marquee-label">取引先企業様</p>
<div class="marquee"><div class="marquee-track partners-track">
{partnerRow1Items.map((p) => (
  <img class="marquee-logo" src={p.logo} alt={p.name} style={p.h ? `height:${p.h}px` : undefined} loading="lazy" decoding="async" />
))}
{partnerRow1Items.map((p) => (
  <img class="marquee-logo" src={p.logo} alt="" style={p.h ? `height:${p.h}px` : undefined} loading="lazy" decoding="async" />
))}
</div></div>
<div class="marquee marquee-row2"><div class="marquee-track partners-track rev">
{partnerRow2Items.map((p) => (
  <img class="marquee-logo" src={p.logo} alt={p.name} style={p.h ? `height:${p.h}px` : undefined} loading="lazy" decoding="async" />
))}
{partnerRow2Items.map((p) => (
  <img class="marquee-logo" src={p.logo} alt="" style={p.h ? `height:${p.h}px` : undefined} loading="lazy" decoding="async" />
))}
</div></div>
</div>
<div class="marquee-block">
<p class="marquee-label">展開団体</p>
<div class="marquee"><div class="marquee-track">
{marqueeItems.map((g) => (
  g.logo
    ? <img class="marquee-logo" src={g.logo} alt={g.name} style={g.h ? `height:${g.h}px` : undefined} loading="lazy" decoding="async" />
    : <span class="marquee-name serif">{g.name}</span>
))}
{marqueeItems.map((g) => (
  g.logo
    ? <img class="marquee-logo" src={g.logo} alt="" style={g.h ? `height:${g.h}px` : undefined} loading="lazy" decoding="async" />
    : <span class="marquee-name serif" aria-hidden="true">{g.name}</span>
))}
</div></div>
</div>
<div class="label-links">
<p class="marquee-label">展開団体公式HP</p>
<div class="label-links-row">
<a class="label-link" href="https://kabuexlabs.com/toudaimurder/" target="_blank" rel="noopener noreferrer">
<span class="label-link-body">
<span class="label-link-cat">マーダーミステリーレーベル</span>
<span class="label-link-name serif">Unlimited Mystery</span>
</span>
<span class="label-link-arrow">↗</span>
</a>
<a class="label-link" href="https://kabuexlabs.com/hacktale/" target="_blank" rel="noopener noreferrer">
<span class="label-link-body">
<span class="label-link-cat">頭脳戦レーベル</span>
<span class="label-link-name serif">HACKTALE</span>
</span>
<span class="label-link-arrow">↗</span>
</a>
<a class="label-link" href="https://kabuexlabs.com/taikenbizyutu/" target="_blank" rel="noopener noreferrer">
<span class="label-link-body">
<span class="label-link-cat">アート×体験レーベル</span>
<span class="label-link-name serif">体験する美術館</span>
</span>
<span class="label-link-arrow">↗</span>
</a>
<a class="label-link" href="https://kabuexlabs.com/smystery/" target="_blank" rel="noopener noreferrer">
<span class="label-link-body">
<span class="label-link-cat">匂い×体験レーベル</span>
<span class="label-link-name serif">Smystery</span>
</span>
<span class="label-link-arrow">↗</span>
</a>
</div>
</div>
</div></section>

<section class="section tinted" id="events"><div class="wrap">
<p class="eyebrow">NOW SHOWING</p><h2 class="h2 serif">現在実施中のイベント</h2>
<p class="h2sub">画像をタップすると、各イベントの特設サイトへ移動します。</p>
<div class="event-row">
{liveEvents.map((e) => (
  <a class="event-card" href={e.url} target="_blank" rel="noopener noreferrer">
    <img src={e.img} alt={`${e.title} ポスター`} width={e.w} height={e.h} loading="lazy" decoding="async">
    <span class="event-name">{e.title}<span class="event-host"><span class="nobr">{e.host}｜</span><span class="nobr">開催地：{e.place}&nbsp;↗</span></span></span>
    <span class="event-desc">{e.desc.split('​').map((c) => <span class="nobr">{c}</span>)}</span>
  </a>
))}
</div>
</div></section>

<LatestPosts heading="最新記事" tinted={false} />

<section class="section tinted"><div class="wrap">
<p class="eyebrow">PRESS RELEASE</p><h2 class="h2 serif">プレスリリース</h2>
<div class="press-list">
{latestPress.map((p) => (
  <a class="press-item" href={p.url} target="_blank" rel="noopener noreferrer">
    <span class="press-date">{pressDate(p.date)}</span>
    <span class="press-title">{p.title}</span>
    <span class="press-src">{p.source ?? 'PR TIMES'} ↗</span>
  </a>
))}
</div>
<p class="vc-line" style="margin-top:40px"><a href="/press/" style="color:var(--accent)">プレスリリース一覧を見る →</a></p>
</div></section>

<section class="section" id="strength"><div class="wrap">
<p class="eyebrow">STRENGTH</p><h2 class="h2 serif">ex Labsの強み</h2>
<p class="h2sub">ex Labsが選ばれる、2つの理由</p>
<div class="str-grid">
<div class="str-card"><p class="str-num">01</p><h3 class="str-title">初期費用は0円、もしくは格安！</h3>
<p class="str-lead"><span class="nobr">弊社は法人様からではなく、</span><span class="nobr">イベントのお客様から</span><span class="nobr">収益回収するモデルを</span><span class="nobr">実現しております。</span></p>
<ul class="feature-points"><li><span><span class="nobr">企画の中身だけでなく、</span><span class="nobr">集客成果まで責任を持ちます。</span></span></li><li><span><span class="nobr">「制作して終わり」ではなく</span><span class="nobr">「成功するところまで伴走する」</span><span class="nobr">そんな会社を目指しております。</span></span></li></ul></div>
<div class="str-card"><p class="str-num">02</p><h3 class="str-title">どんなコンテンツでも制作可能！</h3>
<p class="str-lead"><span class="nobr">謎解き・マーダーミステリー・</span><span class="nobr">頭脳戦・</span><span class="nobr">イマーシブコンテンツなど、</span><span class="nobr">多岐に渡るジャンルを</span><span class="nobr">企画・制作可能です。</span></p>
<ul class="feature-points"><li><span><span class="nobr">自社団体を複数運営し、</span><span class="nobr">それぞれに</span><span class="nobr">コミュニティ・ファン層を</span><span class="nobr">形成しております。</span></span></li><li><span><span class="nobr">そのため、</span><span class="nobr">新規プロジェクトでも</span><span class="nobr">既存の集客基盤を活かした</span><span class="nobr">展開が可能です。</span></span></li></ul>
<div class="chips">
<a class="chip" href="/services/nazotoki-kenshu/">謎解き</a><a class="chip" href="/services/murder-mystery/">マーダーミステリー</a><a class="chip" href="/services/zunousen/">頭脳戦</a><a class="chip" href="/services/immersive/">イマーシブ</a>
</div></div>
</div>
<p class="bizmodel-label">成果報酬型のビジネスモデル</p>
<div class="biz-flow">
<div class="biz-step"><span class="biz-no">01</span><p class="biz-t">クライアント様</p><p class="biz-d"><b>初期費用0円</b>、<span class="nobr">もしくは格安でご依頼</span></p></div>
<span class="biz-arrow" aria-hidden="true">→</span>
<div class="biz-step is-ex"><span class="biz-no">02</span><p class="biz-t serif">ex Labs</p><p class="biz-d"><span class="nobr">企画・制作・運営までを</span><span class="nobr">一貫して担当</span></p></div>
<span class="biz-arrow" aria-hidden="true">→</span>
<div class="biz-step"><span class="biz-no">03</span><p class="biz-t">イベント開催</p><p class="biz-d"><span class="nobr">集客もex Labsが</span><span class="nobr">責任を持って実施</span></p></div>
<span class="biz-arrow" aria-hidden="true">→</span>
<div class="biz-step"><span class="biz-no">04</span><p class="biz-t">チケット売上で収益化</p><p class="biz-d"><span class="nobr">法人様ではなく、</span><span class="nobr">イベントのお客様から回収</span></p></div>
</div>
<div class="biz-punch">
<p class="biz-punch-t serif"><span class="nobr">売れなければ、</span><span class="nobr"><b>弊社が赤字</b>になる。</span></p>
<p class="biz-punch-d"><span class="nobr">だからこそ、</span><span class="nobr">私たちは<strong>集客・運営まで</strong></span><span class="nobr"><strong>責任を持って伴走</strong>します。</span></p>
</div>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">OUR STYLE</p><h2 class="h2 serif">他社様との違い</h2>
<p class="h2sub">一般的なイベント制作会社では、コンテンツ制作までを担当し、その後の集客・運営はクライアント様側が担うケースが多く見られます。</p>
<div class="style-grid">
<div class="style-col them"><p class="style-h">一般的な制作会社</p>
<div class="style-row"><span class="mark ok-muted">✓</span>企画・コンテンツ制作</div>
<div class="style-row" style="color:rgba(36,31,26,.35)"><span class="mark no">×</span>集客（対象外）</div>
<div class="style-row" style="color:rgba(36,31,26,.35)"><span class="mark no">×</span>運営（対象外）</div>
<div class="style-row" style="color:rgba(36,31,26,.35)"><span class="mark no">×</span>コンテンツ改善（対象外）</div></div>
<div class="style-col us"><p class="style-h">ex Labs</p>
<div class="style-row"><span class="mark ok">✓</span>企画・コンテンツ制作</div>
<div class="style-row"><span class="mark ok">✓</span>集客</div>
<div class="style-row"><span class="mark ok">✓</span>運営</div>
<div class="style-row"><span class="mark ok">✓</span>コンテンツ改善</div>
<p class="style-note"><span class="nobr">企画・制作に加え、</span><span class="nobr">集客・運営・コンテンツ改善までを</span><span class="nobr">一貫してご支援する</span><span class="nobr"><strong>「伴走型」の制作体制</strong>。</span><span class="nobr">案件によっては</span><span class="nobr">初期費用を抑えたご提案や</span><span class="nobr"><strong>レベニューシェア型</strong>での実施にも</span><span class="nobr">対応しております。</span></p></div>
</div>
</div></section>

<section class="section" id="works"><div class="wrap">
<div class="works-head"><div><p class="eyebrow" style="margin-bottom:8px">WORKS</p><h2 class="h2 serif" style="margin:0">主な実績</h2></div></div>
<div class="works-grid">

<div class="work-card tag-nazotoki"><img width="880" height="1254" class="work-img" loading="lazy" decoding="async" src="/assets/work-0.webp" alt="神戸須磨シーワールド 写真">
<p class="work-tag"><span class="nobr">謎解きコンテンツ</span><span class="nobr">制作・デザイン</span></p><h3 class="work-name"><span class="nobr">神戸須磨</span><span class="nobr">シーワールド</span></h3>
<p class="work-sub">オルカ海賊団からの挑戦状</p>
<p class="work-desc"><span class="nobr">館内を巡りながら</span><span class="nobr">宝探しを楽しむ</span><span class="nobr">周遊型イベントの謎解きを制作。</span></p></div>

<div class="work-card tag-murder"><img width="849" height="1200" class="work-img" loading="lazy" decoding="async" src="/assets/work-1.webp" alt="博報堂 × 紀伊國屋書店 写真">
<p class="work-tag">ミステリー原案</p><h3 class="work-name"><span class="nobr">博報堂 ×</span> <span class="nobr">紀伊國屋書店</span></h3>
<p class="work-sub">月明かりの書店と呪われた原稿</p>
<p class="work-desc"><span class="nobr">閉店後の紀伊國屋書店を舞台に</span><span class="nobr">開催された、</span><span class="nobr">一夜限りの体験型イベントの</span><span class="nobr">制作を担当しました。</span></p></div>

<div class="work-card"><img width="880" height="1238" class="work-img" loading="lazy" decoding="async" src="/assets/work-2.webp" alt="ヌル・アーデン展 写真">
<p class="work-tag">企画・制作</p><h3 class="work-name">自社主催</h3>
<p class="work-sub">ヌル・アーデン展</p>
<p class="work-desc"><span class="nobr">東京藝術大学出身アーティストとの</span><span class="nobr">コラボレーション企画。</span><span class="nobr">アートと謎解きを融合した</span><span class="nobr">体験型イベントを実施し、</span><span class="nobr">公演終了後には</span><span class="nobr">作品オークションも開催しました。</span></p></div>

<div class="work-card tag-shisetsu"><img width="880" height="1252" class="work-img" loading="lazy" decoding="async" src="/assets/work-3.webp" alt="ロスト・フレーム 写真">
<p class="work-tag">企画・制作</p><h3 class="work-name">下北沢連合会</h3>
<p class="work-sub">ロスト・フレーム</p>
<p class="work-desc"><span class="nobr">下北沢連合会様との連携により、</span><span class="nobr">街全体を舞台とした</span><span class="nobr">アート体験型イベントを</span><span class="nobr">制作しました。</span></p></div>

<div class="work-card tag-shisetsu"><img class="work-img" loading="lazy" decoding="async" src="/assets/work-4.webp" alt="紅漂う街角で 写真">
<p class="work-tag">企画・制作</p><h3 class="work-name">下北沢連合会</h3>
<p class="work-sub">紅漂う街角で</p>
<p class="work-desc"><span class="nobr">下北沢連合会様、</span><span class="nobr">香水ブランドWAKA様と連携した</span><span class="nobr">ミステリーと香水を融合した</span><span class="nobr">体験を提供。</span></p></div>

<div class="work-card tag-zunou"><img class="work-img" loading="lazy" decoding="async" src="/assets/work-5.webp" alt="カラオケ館 写真">
<p class="work-tag">コンテンツ制作</p><h3 class="work-name">カラオケ館</h3>
<p class="work-sub">恣験</p>
<p class="work-desc"><span class="nobr">参加者が様々な試験へ挑戦する</span><span class="nobr">周遊型頭脳戦コンテンツを</span><span class="nobr">制作しました。</span></p></div>

<div class="work-card tag-murder"><img class="work-img" loading="lazy" decoding="async" src="/assets/work-7.webp" alt="サーマルクライムスタジオ 写真">
