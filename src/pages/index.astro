---
// Rendered on request so the latest-posts section stays current
// without a redeploy.
export const prerender = false;

import BaseLayout from '../layouts/BaseLayout.astro';
import LatestPosts from '../components/LatestPosts.astro';
import HeroWorksMarquee from '../components/HeroWorksMarquee.astro';
import { pressItems } from '../data/press';

const latestPress = [...pressItems].sort((a, b) => (a.date < b.date ? 1 : -1)).slice(0, 3);
function pressDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y}.${m}.${d}`;
}

// 現在実施中のイベント — 終了したら配列から消すだけでOK。
const liveEvents = [
  {
    title: 'ロスト・フレーム',
    host: '体験する美術館',
    place: '下北沢',
    desc: '下北沢の街に散らばった絵画を探し、隠された物語を辿る──絵画と街が交差する周遊型アートイマーシブ。',
    url: 'https://taikenbizyutu.studio.site/',
    img: '/assets/events/lost-frame.webp',
    w: 800, h: 1138,
  },
  {
    title: '紅漂う街角で',
    host: 'Smystery × WAKA',
    place: '下北沢',
    desc: '香水ブランドWAKA様とコラボレーションした、香りを手がかりに「ある香水ブランドの秘密」を追うイマーシブミステリー。',
    url: 'https://smystery.studio.site/',
    img: '/assets/events/beni.webp',
    w: 595, h: 842,
  },
];

// 展開団体 — self-run labels/communities shown in the About marquee.
// Add `logo: '/assets/groups/xxx.png'` to an entry to show an image
// instead of the text name; `h` tunes the display height (px) since
// the logos have very different aspect ratios.
const groups: { name: string; logo?: string; h?: number }[] = [
  { name: 'ANAVKEY（アナアキー）', logo: '/assets/groups/anavkey.webp', h: 44 },
  { name: 'HACKTALE', logo: '/assets/groups/hacktale.png', h: 34 },
  { name: 'SMystery', logo: '/assets/groups/smystery.webp', h: 64 },
  { name: 'UNLIMITED MYSTERY', logo: '/assets/groups/unlimited-mystery.webp', h: 48 },
  { name: '体験する美術館', logo: '/assets/groups/taiken-bijutsukan.png', h: 72 },
  { name: '午前零時の童話集', logo: '/assets/groups/gozen-reiji.webp', h: 76 },
  { name: 'ウワサバナシ調査委員会', logo: '/assets/groups/uwasabanashi.webp', h: 62 },
  { name: '東大マーダーミステリーサークル' },
];
// Repeat the list so the marquee loop has no visible gap on wide
// screens.
const marqueeItems = Array(2).fill(groups).flat();
---
<BaseLayout>

<section class="hero">
<div class="hero-overlay"></div>
<div class="wrap hero-center">
<img class="hero-logo" src="/assets/logo.png" alt="株式会社 ex Labs" width="2048" height="520" loading="eager" decoding="async">
<h1 class="hero-title serif"><span class="hl">初期費用0円で謎解きなどの</span><br><span class="hl">体験型イベントを実施しませんか？</span></h1>
<p class="hero-sub">Experience Entertainment — ex Labs Inc.</p>
<div class="hero-actions">
<a class="btn" href="#contact">相談してみる</a>
<a class="btn ghost" href="#works">実績を見る</a>
</div>
</div>
<HeroWorksMarquee />
</section>

<section class="section" id="about"><div class="wrap">
<p class="eyebrow">ABOUT</p><h2 class="h2 serif">会社概要</h2>
<div class="about-grid" style="grid-template-columns:1fr;max-width:720px;margin-left:auto;margin-right:auto">
<div>
<p class="lede" style="margin-left:0">株式会社ex Labs（イーエックスラボ）は、<strong>体験型エンターテインメント領域</strong>を主軸とするクリエイティブカンパニーです。</p>
<p class="about-label">事業内容</p>
<ul class="about-points"><li>自社主催による体験型イベントの企画・運営</li><li>法人向け体験型コンテンツの企画・制作</li><li>体験型エンターテインメント領域における企画・知見提供</li><li>体験型コンテンツを活用した社内研修プログラムの企画・提供</li></ul>
<div class="rule" style="margin-left:0"></div>
<p class="lede" style="margin-left:0">「<strong>その場所だからこそ体験できる物語</strong>」をコンセプトに、商業施設・文化施設・観光施設・IP・ブランドなどの魅力を活かした体験型コンテンツを企画・制作しています。</p>
<p class="vc-line" style="text-align:left">設立からの期間はまだ長くありませんが、複数の上場企業様とのお取引実績を有しており、Skyland Ventures様をはじめとするベンチャーキャピタル様からのご支援もいただいております。</p>
</div>
</div>
<div class="marquee-block">
<p class="marquee-label">展開団体</p>
<div class="marquee"><div class="marquee-track">
{marqueeItems.map((g) => (
  g.logo
    ? <img class="marquee-logo" src={g.logo} alt={g.name} style={g.h ? `height:${g.h}px` : undefined} loading="eager" decoding="async" />
    : <span class="marquee-name serif">{g.name}</span>
))}
{marqueeItems.map((g) => (
  g.logo
    ? <img class="marquee-logo" src={g.logo} alt="" style={g.h ? `height:${g.h}px` : undefined} loading="eager" decoding="async" />
    : <span class="marquee-name serif" aria-hidden="true">{g.name}</span>
))}
</div></div>
</div>
</div></section>

<section class="section tinted" id="events"><div class="wrap">
<p class="eyebrow">NOW SHOWING</p><h2 class="h2 serif">現在実施中のイベント</h2>
<p class="h2sub">画像をタップすると、各イベントの特設サイトへ移動します。</p>
<div class="event-row">
{liveEvents.map((e) => (
  <a class="event-card" href={e.url} target="_blank" rel="noopener noreferrer">
    <img src={e.img} alt={`${e.title} ポスター`} width={e.w} height={e.h} loading="lazy" decoding="async">
    <span class="event-name">{e.title}<span class="event-host"><span class="nobr">{e.host}｜</span><span class="nobr">開催地：{e.place}&nbsp;↗</span></span></span>
    <span class="event-desc">{e.desc}</span>
  </a>
))}
</div>
</div></section>

<LatestPosts heading="最新記事" tinted={false} />

<section class="section tinted"><div class="wrap">
<p class="eyebrow">PRESS RELEASE</p><h2 class="h2 serif">プレスリリース</h2>
<div class="press-list">
{latestPress.map((p) => (
  <a class="press-item" href={p.url} target="_blank" rel="noopener noreferrer">
    <span class="press-date">{pressDate(p.date)}</span>
    <span class="press-title">{p.title}</span>
    <span class="press-src">{p.source ?? 'PR TIMES'} ↗</span>
  </a>
))}
</div>
<p class="vc-line" style="margin-top:40px"><a href="/press/" style="color:var(--accent)">プレスリリース一覧を見る →</a></p>
</div></section>

<section class="section" id="strength"><div class="wrap">
<p class="eyebrow">STRENGTH</p><h2 class="h2 serif">ex Labsの強み</h2>
<p class="h2sub">ex Labsが選ばれる、2つの理由</p>
<div class="str-grid">
<div class="str-card"><p class="str-num">01</p><h3 class="str-title">初期費用は0円、もしくは格安！</h3>
<p class="str-lead">弊社は法人様からではなく、イベントのお客様から収益回収するモデルを実現しております。</p>
<ul class="feature-points"><li>企画の中身だけでなく、集客成果まで責任を持ちます。</li><li>「制作して終わり」ではなく「成功するところまで伴走する」そんな会社を目指しております。</li></ul></div>
<div class="str-card"><p class="str-num">02</p><h3 class="str-title">どんなコンテンツでも制作可能！</h3>
<p class="str-lead">謎解き・マーダーミステリー・頭脳戦・イマーシブコンテンツなど、多岐に渡るジャンルを企画・制作可能です。</p>
<ul class="feature-points"><li>自社団体を複数運営し、それぞれにコミュニティ・ファン層を形成しております。</li><li>そのため、新規プロジェクトでも既存の集客基盤を活かした展開が可能です。</li></ul>
<div class="chips">
<a class="chip" href="/services/nazotoki-kenshu/">謎解き</a><a class="chip" href="/services/murder-mystery/">マーダーミステリー</a><a class="chip" href="/services/zunousen/">頭脳戦</a><span class="chip">イマーシブコンテンツ</span>
</div></div>
</div>
</div></section>

<section class="section tinted"><div class="wrap">
<p class="eyebrow">OUR STYLE</p><h2 class="h2 serif">他社様との違い</h2>
<p class="h2sub">一般的なイベント制作会社では、コンテンツ制作までを担当し、その後の集客・運営はクライアント様側が担うケースが多く見られます。</p>
<div class="style-grid">
<div class="style-col them"><p class="style-h">一般的な制作会社</p>
<div class="style-row"><span class="mark ok-muted">✓</span>企画・コンテンツ制作</div>
<div class="style-row" style="color:rgba(36,31,26,.35)"><span class="mark no">×</span>集客（対象外）</div>
<div class="style-row" style="color:rgba(36,31,26,.35)"><span class="mark no">×</span>運営（対象外）</div>
<div class="style-row" style="color:rgba(36,31,26,.35)"><span class="mark no">×</span>コンテンツ改善（対象外）</div></div>
<div class="style-col us"><p class="style-h">ex Labs</p>
<div class="style-row"><span class="mark ok">✓</span>企画・コンテンツ制作</div>
<div class="style-row"><span class="mark ok">✓</span>集客</div>
<div class="style-row"><span class="mark ok">✓</span>運営</div>
<div class="style-row"><span class="mark ok">✓</span>コンテンツ改善</div>
<p class="style-note">企画・制作に加え、集客・運営・コンテンツ改善までを一貫してご支援する<strong>「伴走型」の制作体制</strong>。案件によっては初期費用を抑えたご提案や<strong>レベニューシェア型</strong>での実施にも対応しております。</p></div>
</div>
</div></section>

<section class="section" id="works"><div class="wrap">
<div class="works-head"><div><p class="eyebrow" style="margin-bottom:8px">WORKS</p><h2 class="h2 serif" style="margin:0">主な実績</h2></div></div>
<div class="works-grid">

<div class="work-card tag-nazotoki"><img width="880" height="1254" class="work-img" loading="lazy" decoding="async" src="/assets/work-0.webp" alt="神戸須磨シーワールド 写真">
<p class="work-tag"><span class="nobr">謎解きコンテンツ</span><span class="nobr">制作・デザイン</span></p><h3 class="work-name"><span class="nobr">神戸須磨</span><span class="nobr">シーワールド</span></h3>
<p class="work-sub">オルカ海賊団からの挑戦状</p>
<p class="work-desc">館内を巡りながら宝探しを楽しむ周遊型イベントの謎解きを制作。</p></div>

<div class="work-card tag-murder"><img width="849" height="1200" class="work-img" loading="lazy" decoding="async" src="/assets/work-1.webp" alt="博報堂 × 紀伊國屋書店 写真">
<p class="work-tag">ミステリー原案</p><h3 class="work-name"><span class="nobr">博報堂 ×</span> <span class="nobr">紀伊國屋書店</span></h3>
<p class="work-sub">月明かりの書店と呪われた原稿</p>
<p class="work-desc">閉店後の紀伊國屋書店を舞台に開催された、一夜限りの体験型イベントの制作を担当しました。</p></div>

<div class="work-card"><img width="880" height="1238" class="work-img" loading="lazy" decoding="async" src="/assets/work-2.webp" alt="ヌル・アーデン展 写真">
<p class="work-tag">企画・制作</p><h3 class="work-name">自社主催</h3>
<p class="work-sub">ヌル・アーデン展</p>
<p class="work-desc">東京藝術大学出身アーティストとのコラボレーション企画。アートと謎解きを融合した体験型イベントを実施し、公演終了後には作品オークションも開催しました。</p></div>

<div class="work-card tag-shisetsu"><img width="880" height="1252" class="work-img" loading="lazy" decoding="async" src="/assets/work-3.webp" alt="ロスト・フレーム 写真">
<p class="work-tag">企画・制作</p><h3 class="work-name">下北沢連合会</h3>
<p class="work-sub">ロスト・フレーム</p>
<p class="work-desc">下北沢連合会様との連携により、街全体を舞台としたアート体験型イベントを制作しました。</p></div>

<div class="work-card tag-shisetsu"><img class="work-img" loading="lazy" decoding="async" src="/assets/work-4.webp" alt="紅漂う街角で 写真">
<p class="work-tag">企画・制作</p><h3 class="work-name">下北沢連合会</h3>
<p class="work-sub">紅漂う街角で</p>
<p class="work-desc">下北沢連合会様、香水ブランドWAKA様と連携したミステリーと香水を融合した体験を提供。</p></div>

<div class="work-card tag-zunou"><img class="work-img" loading="lazy" decoding="async" src="/assets/work-5.webp" alt="カラオケ館 写真">
<p class="work-tag">コンテンツ制作</p><h3 class="work-name">カラオケ館</h3>
<p class="work-sub">恣験</p>
<p class="work-desc">参加者が様々な試験へ挑戦する周遊型頭脳戦コンテンツを制作しました。</p></div>

<div class="work-card tag-murder"><img width="739" height="415" class="work-img" loading="lazy" decoding="async" src="/assets/work-6.webp" alt="ヒカル様 写真">
<p class="work-tag">マーダーミステリー制作</p><h3 class="work-name">ヒカル様</h3>
<p class="work-desc">オンライン向け作品を累計3作品制作しました。</p></div>

<div class="work-card tag-murder"><img class="work-img" loading="lazy" decoding="async" src="/assets/work-7.webp" alt="サーマルクライムスタジオ 写真">
<p class="work-tag">マーダーミステリー制作</p><h3 class="work-name"><span class="nobr">サーマルクライム</span><span class="nobr">スタジオ</span></h3>
<p class="work-desc">宿泊者向けコンテンツを制作し、実施後には新規宿泊予約20件以上の獲得につながりました。</p></div>

<div class="work-card tag-zunou"><img width="880" height="1248" class="work-img" loading="lazy" decoding="async" src="/assets/work-8.webp" alt="東京都頭脳王決定戦 写真">
<p class="work-tag">企画・制作</p><h3 class="work-name">自社主催</h3>
<p class="work-sub">東京都頭脳王決定戦</p>
<p class="work-desc">東京都内4会場を同時に活用し、「東京都で最も頭の良い人を決める」というコンセプトの大型イベントを企画・運営しました。</p></div>

</div>
</div></section>

<section class="section perf"><div class="wrap">
<p class="eyebrow">PERFORMANCE</p><h2 class="h2 serif">実績紹介</h2>
<p class="perf-lede">自社イベント「<strong>ヌル・アーデン展</strong>」では、以下の実績を達成しました。</p>
<div class="stat-row">
<div class="stat"><p class="stat-num serif">1,500<span class="stat-unit">枚</span></p><p class="stat-label">チケット販売枚数</p></div>
<div class="stat"><p class="stat-num serif"><span class="stat-unit">¥</span>4,000</p><p class="stat-label">チケット価格</p></div>
</div>
<p class="perf-lede" style="margin-bottom:0">しかも、以下の条件下での実績です。</p>
<div class="cond-list">
<div class="cond-item"><span class="cond-check">✓</span>SNSアカウントをゼロから立ち上げ</div>
<div class="cond-item"><span class="cond-check">✓</span>プレスリリース未実施</div>
<div class="cond-item"><span class="cond-check">✓</span>広告宣伝費0円</div>
<div class="cond-item"><span class="cond-check">✓</span>Xのみで集客</div>
</div>
</div></section>

<section class="section"><div class="wrap">
<p class="eyebrow">CONTENTS</p><h2 class="h2 serif">提供コンテンツ</h2>
<p class="h2sub">以下のような体験型コンテンツを企画・制作しております。上記以外のジャンルについても、ご要望に応じてオリジナルコンテンツを企画・制作いたします。</p>
<div class="genre-grid">
