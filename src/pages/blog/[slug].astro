---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getPost, isMicrocmsConfigured } from '../../lib/microcms';

const { slug } = Astro.params;
const configured = isMicrocmsConfigured();
const post = configured && slug ? await getPost(slug) : null;

if (!post) {
  Astro.response.status = 404;
}

function formatDate(iso: string) {
  const d = new Date(iso);
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
}

function excerpt(html: string, length = 110) {
  const text = html.replace(/<[^>]+>/g, '').replace(/\s+/g, ' ').trim();
  return text.length > length ? text.slice(0, length) + '…' : text;
}

const articleLd = post
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: post.title,
      datePublished: post.publishedAt,
      ...(post.revisedAt ? { dateModified: post.revisedAt } : {}),
      ...(post.eyecatch ? { image: [post.eyecatch.url] } : {}),
      author: { '@type': 'Organization', name: '株式会社ex Labs' },
      publisher: { '@type': 'Organization', name: '株式会社ex Labs' },
      mainEntityOfPage: new URL(Astro.url.pathname, Astro.site).toString(),
    }
  : null;
---
<BaseLayout
  title={post ? `${post.title}｜ex Labsブログ` : '記事が見つかりません｜ex Labsブログ'}
  description={post ? excerpt(post.body) : undefined}
  ogImage={post?.eyecatch?.url}
  ogType="article"
>
{articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}
<Breadcrumb items={[
  { name: 'ホーム', href: '/' },
  { name: 'ブログ', href: '/blog' },
  { name: post ? post.title : '記事が見つかりません' },
]} />

<section class="section" id="article-top" style="padding-top:56px"><div class="wrap">

{!post && (
  <>
  <p class="eyebrow">BLOG</p>
  <h2 class="h2 serif">記事が見つかりません</h2>
  <p class="blog-empty">お探しの記事は存在しないか、削除された可能性があります。</p>
  </>
)}

{post && (
  <>
  <p class="eyebrow">BLOG</p>
  <h1 class="h2 serif">{post.title}</h1>
  <p class="article-date">{formatDate(post.publishedAt)}</p>
  {post.eyecatch && (
    <img class="article-hero" src={post.eyecatch.url} alt={post.title} />
  )}
  <div class="article-body" set:html={post.body} />
  </>
)}

<a class="article-back" href="/blog">← ブログ一覧へ戻る</a>

</div></section>

</BaseLayout>
