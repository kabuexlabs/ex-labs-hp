---
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { getPostList, isMicrocmsConfigured } from '../../lib/microcms';

const configured = isMicrocmsConfigured();
const PAGE_SIZE = 12;
const page = Math.max(1, Number(Astro.url.searchParams.get('page') ?? '1') || 1);
const offset = (page - 1) * PAGE_SIZE;

const { contents, totalCount } = configured
  ? await getPostList(offset, PAGE_SIZE)
  : { contents: [], totalCount: 0 };

const totalPages = Math.max(1, Math.ceil(totalCount / PAGE_SIZE));

function formatDate(iso: string) {
  const d = new Date(iso);
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
}

function excerpt(html: string, length = 80) {
  const text = html.replace(/<[^>]+>/g, '');
  return text.length > length ? text.slice(0, length) + '…' : text;
}
---
<BaseLayout title="ブログ｜謎解き研修・マダミス・イマーシブの解説記事 - 株式会社ex Labs" description="謎解き研修の効果と進め方、マーダーミステリー（マダミス）制作の流れ、イマーシブイベントの企画方法、施設集客の事例など、体験型エンターテインメントの実務ノウハウを制作会社の視点で解説します。">
<Breadcrumb items={[
  { name: 'ホーム', href: '/' },
  { name: 'ブログ' },
]} />

<section class="section" id="blog-top" style="padding-top:56px"><div class="wrap">
<p class="eyebrow">BLOG</p><h1 class="h2 serif">ブログ</h1>

{!configured && (
  <p class="blog-empty">まだブログの準備中です。もうしばらくお待ちください。</p>
)}

{configured && contents.length === 0 && (
  <p class="blog-empty">まだ記事がありません。</p>
)}

{configured && contents.length > 0 && (
  <>
  <div class="blog-grid">
    {contents.map((post) => (
      <div class="blog-card">
        <a href={`/blog/${post.id}`}>
          {post.eyecatch ? (
            <img class="blog-img" src={post.eyecatch.url} alt={post.title} />
          ) : (
            <div class="blog-img"></div>
          )}
        </a>
        <p class="blog-date">{formatDate(post.publishedAt)}</p>
        <h2 class="blog-title"><a href={`/blog/${post.id}`}>{post.title}</a></h2>
        <p class="blog-excerpt">{excerpt(post.body)}</p>
      </div>
    ))}
  </div>

  <div class="blog-pagination">
    {page > 1 ? (
      <a href={`/blog?page=${page - 1}`}>← 前へ</a>
    ) : (
      <span class="disabled">← 前へ</span>
    )}
    <span>{page} / {totalPages}</span>
    {page < totalPages ? (
      <a href={`/blog?page=${page + 1}`}>次へ →</a>
    ) : (
      <span class="disabled">次へ →</span>
    )}
  </div>
  </>
)}

</div></section>

</BaseLayout>
