---
import ToudaimurderLayout from '../../../layouts/ToudaimurderLayout.astro';
import { tmWorks } from '../../../data/toudaimurderWorks';

const base = '/toudaimurder';
---

<ToudaimurderLayout
  wide
  active="works"
  title="作品一覧｜東大マーダーミステリーサークル"
  description="東大マーダーミステリーサークルの作品一覧。マーダーミステリーからイマーシブコンテンツまで、現役東大生と有名作家のチームが制作した作品をご紹介します。"
>
  <main class="wrap">
    <div class="shead rv"><p class="crumb mono"><a href={`${base}/`}>TOP</a> / WORKS</p><h1 class="sh"><span class="sht en">WORKS</span><span class="shj">作品一覧</span></h1></div>
    <div class="cards rv d1">
      {tmWorks.map((w) => (
        <div>
          <a href={`${base}/works/${w.slug}/`}><div class="ph pv"><span class="mono">作品キービジュアル 407×570</span></div></a>
          <div class="cmeta"><span class="badge">{w.badge}</span><span class="cdate mono">{w.meta}</span></div>
          <h2 class="ct"><a href={`${base}/works/${w.slug}/`}>{w.title}</a></h2>
          <p class="cpl">{w.play}</p>
          <p class="wd">{w.desc}</p>
        </div>
      ))}
    </div>
  </main>
</ToudaimurderLayout>

<style>
.shead{padding:80px 0 44px}
.cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));gap:40px;padding-bottom:96px}
</style>
