---
import ToudaimurderLayout from '../../../layouts/ToudaimurderLayout.astro';

const base = '/toudaimurder';

// お知らせは追って差し替え予定のプレースホルダー。
const news = [
  { date: '0000.00.00', tag: 'カテゴリ', title: '（お知らせの見出しをここに入力）', body: '（本文をここに入力）' },
  { date: '0000.00.00', tag: 'カテゴリ', title: '（お知らせの見出しをここに入力）', body: '（本文をここに入力）' },
  { date: '0000.00.00', tag: 'カテゴリ', title: '（お知らせの見出しをここに入力）', body: '（本文をここに入力）' },
];
---

<ToudaimurderLayout
  active="news"
  title="お知らせ｜東大マーダーミステリーサークル"
  description="東大マーダーミステリーサークルからのお知らせ一覧。新作リリースや公演情報をお届けします。"
>
  <main class="wrap">
    <div class="shead rv"><p class="crumb mono"><a href={`${base}/`}>TOP</a> / NEWS</p><h1 class="sh"><span class="sht en">NEWS</span><span class="shj">お知らせ</span></h1></div>
    <div class="list rv d1">
      {news.map((n) => (
        <div class="nrow">
          <div class="ph nth"><span class="mono">サムネイル 16:9</span></div>
          <div><span class="ndate mono">{n.date}</span><span class="ntag">{n.tag}</span><h2 class="nt">{n.title}</h2><p class="ns">{n.body}</p></div>
        </div>
      ))}
    </div>
  </main>
</ToudaimurderLayout>

<style>
.shead{padding:80px 0 48px}
.nrow{display:grid;grid-template-columns:220px 1fr;gap:32px;padding:30px 0;border-top:1px solid var(--ln);align-items:center}
.nth{aspect-ratio:16/9}
.ndate{font-size:12px;color:var(--acc);letter-spacing:.12em}
.ntag{display:inline-block;border:1px solid var(--ln);color:var(--dim);font-size:11px;padding:2px 10px;margin-left:12px;letter-spacing:.1em}
.nt{font-size:17px;font-weight:700;margin:6px 0 2px}
.ns{font-size:13px;color:var(--dim);margin:0}
.list{padding-bottom:96px}
@media (max-width:900px){.nrow{grid-template-columns:1fr}}
</style>
