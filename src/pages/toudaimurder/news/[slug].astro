---
import ToudaimurderLayout from '../../../layouts/ToudaimurderLayout.astro';
import { tmNews } from '../../../data/toudaimurderNews';
import { tmWorks } from '../../../data/toudaimurderWorks';

export function getStaticPaths() {
  return tmNews.map((article) => ({ params: { slug: article.slug }, props: { article } }));
}

const { article } = Astro.props;
const base = '/toudaimurder';
const work = article.workSlug ? tmWorks.find((w) => w.slug === article.workSlug) : undefined;
const paragraphs = article.body.split('\n\n');
const others = tmNews.filter((n) => n.slug !== article.slug);
---

<ToudaimurderLayout
  active="news"
  title={`${article.title}｜東大マーダーミステリーサークル`}
  description={article.summary}
>
  <main class="wrap">
    <article class="art fin">
      <p class="crumb mono"><a href={`${base}/`}>TOP</a> / <a href={`${base}/news/`}>NEWS</a> / {article.title}</p>
      <div class="ahead">
        <span class="ndate mono">{article.date}</span><span class="ntag">{article.tag}</span>
      </div>
      <h1 class="at min">{article.title}</h1>
      {article.image && (
        <div class="aimg"><img src={article.image} alt={`${article.title} サムネイル`} /></div>
      )}
      <div class="abody">
        {paragraphs.map((p) => <p>{p}</p>)}
      </div>
      {work && (
        <a class="wlink" href={`${base}/works/${work.slug}/`}>
          <span class="wlbl en">WORK</span>
          <span class="wtt">{work.title}</span>
          <span class="wgo en">作品ページを見る →</span>
        </a>
      )}
    </article>
    <div class="others fin2">
      <h2 class="olbl">他のお知らせ</h2>
      {others.map((n) => (
        <a class="orow" href={`${base}/news/${n.slug}/`}>
          <span class="ndate mono">{n.date}</span><span class="ntag">{n.tag}</span>
          <span class="ott">{n.title}</span>
        </a>
      ))}
      <div style="margin-top:36px"><a class="more en" href={`${base}/news/`}>ALL NEWS</a></div>
    </div>
  </main>
</ToudaimurderLayout>

<style>
@keyframes fadeup{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:none}}
.fin{animation:fadeup .8s cubic-bezier(.22,.61,.36,1) both}
.fin2{animation:fadeup .8s cubic-bezier(.22,.61,.36,1) .15s both}
.art{max-width:800px;margin:0 auto;padding:72px 0 64px}
.art .crumb{margin:0 0 28px}
.ahead{display:flex;align-items:center;gap:0;margin:0 0 14px}
.ndate{font-size:12px;color:var(--acc);letter-spacing:.12em}
.ntag{display:inline-block;border:1px solid var(--ln);color:var(--dim);font-size:11px;padding:2px 10px;margin-left:12px;letter-spacing:.1em}
.at{font-size:clamp(24px,2.8vw,36px);font-weight:800;line-height:1.6;margin:0 0 36px;letter-spacing:.04em}
.aimg{border:1px solid var(--ln);margin:0 0 40px;max-height:440px;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#0e0c0f}
.aimg img{width:100%;height:auto;max-height:440px;object-fit:contain;display:block}
.abody p{margin:0 0 24px;line-height:2.1}
.wlink{display:flex;align-items:center;gap:20px;border:1px solid var(--ln);background:#0e0c0f;padding:22px 28px;margin-top:12px;transition:border-color .2s;flex-wrap:wrap}
.wlink:hover{border-color:var(--acc);color:#eae5e1}
.wlbl{font-size:10px;color:var(--acc);letter-spacing:.28em}
.wtt{font-weight:700;font-size:15px}
.wgo{margin-left:auto;font-size:12px;color:var(--acc);letter-spacing:.14em}
.others{max-width:800px;margin:0 auto;border-top:1px solid var(--ln);padding:48px 0 96px}
.olbl{font-size:18px;font-weight:800;margin:0 0 20px}
.orow{display:flex;align-items:center;gap:0;padding:14px 0;border-bottom:1px solid var(--ln);flex-wrap:wrap}
.ott{display:block;width:100%;font-size:14px;font-weight:700;margin-top:4px}
</style>
