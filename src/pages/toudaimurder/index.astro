---
// Standalone campaign LP, served at toudaimurder.kabuexlabs.com via the
// host-based rewrite in vercel.json. It intentionally does not use
// BaseLayout — this is its own dark-themed brand, not the corporate site.
const SITE = 'https://toudaimurder.kabuexlabs.com/';
const title = '【公式】ウワサバナシ調査委員会 | イマーシブ公演';
const description =
  '渋谷サクラステージで、あなたも「調査員」になる。イマーシブ公演「ウワサバナシ調査委員会」公式サイト。2026.10.9–11.3 開催。';
const ogImage = new URL('/assets/toudaimurder/logo.jpg', SITE).toString();

const eventLd = {
  '@context': 'https://schema.org',
  '@type': 'Event',
  name: 'ウワサバナシ調査委員会',
  description,
  startDate: '2026-10-09',
  endDate: '2026-11-03',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: '渋谷サクラステージ',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '渋谷3-2-1',
      addressLocality: '渋谷区',
      addressRegion: '東京都',
      postalCode: '150-0002',
      addressCountry: 'JP',
    },
  },
  organizer: {
    '@type': 'Organization',
    name: '株式会社ex Labs',
    url: 'https://kabuexlabs.com/',
  },
  offers: [
    { '@type': 'Offer', name: '平日', price: '4500', priceCurrency: 'JPY' },
    { '@type': 'Offer', name: '土日祝', price: '5000', priceCurrency: 'JPY' },
  ],
};
---

<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={SITE}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="website">
<meta property="og:url" content={SITE}>
<meta property="og:image" content={ogImage}>
<meta property="og:site_name" content="ウワサバナシ調査委員会">
<meta property="og:locale" content="ja_JP">
<meta name="twitter:card" content="summary_large_image">
<link rel="icon" type="image/png" href="/favicon.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600;700;800&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet">
<script type="application/ld+json" set:html={JSON.stringify(eventLd)} />
</head>
<body>

<header class="hdr"><a href="#story">ストーリー</a><a href="#about">ABOUT</a><a href="#cast">キャスト</a><a href="#kv" class="hbrand"><img class="hlogo" src="/assets/toudaimurder/logo.jpg" alt="ウワサバナシ調査委員会"></a><a href="#ticket">チケット</a><a href="#access">アクセス</a><a href="#faq">FAQ</a></header>
<a class="cta" href="#ticket">チケットを予約</a>

<section class="kv" id="kv">
  <div class="kvbg"></div>
  <div class="kvnoise"></div>
  <div class="kvin">
    <img class="kvlogo" src="/assets/toudaimurder/logo.jpg" alt="ウワサバナシ調査委員会">
    <p class="kvcatch mincho">そのウワサ、確かめに行きませんか。</p>
    <div class="kvmeta"><span class="kvdate">2026.10.9 <span class="accent">—</span> 11.3</span><span class="kvvenue">渋谷サクラステージ</span></div>
  </div>
</section>

<div class="news" aria-hidden="true"><div class="newsin">
  <span class="newsitem">NEWS ／ 2026.07.07 公式サイトを公開しました</span><span class="newsitem">NEWS ／ 2026.07.07 チケット情報を公開しました</span><span class="newsitem">NEWS ／ 2026.07.07 公式サイトを公開しました</span><span class="newsitem">NEWS ／ 2026.07.07 チケット情報を公開しました</span><span class="newsitem">NEWS ／ 2026.07.07 公式サイトを公開しました</span><span class="newsitem">NEWS ／ 2026.07.07 チケット情報を公開しました</span>
</div></div>

<section class="sec" id="story">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">STORY</h2><p class="sechead-ja">ストーリー</p><div class="rule"></div></div>
    <p class="storyp">渋谷には、いくつかのウワサがある。<br>夜のサクラステージに現れる、誰もいないはずのフロア。<br>終電のあとにだけ流れる、聞き覚えのない館内放送。<br>SNSに書き込まれては、なぜか消えていく目撃談。</p>
    <div class="simg imgslot"><span>渋谷の夜景・現場写真</span></div>
    <p class="storyp">誰が言い出したのかは、わからない。<br>ほんとうかどうかも、わからない。<br>ただ——調べた者から、順に黙っていく。</p>
    <p class="storyp">あなたは今夜、「ウワサバナシ調査委員会」の<br>調査員として招集された。<br>証言を集め、出どころを辿り、噂の核心へ。</p>
    <div class="simg imgslot"><span>調査資料・小道具の写真</span></div>
    <p class="storyp storylead">噂は、調べる者を選ぶ。<br>あなたの選択が、結末を変える。</p>
  </div>
</section>

<section class="sec sec-alt" id="about">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">ABOUT</h2><p class="sechead-ja">本公演の楽しみ方</p><div class="rule"></div></div>
    <div class="aboutgrid">
      <div class="abcard"><p class="abnum">01</p><h3 class="abh">舞台は、<br>渋谷サクラステージ。</h3><p class="abp">物語の現場は、実在する渋谷の複合施設。見慣れた街の風景が、調査を進めるほどに違って見えてきます。</p></div>
      <div class="abcard"><p class="abnum">02</p><h3 class="abh">あなた自身が<br>“調査員”になる。</h3><p class="abp">本公演は、あなたが物語の登場人物として噂の調査に巻き込まれていくイマーシブ（没入型）体験。集めた証言や、あなたの「選択」そのものが物語を動かします。</p></div>
      <div class="abcard"><p class="abnum">03</p><h3 class="abh">観るでも、解くでもない。<br>“確かめに行く”物語。</h3><p class="abp">これは映画でも、演劇でも、いわゆる謎解きでもありません。疑い、迷い、選ぶ——噂と向き合う行為そのものを楽しむ体験です。</p></div>
    </div>
  </div>
</section>

<section class="sec" id="cast">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">CAST</h2><p class="sechead-ja">キャスト</p><div class="rule"></div></div>
    <div class="castbox"><p class="castsoon">COMING SOON....</p></div>
  </div>
</section>

<section class="sec sec-alt" id="ticket">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">TICKET</h2><p class="sechead-ja">チケット情報</p><div class="rule"></div></div>
    <div class="price">
      <div class="pricebox"><p class="pricelabel">平日</p><p class="priceval">¥4,500<span class="dim" style="font-size:13px">（税込）</span></p></div>
      <div class="pricebox"><p class="pricelabel">土日祝</p><p class="priceval">¥5,000<span class="dim" style="font-size:13px">（税込）</span></p></div>
    </div>
    <div style="text-align:center">
      <a class="buy" href="#ticket">チケットを購入する</a>
      <p class="pricenote">日時指定チケット制／表示価格のほか別途手数料がかかります</p>
    </div>
  </div>
</section>

<section class="sec" id="team">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">TEAM</h2><p class="sechead-ja">企画・プロデュース</p><div class="rule"></div></div>
    <div class="teamgrid">
      <div class="teamimg imgslot"><span>チーム写真</span></div>
      <div>
        <p class="teamp">「ウワサバナシ調査委員会」は、街に流れる噂や記憶を題材に物語体験をつくる企画チームです。没入型公演、体験型展示、街歩き型のイベントなど、場所に宿る声を拾い上げ、ひとつの体験へと立ち上げます。</p>
        <p class="teamp">本公演では、渋谷サクラステージを舞台に、“噂”というもっとも身近な物語装置と向き合います。</p>
        <p style="margin:20px 0 0"><a href="#contact">最新情報を発信中 →</a></p>
      </div>
    </div>
  </div>
</section>

<section class="sec sec-alt" id="notes">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">NOTES</h2><p class="sechead-ja">注意事項 ─ ご購入前に必ずご確認ください</p><div class="rule"></div></div>
    <div class="notes">
      <h3 class="noteh">チケット・ご予約について</h3>
      <ul><li>体験時間は約80分を予定しております。</li><li>日時指定制です。ご希望の回をご予約ください。</li><li>チケット1枚につき、1名様のみご参加いただけます。</li><li>決済完了後の日時変更・キャンセル・返金は承っておりません。</li><li>複数名で体験されたい場合は、代表者様がまとめてご購入ください。</li></ul>
      <h3 class="noteh">ご来場・受付について</h3>
      <ul><li>開演時刻を過ぎますとご入場いただけません。10分前を目安にご来場ください。</li><li>受付にて有効なチケットをご提示いただけない場合、ご参加をお断りすることがございます。</li></ul>
      <h3 class="noteh">ご参加いただけない方</h3>
      <ul><li>15歳未満の方（保護者同伴の場合を含む）</li><li>心臓疾患・血圧の異常がある方、医療補助器具をご使用の方</li><li>パニック障害や発作の既往がある方、妊娠中の方</li><li>飲酒・酩酊状態の方</li><li>日本語での誘導に従うことが困難な方</li></ul>
      <h3 class="noteh">演出・場内でのお願い</h3>
      <ul><li>本公演には、暗闇・大音量・ストロボ・出演者による接触などの演出が含まれます。</li><li>出演者・スタッフの指示には必ずお従いください。</li><li>館内での飲食・喫煙、許可のない撮影・録音は固くお断りいたします。</li><li>SNS投稿の際は、ネタバレへのご配慮をお願いいたします。</li></ul>
    </div>
  </div>
</section>

<section class="sec" id="access">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">ACCESS</h2><p class="sechead-ja">アクセス</p><div class="rule"></div></div>
    <div class="acgrid">
      <div>
        <h3 class="acname">渋谷サクラステージ</h3>
        <p class="acp">〒150-0002 東京都渋谷区渋谷3-2-1</p>
        <p class="acp">JR「渋谷駅」新南改札より直結<br>東京メトロ・東急線「渋谷駅」C2出口より徒歩3分</p>
        <p style="margin-top:16px"><a href="https://www.google.com/maps/search/?api=1&query=渋谷サクラステージ" target="_blank" rel="noopener">Google Mapはこちら →</a></p>
      </div>
      <iframe class="map" src="https://maps.google.com/maps?q=%E6%B8%8B%E8%B0%B7%E3%82%B5%E3%82%AF%E3%83%A9%E3%82%B9%E3%83%86%E3%83%BC%E3%82%B8&t=&z=16&ie=UTF8&iwloc=B&output=embed" loading="lazy" title="地図"></iframe>
    </div>
  </div>
</section>

<section class="sec sec-alt" id="faq">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">FAQ</h2><p class="sechead-ja">よくある質問</p><div class="rule"></div></div>
    <div class="faqlist">
      <details class="faq"><summary><span class="qm">Q</span>体験時間はどれくらいですか？</summary><p>約80分を予定しています。</p></details>
      <details class="faq"><summary><span class="qm">Q</span>イマーシブ体験が初めてでも楽しめますか？</summary><p>はい、初めての方もお楽しみいただけます。知識や事前準備は必要ありません。</p></details>
      <details class="faq"><summary><span class="qm">Q</span>ホラー要素はありますか？</summary><p>本公演には、暗闇や不穏な演出が含まれます。驚かせることを目的とした過度な演出はございませんが、ご不安な場合はお問い合わせください。</p></details>
      <details class="faq"><summary><span class="qm">Q</span>謎解きはありますか？</summary><p>いわゆる謎解き要素は基本的にございません。証言を聞き、あなた自身の選択をお楽しみください。</p></details>
      <details class="faq"><summary><span class="qm">Q</span>一度体験したらもう楽しめませんか？</summary><p>選択によって展開が変わるため、何度でもお楽しみいただけます。</p></details>
      <details class="faq"><summary><span class="qm">Q</span>友達やグループでの参加はできますか？</summary><p>複数人でのご参加も歓迎です。体験の途中で一時的に離れ離れになる場合があります。</p></details>
      <details class="faq"><summary><span class="qm">Q</span>遅れた場合、入場できますか？</summary><p>他のお客様の体験の関係上、途中入場は一律お断りしております。開演10分前には必ずお越しください。</p></details>
      <details class="faq"><summary><span class="qm">Q</span>年齢制限はありますか？</summary><p>本公演は15歳以上の方のみご参加いただけます。未就学児・乳幼児のご入場は保護者同伴の場合でもご遠慮いただいております。</p></details>
    </div>
  </div>
</section>

<section class="sec" id="contact">
  <div class="wrap rv">
    <div class="sechead"><h2 class="sechead-en">CONTACT</h2><p class="sechead-ja">お問い合わせ</p><div class="rule"></div></div>
    <div style="text-align:center"><a class="buy" href="https://kabuexlabs.com/#contact">お問い合わせページへ</a></div>
  </div>
</section>

<footer class="ftr">
  <div class="rv">
    <img class="ftrlogo" src="/assets/toudaimurder/logo.jpg" alt="ウワサバナシ調査委員会">
    <div class="snsrow"><a class="sns" href="https://x.com/" target="_blank" rel="noopener">X（旧Twitter）</a></div>
    <p class="staff">主催・企画：株式会社ex Labs<br>脚本：とんとん<br>会場：渋谷サクラステージ<br>運営会社：<a href="https://kabuexlabs.com/" target="_blank" rel="noopener">株式会社ex Labs</a></p>
    <p class="copy">© 株式会社ex Labs All Rights Reserved.</p>
  </div>
</footer>

<script is:inline>
(function () {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
    document.querySelectorAll('.rv').forEach(function (el) { el.classList.add('vis'); });
    return;
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('vis');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.rv').forEach(function (el) { io.observe(el); });
})();
</script>

<style>
:root{--accent:#5fc9dc;--bg:#0a0d10;--bg2:#10151a;--ink:#d9e2e6;--dim:#8a979e}
:global(html){background:var(--bg)}
body{margin:0;background:var(--bg);color:var(--ink);font-family:'Zen Kaku Gothic New',sans-serif;line-height:1.9}
a{color:var(--accent);text-decoration:none}a:hover{color:#fff}
.mincho{font-family:'Shippori Mincho',serif}
.accent{color:var(--accent)}
.dim{color:var(--dim)}
.wrap{max-width:1080px;margin:0 auto;padding:0 24px}
.sec{padding:110px 0}
.sec-alt{background:var(--bg2)}
.sechead{display:flex;flex-direction:column;align-items:center;gap:6px;margin-bottom:64px}
.sechead-en{font-family:'Shippori Mincho',serif;font-size:34px;letter-spacing:.35em;color:#fff;margin:0}
.sechead-ja{font-size:13px;letter-spacing:.3em;color:var(--accent);margin:0}
.rule{width:36px;height:1px;background:var(--accent);margin-top:10px}
.hdr{position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;justify-content:center;gap:36px;padding:14px 20px;background:rgba(10,13,16,.82);backdrop-filter:blur(8px);border-bottom:1px solid rgba(255,255,255,.06)}
.hdr a{color:var(--ink);font-size:13px;letter-spacing:.14em}
.hdr a:hover{color:var(--accent)}
.hlogo{height:44px;filter:invert(1);mix-blend-mode:screen}
.cta{position:fixed;right:22px;bottom:22px;z-index:60;background:var(--accent);color:#06141a;font-weight:700;letter-spacing:.14em;padding:19px 34px;border-radius:999px;box-shadow:0 8px 28px rgba(0,0,0,.55);font-size:15px;animation:ctapulse 2.4s ease-out infinite}
.cta:hover{color:#000;filter:brightness(1.12);animation-play-state:paused}
@keyframes ctapulse{0%{box-shadow:0 8px 28px rgba(0,0,0,.55),0 0 0 0 color-mix(in srgb,var(--accent) 55%,transparent)}75%{box-shadow:0 8px 28px rgba(0,0,0,.55),0 0 0 20px color-mix(in srgb,var(--accent) 0%,transparent)}100%{box-shadow:0 8px 28px rgba(0,0,0,.55),0 0 0 0 color-mix(in srgb,var(--accent) 0%,transparent)}}
.rv{opacity:0;transform:translateY(28px);transition:opacity .9s ease,transform .9s ease}
.rv.vis{opacity:1;transform:none}
@keyframes rise{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:none}}
.kvlogo{animation:rise 1.3s ease .1s both}
.kvcatch{animation:rise 1.3s ease .5s both}
.kvmeta{animation:rise 1.3s ease .9s both}
.snsrow{display:flex;justify-content:center;flex-wrap:wrap;gap:14px;margin:0 0 34px}
.sns{display:inline-flex;align-items:center;justify-content:center;height:44px;padding:0 24px;border:1px solid rgba(255,255,255,.18);border-radius:999px;color:var(--ink);font-size:13px;letter-spacing:.12em}
.sns:hover{border-color:var(--accent);color:var(--accent)}
.teamimg{width:280px;height:280px}
.kv{position:relative;min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:34px;text-align:center;overflow:hidden;padding:120px 24px 80px;box-sizing:border-box}
.kvbg{position:absolute;inset:0;background:radial-gradient(ellipse 90% 70% at 50% 30%,#15222b 0%,var(--bg) 70%);z-index:0}
.kvnoise{position:absolute;inset:0;opacity:.5;background:repeating-linear-gradient(0deg,transparent 0 3px,rgba(255,255,255,.012) 3px 4px);z-index:0}
.kvin{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:30px}
.kvlogo{width:min(560px,82vw);filter:invert(1);mix-blend-mode:screen}
.kvcatch{font-size:clamp(15px,2vw,19px);letter-spacing:.22em;color:var(--ink);margin:0}
.kvmeta{display:flex;flex-wrap:wrap;justify-content:center;gap:14px 40px;font-family:'Shippori Mincho',serif}
.kvdate{font-size:clamp(22px,3.4vw,34px);letter-spacing:.12em;color:#fff}
.kvvenue{font-size:14px;letter-spacing:.24em;color:var(--dim)}
.news{background:var(--accent);color:#06141a;overflow:hidden;white-space:nowrap;padding:10px 0;font-size:13px;font-weight:700;letter-spacing:.08em}
.newsin{display:inline-block;animation:tick 30s linear infinite}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.newsitem{display:inline-block;padding:0 34px}
.storyp{font-family:'Shippori Mincho',serif;font-size:clamp(15px,1.7vw,18px);letter-spacing:.1em;line-height:2.6;margin:0 0 44px;text-align:center}
.storylead{font-size:clamp(19px,2.4vw,26px);color:#fff;letter-spacing:.16em}
.simg{width:min(720px,100%);height:340px;margin:56px auto;display:block}
.imgslot{border:1px dashed rgba(255,255,255,.15);display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,.02)}
.imgslot span{font-size:13px;letter-spacing:.12em;color:var(--dim)}
.aboutgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:28px}
.abcard{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07);padding:38px 30px}
.abnum{font-family:'Shippori Mincho',serif;font-size:15px;letter-spacing:.3em;color:var(--accent);margin:0 0 16px}
.abh{font-family:'Shippori Mincho',serif;font-size:20px;line-height:1.8;letter-spacing:.06em;color:#fff;margin:0 0 16px}
.abp{font-size:14px;color:var(--dim);margin:0}
.castbox{text-align:center;padding:70px 24px;border:1px dashed rgba(255,255,255,.15)}
.castsoon{font-family:'Shippori Mincho',serif;font-size:clamp(20px,3vw,30px);letter-spacing:.4em;color:var(--dim);margin:0}
.price{display:flex;flex-wrap:wrap;justify-content:center;gap:22px;margin:0 0 40px}
.pricebox{background:var(--bg2);border:1px solid rgba(255,255,255,.08);padding:30px 46px;text-align:center;min-width:200px}
.pricelabel{font-size:13px;letter-spacing:.2em;color:var(--accent);margin:0 0 8px}
.priceval{font-family:'Shippori Mincho',serif;font-size:30px;color:#fff;margin:0}
.pricenote{font-size:12px;color:var(--dim);text-align:center;margin:18px 0 0}
.buy{display:inline-block;background:var(--accent);color:#06141a;font-weight:700;letter-spacing:.14em;padding:18px 60px;font-size:15px}
.buy:hover{color:#000;filter:brightness(1.12)}
.teamgrid{display:grid;grid-template-columns:280px 1fr;gap:44px;align-items:start}
.teamp{font-size:14px;color:var(--dim);margin:0 0 14px}
.notes{max-width:820px;margin:0 auto}
.noteh{font-family:'Shippori Mincho',serif;font-size:17px;letter-spacing:.1em;color:var(--accent);border-bottom:1px solid rgba(255,255,255,.1);padding-bottom:10px;margin:44px 0 16px}
.notes ul{margin:0;padding-left:22px}
.notes li{font-size:13px;color:var(--dim);margin-bottom:8px}
.acgrid{display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:start}
.acname{font-family:'Shippori Mincho',serif;font-size:24px;color:#fff;letter-spacing:.08em;margin:0 0 10px}
.acp{font-size:14px;color:var(--dim);margin:0 0 8px}
.map{width:100%;height:320px;border:0;filter:grayscale(1) invert(.92) contrast(.9)}
.faqlist{max-width:820px;margin:0 auto}
.faq{border-bottom:1px solid rgba(255,255,255,.08)}
.faq summary{cursor:pointer;list-style:none;display:flex;gap:16px;align-items:baseline;padding:22px 8px;font-family:'Shippori Mincho',serif;font-size:16px;color:#fff;letter-spacing:.04em}
.faq summary::-webkit-details-marker{display:none}
.faq summary:hover{color:var(--accent)}
.qm{color:var(--accent);font-size:18px;flex-shrink:0}
.faq p{margin:0;padding:0 8px 24px 42px;font-size:14px;color:var(--dim)}
.ftr{background:#05080a;padding:70px 0 40px;text-align:center}
.ftrlogo{height:70px;filter:invert(1);mix-blend-mode:screen;margin-bottom:30px}
.staff{font-size:12px;color:var(--dim);letter-spacing:.1em;line-height:2.2;margin:0 0 34px}
.copy{font-size:11px;color:#4a565c;letter-spacing:.08em;margin:0}
@media (max-width:760px){.hdr{gap:8px 14px;flex-wrap:wrap;padding:10px 12px}.hdr a{font-size:11px;letter-spacing:.08em}.hlogo{height:30px}.hbrand{order:-1;flex-basis:100%;display:flex;justify-content:center}.teamgrid,.acgrid{grid-template-columns:1fr}.teamimg{width:100%;height:240px}.sec{padding:76px 0}.kv{padding:130px 20px 70px}.simg{height:220px}.price{gap:14px}.pricebox{flex:1 1 140px;padding:24px 20px;min-width:0}.buy{display:block;padding:17px 20px}.cta{right:14px;bottom:14px;padding:16px 24px;font-size:14px}.map{height:260px}}
</style>
</body>
</html>
