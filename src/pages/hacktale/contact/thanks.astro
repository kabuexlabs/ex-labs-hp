---
// お問い合わせ送信完了ページ。
// JS 無効環境で FormSubmit へ通常 POST した際のリダイレクト先（_next）。
import HacktaleLayout from '../../../layouts/HacktaleLayout.astro';
import { htBase } from '../../../data/hacktale';
---

<HacktaleLayout
  title="お問い合わせありがとうございました | ハックテイル"
  description="お問い合わせを受け付けました。折り返し担当者よりご連絡いたします。"
  twitterCard="summary"
  back={{ href: `${htBase}/`, label: 'トップへ戻る' }}
  noindex
>

<section class="sec"><div class="wrap thanks">
<p class="kick en m0">THANK YOU</p>
<h1 class="t1">お問い合わせ<br>ありがとうございました</h1>
<p class="body">送信が完了しました。<br>折り返し担当者よりご連絡いたしますので、今しばらくお待ちください。</p>
<div class="fx ac gap16 fwrap" style="margin-top:36px"><a class="btn btn-acc" href={`${htBase}/`}>トップへ戻る</a><a class="btn" href={`${htBase}/#works`}>作品一覧を見る</a></div>
</div></section>

</HacktaleLayout>

<style>
.sec{padding:112px 0 128px}
.kick{font-size:14px;letter-spacing:.35em;color:var(--acc)}
.t1{font-size:clamp(28px,4vw,44px);font-weight:900;line-height:1.5;margin:18px 0 20px}
.body{font-size:15px;line-height:2.1;color:#c9c5ba;margin:0}
</style>
