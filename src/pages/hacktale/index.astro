</style>

<script>
// スクロールリビール。JS 無効時も見えるよう、初期表示外の要素だけを JS で隠してから発火する。
// モバイルではカード列が横スクロールになるため、カード個別ではなく列全体を対象にする
// （個別に監視すると横方向に画面外のカードが隠れたままになり「消えた」ように見える）。
const perCard = window.matchMedia('(min-width: 901px)').matches;
const els = document.querySelectorAll<HTMLElement>(perCard ? '.card, .shead' : '.cards, .shead');
const io = new IntersectionObserver(
  (entries) => {
    entries.forEach((en) => {
      if (en.isIntersecting) {
        en.target.classList.add('rev');
        io.unobserve(en.target);
      }
    });
  },
  { threshold: 0.15 },
);
els.forEach((el, i) => {
  if (el.getBoundingClientRect().top > window.innerHeight * 0.9) {
    el.classList.add('pre');
    el.style.transitionDelay = (i % 3) * 0.12 + 's';
  }
  io.observe(el);
});
</script>
