import { jsonLd } from '../../lib/microcms';
import HacktaleContactForm from '../../components/HacktaleContactForm.astro';
import {
  htBase,
  htWorks,
  HT_CONTACT_EMAIL,
  HT_LINE_URL,
  HT_X_URL,
  HT_X_HANDLE,
  HT_COMPANY_URL,
} from '../../data/hacktale';

const tickerItems = [
  '『東京都頭脳王決定戦 開催中』',
  'JANKEN24、完売。',
  '東京都頭脳王決定戦、チケット完売',
];

const site = Astro.site ?? new URL('https://kabuexlabs.com');
const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'HACKTALE（ハックテイル）',
  alternateName: ['ハックテイル', 'HACKTALE'],
  description:
    '交渉・閃き・論理で勝敗が決まる『頭脳戦』を制作・展開するレーベル。プレゼント・ポーカー、人狼定理、ダイスボックス、東京都頭脳王決定戦、JANKEN24などを手がける。',
  url: new URL('/hacktale/', site).toString(),
  logo: new URL('/assets/hacktale/ogp.png', site).toString(),
  email: HT_CONTACT_EMAIL,
  sameAs: [HT_X_URL, HT_LINE_URL],
  parentOrganization: { '@type': 'Organization', name: '株式会社ex Labs', url: 'https://kabuexlabs.com/' },
  knowsAbout: ['頭脳戦', '頭脳戦制作', '交渉ゲーム', '心理戦'],
