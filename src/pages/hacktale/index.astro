>

<script type="application/ld+json" set:html={jsonLd(orgLd)} />

{/* ループ系は「前半＋複製の後半」を並べ、-50% 移動でちょうど前半の幅ぶん戻る構造。
    コンテナ側の gap だと継ぎ目がずれるため、間隔は各半分の padding-right で持つ */}
<div class="tkr"><div class="tk">
<div class="tkhalf">{tickerItems.map((t) => <span>{t}</span>)}</div>
<div class="tkhalf" aria-hidden="true">{tickerItems.map((t) => <span>{t}</span>)}</div>
</div></div>

<div class="fmq fmq-top" aria-hidden="true"><div class="fmt en"><span class="fmhalf">HACKTALE — BRAIN &amp; NEGOTIATION GAMES —</span><span class="fmhalf">HACKTALE — BRAIN &amp; NEGOTIATION GAMES —</span></div></div>

<section class="hero" id="top"><div class="hbg"></div><div class="wrap posrel">
<p class="kick en m0">HACKTALE — BRAIN &amp; NEGOTIATION GAMES</p>
<h1 class="h1">日本で唯一無二の<br>『頭脳戦』制作団体</h1>
<p class="lead m0">交渉/閃きなどを必要とする『頭脳戦』を制作している団体、ハックテイルです。</p>
<div class="fx ac gap16 fwrap" style="margin-top:40px">
<a class="btn btn-acc" href="#works">作品一覧を見る</a>
<a class="btn" href={HT_LINE_URL} target="_blank" rel="noopener">公式LINEで予約</a>
<a class="btn" href={HT_X_URL} target="_blank" rel="noopener">Xを見る</a>
</div>
</div></section>

<section class="sec" id="works"><div class="wrap">
<div class="shead"><span class="en st">WORKS</span><span class="sj">作品一覧</span><a class="more en" href={`${htBase}/works/`}>MORE</a></div>
<div class="cards">
{htWorks.map((w) => (
