---
// 公演「怪盗と秘密の試験」（IMMERSIVE ILLUSION）公式ティザーLP。
// まだ一般公開しないサブページ — noindex を付け、サイトマップ
// (src/pages/sitemap.xml.ts の STATIC_PATHS) にも載せていない。
// コーポレートサイトとはデザイン系統が別物なので BaseLayout は
// 使わず、このファイルだけで完結させている。
// デザインハンドオフ（Claude Design）を Astro に移植したもの。

const title = '【公式】怪盗と秘密の試験 | イマーシブイリュージョン';
const description =
  'イマーシブ×マジック公演「怪盗と秘密の試験」公式サイト。義賊組織「レイヴン怪盗団」からの招待状を手に、会員制バーで団員候補として"秘密の試験"へ挑むイマーシブ体験。日本一・世界7位のプロマジシャン・才藤大芽が監修・出演。2026年9月、東京・六本木にて開催。';

const newsItems = [
  { date: '2026.07.22', text: '出演者情報を公開しました' },
  { date: '2026.07.11', text: '出演マジシャンに才藤大芽の出演が決定しました' },
  { date: '2026.07.11', text: 'ティザーサイトを公開しました' },
];

// 本イベントの特徴（公式チケットサイトの記載に準拠）。
const abouts = [
  {
    num: '01',
    h: '「会員制バー」が<br>物語の舞台。',
    p: '舞台は、通常は会員しか足を踏み入れることのできない会員制バー。限られた人だけが扉を開くことを許される、非日常的で秘密めいた空間そのものが、レイヴン怪盗団の物語を構成する一部となります。',
  },
  {
    num: '02',
    h: 'あなた自身が<br>“怪盗候補”に。',
    p: '物語を外から観るだけではありません。あなたはレイヴン怪盗団の団員候補となり、登場人物と実際に会話しながら秘密の試験へ挑戦します。仲間との協力、駆け引き、そして自らの選択が、あなただけの体験を形づくります。',
  },
  {
    num: '03',
    h: '日本一・世界7位の<br>本格イリュージョン。',
    p: 'イリュージョンを監修・実演するのは、プロマジシャン・才藤大芽。世界大会で評価された技術と、至近距離だからこそ味わえる驚きを、イマーシブストーリーの中で目の前で体感していただきます。',
  },
];

// イベント当日の流れ（公式チケットサイトより）。
const flowSteps = [
  { n: '1', t: '受付', d: '指定された受付場所へ、チケットに記載された受付時間までにお越しください。受付時にチケットを確認いたします。会員制バーという会場の性質上、受付時間より前に店内へ入ることはできません。スタッフの案内があるまで、指定された場所でお待ちください。' },
  { n: '2', t: '事前説明', d: 'イベントへの参加方法や注意事項について、スタッフからご案内します。' },
  { n: '3', t: '会員制バーへの入場', d: 'スタッフの案内に従い、秘密の試験会場となる会員制バーへ入場していただきます。扉を開けた瞬間から、皆様は「レイヴン怪盗団」の団員候補です。' },
  { n: '4', t: '秘密の試験開始', d: '登場人物との会話や仲間との協力、さまざまな試練を通して、怪盗としての資質を示してください。試験の中では、才藤大芽氏による本格的なイリュージョンも目の前で繰り広げられます。' },
  { n: '5', t: '物語の終了', d: '試験の結果を見届けたところで、イベント終了となります。終了後はスタッフの案内に従ってご退出ください。' },
];

// 出演者（才藤大芽は TEAM セクションで別掲）。X ハンドルは @ を除いた値。
const cast = [
  { slug: 'shiera', name: 'しえら', x: 'shierrrrrrra', bio: 'ダンサー、アクターなどをメインに活動しています。たまに歌って踊ったりもします。' },
  { slug: 'ono-ai', name: '大野愛', x: 'madoka145', bio: '舞台やイマーシブシアターを中心に、俳優・ダンサーとして活動中。マーダーミステリーのGMとしての経験も重ね、エンターテイメントの現場で幅広く活躍している。' },
  { slug: 'sugita-maho', name: '杉田真帆', x: 'Maho__0407', bio: '舞台役者、フリーランスで都内で活動中。' },
  { slug: 'kanade-waon', name: '花奏和音', x: 'waonnu', bio: '山形県出身。東北芸術工科大学デザイン工学部卒。18歳から地元劇団で演技を学ぶ。退団後も小劇場を中心に活動を続け、2020年から東京での演劇活動を開始。2025年2月には、女優・千歳まち氏との演劇ユニット『花千本produce』を旗揚げし、初回公演ではプロデュースや出演のほか宣伝美術も務めた。現在イマーシブシアターや体験型コンテンツに多く出演するほか、『ストーリープレイングシアター』にてGMを務めるなど、活動の幅を広げる。' },
  { slug: 'mayuri', name: 'まゆり（楯真由子）', x: 'MayuliG_G6', bio: '出てくる度、物騒な事件を起こしがちなお姉さんです。今日はどんな風に君たちを可愛がろうかな。なんてね。' },
  { slug: 'sasano-ami', name: '佐々野愛美', x: 'Ami_Sasano', bio: '俳優、タレント、モデルなどマルチに活動中。現在はイマーシブシアターを中心に活動しており、マダミスや謎解きなど体験型コンテンツが大好き。' },
  { slug: 'miyasaka-rino', name: '宮坂莉乃', x: 'MiyasakaRino', bio: '長野県出身。2020年、舞台を中心に活動を開始。近年はイマーシブ作品に出演する。趣味はマーダーミステリー、人狼ゲーム、シナリオ制作。' },
  { slug: 'kameda-risa', name: '亀田理紗', x: 'kame_yuto', bio: '俳優・MC。謎解きゲームやイマーシブシアターなど、体験型エンターテインメントを中心に活動。芝居歴18年、キャスト歴12年。演技と進行を通して、物語への没入感を支えることを得意としている。' },
];

const faqs = [
  { q: '会場はどんな場所ですか？', a: '通常は会員しか入ることのできない会員制バーが舞台です。閉ざされた秘密めいた空間そのものが、物語を構成する一部となります。' },
  { q: 'マジックショーとの違いは何ですか？', a: '客席から観るショーではなく、あなた自身が団員候補として物語に参加するイマーシブ（没入型）体験です。マジックは物語の中で、目の前で繰り広げられます。' },
  { q: 'イマーシブ体験や謎解きが初めてでも楽しめますか？', a: 'はい。特別な知識や経験は必要ありません。体験中は登場人物やスタッフが必要に応じて進行をサポートしますので、はじめての方もお楽しみいただけます。' },
  { q: '1人でも参加できますか？', a: 'はい、お1人でのご参加も歓迎です。複数名でのご参加ももちろんお楽しみいただけます。' },
  { q: 'お酒は飲めますか？', a: '会場は会員制バーです。お飲み物については当日会場にてご案内いたします。なお、飲酒により正常な判断・行動が難しいとスタッフが判断した場合は、ご参加をお断りすることがあります。' },
  { q: '服装の指定はありますか？', a: '特に指定はございません。会員制バーの雰囲気に合わせた服装で、物語の世界をお楽しみください。' },
];
---

<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<meta name="robots" content="noindex, nofollow">
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="website">
<meta property="og:site_name" content="怪盗と秘密の試験">
<meta property="og:locale" content="ja_JP">
<link rel="icon" href="/favicon.ico" sizes="48x48">
<link rel="icon" type="image/png" href="/favicon-ex.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Zen+Old+Mincho:wght@400;500;700;900&family=Cinzel:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

<header class="hdr">
<div><div class="hdr-title">怪盗と秘密の試験</div><div class="hdr-org latin">IMMERSIVE ILLUSION</div></div>
<nav class="nav">
<a href="#story">STORY</a><a href="#about">ABOUT</a><a href="#team">TEAM</a><a href="#cast">CAST</a><a href="#ticket">TICKET</a><a href="#flow">FLOW</a><a href="#access">ACCESS</a><a href="#faq">FAQ</a><a href="#contact">CONTACT</a>
</nav>
<a class="cta" href="#ticket">チケット</a>
</header>

<main>

<section class="kv" id="kv">
<div class="kv-scrim"></div>
<div class="kv-body">
<div class="kv-logo imgslot" role="img" aria-label="ロゴ画像（準備中）"><span>LOGO</span></div>
<div class="kv-org latin">IMMERSIVE ILLUSION PRESENTS</div>
<h1 class="kv-title">怪盗と秘密の試験</h1>
<div class="kv-sub latin">THE PHANTOM THIEF AND THE SECRET EXAMINATION</div>
<div class="badge">会員制バー × イマーシブ × イリュージョン</div>
<div class="kv-date">2026年9月　開催</div>
<div class="kv-meta"><span>東京・六本木</span><span>出演マジシャン：才藤大芽</span></div>
</div>
</section>

<section class="news" id="news">
<div class="inner">
<div class="label label-center">News</div>
{newsItems.map(({ date, text }) => (
  <div class="news-row"><span class="news-date latin">{date}</span><span>{text}</span></div>
))}
</div>
</section>

<section class="sec" id="story">
<div class="sechead rv"><span class="label">Story</span><h2 class="h2">ストーリー</h2><span class="rule"></span></div>
<div class="narrow">
<p class="story-p rv">ある日、あなたのもとへ一通の招待状が届く。<br>差出人は、都市伝説として語られる義賊組織<br><span class="acc">「レイヴン怪盗団」</span>。</p>
<div class="letter rv" role="img" aria-label="招待状：秘密の試験に招待する ── レイヴン怪盗団より">
<div class="letter-in">
<div class="lcol lmain">{[...'秘密の試験に'].map((c) => (<span>{c}</span>))}</div>
<div class="lcol lmain">{[...'招待する'].map((c) => (<span>{c}</span>))}</div>
<div class="lcol lsign">{[...'レイヴン怪盗団より'].map((c) => (<span>{c}</span>))}</div>
</div>
</div>
<p class="story-p rv" style="margin-top:48px">招待状に記されていたのは、ただ一文。<br>それが何を意味するのかは、誰も知らない。<br><br>興味をひかれたあなたが指定された場所へ向かうと、<br>そこにあったのは、普段は会員しか<br>入ることのできない<span class="acc">秘密のバー。</span></p>
<div class="story-imgs rv">
<div class="story-img imgslot" role="img" aria-label="会員制バーの内観写真（準備中）"><span>会員制バーの内観写真</span></div>
<div class="story-img imgslot" role="img" aria-label="雰囲気写真（準備中）"><span>雰囲気写真</span></div>
</div>
<p class="story-p rv" style="margin-bottom:0">重い扉の向こうで、<br>あなたを待ち受けていたものとは──。<br><br>その扉を開けた瞬間から、<br>あなたの日常は<span class="acc">終わりを告げる。</span></p>
</div>
</section>

<section class="sec sec-alt" id="about">
<div class="sechead rv"><span class="label">About</span><h2 class="h2">本公演の楽しみ方</h2><span class="rule"></span></div>
<div class="inner about-grid">
{abouts.map(({ num, h, p }) => (
  <div class="about-card rv"><span class="about-num latin">{num}</span><h3 class="about-h" set:html={h}></h3><p class="about-p">{p}</p></div>
))}
</div>
</section>

<section class="sec" id="team">
<div class="sechead rv"><span class="label">Team</span><h2 class="h2">イリュージョン監修・出演</h2><span class="rule"></span></div>
<div class="inner">
<div class="cast-main rv">
<img class="cast-photo" src="/assets/kaitou/cast/saito-taiga.jpg" width="720" height="960" loading="lazy" alt="才藤大芽 宣材写真">
<div>
<div class="cast-role latin">MAGICIAN / SUPERVISOR</div>
<h3 class="cast-name">才藤大芽</h3>
<div class="dim cast-latin">SAITO TAIGA</div>
<p class="cast-bio">京都大学卒業後、プロマジシャンとして活動を開始。マジック界最高峰の世界大会「FISM」に日本代表として2度選出され、2018年大会では世界7位を記録。2021年には「Japan National Championship of Magic」で優勝を果たした、日本一・世界7位の実績を持つマジシャンです。ハリウッドにあるマジック界の殿堂「マジックキャッスル」への出演歴も持ち、『ヒルナンデス！』『チコちゃんに叱られる！』『開運！なんでも鑑定団』など数々のテレビ番組にも出演。本イベントではイリュージョンを監修するだけでなく、才藤氏本人が物語の登場人物として出演し、至近距離ならではの驚きを体感していただきます。</p>
<div class="cast-links"><a href="https://www.saitotaiga.com/" target="_blank" rel="noopener">Official Site</a><a href="https://x.com/taiga365ib" target="_blank" rel="noopener">X (Twitter)</a></div>
</div>
</div>
</div>
</section>

<section class="sec sec-alt" id="cast">
<div class="sechead rv"><span class="label">Cast</span><h2 class="h2">キャスト</h2><span class="rule"></span></div>
<div class="inner cast-grid rv">
{cast.map((c, i) => (
  <button class="castc" type="button" data-cast={i}>
  <img class="castc-photo" src={`/assets/kaitou/cast/${c.slug}.jpg`} width="720" height="960" loading="lazy" alt={`${c.name} 宣材写真`}>
  <span class="castc-name">{c.name}</span>
  </button>
))}
</div>
<p class="casthint dim">※ 写真をタップするとプロフィールをご覧いただけます</p>
</section>

<dialog class="castdlg" id="castdlg">
<button class="dlgclose" type="button" aria-label="閉じる">×</button>
<div class="dlgbody">
<img class="dlgimg" id="dlgimg" src="" alt="">
<div class="dlginfo">
<p class="dlgname" id="dlgname"></p>
<a class="dlgx latin" id="dlgx" href="#" target="_blank" rel="noopener"></a>
<p class="dlgbio" id="dlgbio"></p>
</div>
</div>
</dialog>

<section class="sec" id="ticket">
<div class="sechead rv"><span class="label">Ticket</span><h2 class="h2">チケット情報</h2><span class="rule"></span></div>
<div class="narrow ticket-box rv">
<div class="price">¥4,900 <small>（税込）/ 1名</small></div>
<div class="ticket-type">日時指定チケット制</div>
<a class="buy" href="#ticket" data-ticket>チケットを購入する</a>
<div class="tnote">※外部チケットサイトが開きます（販売ページ準備中）<br>※購入後のお客様都合によるキャンセル・払い戻し・日時変更はお受けできません<br>※表示価格のほか、別途手数料がかかる場合があります</div>
</div>
</section>

<section class="sec sec-alt" id="flow">
<div class="sechead rv"><span class="label">Flow</span><h2 class="h2">当日の流れ</h2><span class="rule"></span></div>
<div class="narrow flow">
{flowSteps.map((s) => (
  <div class="flow-row rv">
  <div class="flow-n latin">{s.n}</div>
  <div class="flow-body"><h3 class="flow-t">{s.t}</h3><p class="flow-d">{s.d}</p></div>
  </div>
))}
</div>
</section>

<section class="sec" id="notes">
<div class="sechead rv"><span class="label">Notice</span><h2 class="h2">注意事項</h2><span class="rule"></span></div>
<div class="narrow rv">
<h3 class="notes-h">キャンセル・日時変更について</h3>
<ul class="notes-ul">
<li>チケット購入後のお客様都合によるキャンセル、払い戻しおよび日時変更は、システムの都合上お受けできません。</li>
<li>ご購入前に、参加日時や枚数を十分にご確認ください。</li>
</ul>
<h3 class="notes-h">イベント参加について</h3>
<ul class="notes-ul">
<li>本イベントは、参加者自身が物語の登場人物となって楽しむ体験型イベントです。</li>
<li>イベント中、キャストとの会話や参加者同士で協力する場面があります。</li>
<li>受付時間に遅れた場合、演出および進行の都合上、ご参加いただけません。</li>
<li>日本語で進行するイベントです。</li>
<li>飲酒により正常な判断や行動が難しいとスタッフが判断した場合、参加をお断りします。</li>
<li>スタッフおよびキャストの指示に従っていただけない場合、イベントの途中でも退場をお願いすることがあります。その場合の返金はいたしかねます。</li>
<li>本イベントはフィクションです。実在する人物、団体、事件等とは関係ありません。</li>
</ul>
<h3 class="notes-h">写真撮影・動画撮影・録音について</h3>
<ul class="notes-ul">
<li>主催者またはスタッフから明確な許可がある場合を除き、会場内での写真撮影、動画撮影および録音はすべて禁止です。</li>
<li>撮影許可が出た場合も、指定された時間・場所・内容の範囲内でのみ撮影可能です。</li>
<li>ネタバレとなる内容や、ほかの参加者が映り込んだ写真・動画を無断で公開することは禁止です。</li>
</ul>
<h3 class="notes-h">体験中の行為について</h3>
<ul class="notes-ul">
<li>キャストやほかの参加者に触れる行為は禁止です。</li>
<li>会場内の備品や装飾品には、スタッフまたはキャストから案内があった場合を除き、触れないでください。</li>
<li>キャストやほかの参加者に対する暴言、威圧的な行為、過度な接触は禁止です。</li>
<li>イベントの進行を妨げる行為や、ほかの参加者の体験を損なう行為はお控えください。</li>
</ul>
<h3 class="notes-h">ネタバレについて</h3>
<ul class="notes-ul">
<li>イベントの内容、仕掛け、試験の詳細、物語の結末など、ネタバレとなる情報をインターネットやSNS上で公開することはお控えください。</li>
<li>これから参加される方の体験を損なわないよう、ご配慮をお願いいたします。</li>
</ul>
<h3 class="notes-h">持ち物・手荷物について</h3>
<ul class="notes-ul">
<li>会場にクロークはございません。</li>
<li>大きな荷物を保管するスペースもございませんので、駅周辺のコインロッカーなどへお預けのうえ、できる限り身軽な状態でお越しください。</li>
<li>貴重品は必ずご自身で管理してください。紛失、盗難または破損について、主催者および会場は責任を負いかねます。</li>
<li>イベント開始前に、お手洗いなどをお済ませください。</li>
</ul>
</div>
</section>

<section class="sec sec-alt" id="access">
<div class="sechead rv"><span class="label">Access</span><h2 class="h2">アクセス</h2><span class="rule"></span></div>
<div class="inner acc-grid">
<div class="acc-dl rv">
<div class="acc-dt latin" style="margin-top:0">AREA</div><div class="acc-dd">東京・六本木エリアの会員制バー</div>
<div class="acc-dt latin">RECEPTION</div><div class="acc-dd">受付場所は、チケットご購入者にのみご案内いたします。受付時間より前の入場はできません。</div>
<div class="acc-dt latin">NEAREST STATION</div><div class="acc-dd">東京メトロ日比谷線・都営大江戸線「六本木駅」周辺</div>
