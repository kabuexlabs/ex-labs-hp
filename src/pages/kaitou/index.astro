  // 成功時はデザイン通りのサンクス表示、失敗時はエラー表示して再送可能にする。
  // JS無効時はブラウザ標準POSTにフォールバック（Formspreeの完了画面経由）。
  var form = document.getElementById('cform');
  var sent = document.getElementById('sentbox');
  var reset = document.getElementById('cformreset');
  if (form && sent) {
    var err = form.querySelector('.form-err');
    var btn = form.querySelector('.sendbtn');
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      if (err) err.hidden = true;
      var label = btn ? btn.textContent : '';
      if (btn) { btn.disabled = true; btn.textContent = '送信中…'; }
      fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' }
      }).then(function (res) {
        if (!res.ok) throw new Error('formspree ' + res.status);
        form.hidden = true;
        sent.hidden = false;
      }).catch(function () {
        if (err) err.hidden = false;
        if (btn) { btn.disabled = false; btn.textContent = label; }
      });
    });
  }
  if (reset && form && sent) {
    reset.addEventListener('click', function () {
      sent.hidden = true;
      form.hidden = false;
      form.reset();
      var b = form.querySelector('.sendbtn');
      if (b) { b.disabled = false; b.textContent = '送信する'; }
    });
  }
})();
</script>

<script is:inline define:vars={{ cast }}>
(function () {
  // キャストカードのクリックで、プロフィールをモーダル表示する。
  var dlg = document.getElementById('castdlg');
  if (!dlg || typeof dlg.showModal !== 'function') return;
  var img = document.getElementById('dlgimg');
  var name = document.getElementById('dlgname');
  var bio = document.getElementById('dlgbio');
  var x = document.getElementById('dlgx');
  document.querySelectorAll('.castc').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var c = cast[Number(btn.dataset.cast)];
      if (!c) return;
      img.src = '/assets/kaitou/cast/' + c.slug + '.jpg';
      img.alt = c.name + ' 宣材写真';
      name.textContent = c.name;
      bio.textContent = c.bio;
      x.textContent = '@' + c.x;
      x.href = 'https://x.com/' + c.x;
      dlg.showModal();
    });
  });
  dlg.querySelector('.dlgclose').addEventListener('click', function () { dlg.close(); });
  dlg.addEventListener('click', function (e) { if (e.target === dlg) dlg.close(); });
})();
</script>

</body>
</html>
