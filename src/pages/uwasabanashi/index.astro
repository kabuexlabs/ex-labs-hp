---
// 公演「ウワサバナシ調査委員会」公式LP。
// 検索インデックス許可済み（sitemap.xml の STATIC_PATHS にも掲載）。
// コーポレートサイトとはデザイン系統が別物なので BaseLayout は
// 使わず、このファイルだけで完結させている。

// キャスト一覧。写真は /public/assets/uwasabanashi/cast-<id>.webp に配置。
// 並び順は50音順（おおの→かなで→かわかみ→しえら→すぎた→べっとう→ほしの→まゆり→みずしろ→わため）。
// キャストを追加・変更するときも必ず50音順を維持すること。
const cast = [
  { id: 'ohno', name: '大野愛', x: 'madoka145', bio: '舞台やイマーシブシアターを中心に、俳優・ダンサーとして活動中。マーダーミステリーのGMとしての経験も重ね、エンターテイメントの現場で幅広く活躍している。' },
  { id: 'hanakanade', name: '花奏和音', x: 'waonnu', bio: '山形県出身。東北芸術工科大学デザイン工学部卒。18歳から地元劇団で演技を学ぶ。退団後も小劇場を中心に活動を続け、2020年から東京での演劇活動を開始。2025年2月には、女優・千歳まち氏との演劇ユニット『花千本produce』を旗揚げし、初回公演ではプロデュースや出演のほか宣伝美術も務めた。現在イマーシブシアターや体験型コンテンツに多く出演するほか、『ストーリープレイングシアター』にてGMを務めるなど、活動の幅を広げる。' },
  { id: 'kawakami', name: '川上雅人', x: 'masatooooo0801', bio: '東京を拠点に舞台、映像、イマーシブ、テーマパークと幅広く活動中。特技は人の顔と名前を覚えることと返信が早いこと。' },
  { id: 'shiera', name: 'しえら', x: 'shierrrrrrra', bio: 'ダンサー、アクターなどをメインに活動しています。たまに歌って踊ったりもします。' },
  { id: 'sugita', name: '杉田真帆', x: 'Maho__0407', bio: '舞台役者、フリーランスで都内で活動中' },
  { id: 'betto', name: 'べっとうかつき', x: 'katuki_betto', bio: 'ホラーやイマーシブ作品を中心に活動。出演に加え、企画や制作も行う。体験型エンターテインメントならではの没入感に魅力を感じ、観客の記憶に残る体験を目指して日々取り組んでいます。' },
  { id: 'hoshino', name: '星乃圭吾', x: 'KeigoHoshino', bio: '俳優・声優・アイドル・司会・エンタメクリエイターなど様々な分野で活動中です！座右の銘は『期待に応えて 予想を裏切る』' },
  { id: 'mayuri', name: 'まゆり（楯真由子）', x: 'MayuliG_G6', bio: '出てくる度、物騒な事件を起こしがちなお姉さんです。今日はどんな風に君たちを可愛がろうかな。なんてね。' },
  { id: 'mizushiro', name: '水城けい', x: 'mizushiro_kei', bio: '舞台やイマーシブ作品を中心に活動しています。体を使った表現やアクションが大好きです。一つ一つの出会いを大切に作品作りに向き合っております。' },
  { id: 'watame', name: '綿目霞', x: 'Watamekasumi', bio: '女優。主な出演作として「IdentityⅤ STAGE」心眼ヘレナ・アダムス役など。ストレートプレイから2.5次元舞台まで幅広くこなす。' },
];

const title = '【公式】ウワサバナシ調査委員会 | イマーシブ公演';
const canonical = 'https://kabuexlabs.com/uwasabanashi/';
const ogImage = 'https://kabuexlabs.com/assets/uwasabanashi/og.png';
const description =
  'イマーシブ公演「ウワサバナシ調査委員会」公式サイト。2026年9月19日・20日・26日・27日・10月3日・4日、渋谷サクラステージにて開催。ねぇ、知ってる？現実を変えることができるノートがあるって。';

// 検索結果のリッチリザルト用イベント構造化データ
const eventLd = {
  '@context': 'https://schema.org',
  '@type': 'TheaterEvent',
  name: 'ウワサバナシ調査委員会',
  description,
  url: canonical,
  image: ogImage,
  startDate: '2026-09-19',
  endDate: '2026-10-04',
  eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
  eventStatus: 'https://schema.org/EventScheduled',
  location: {
    '@type': 'Place',
    name: '渋谷サクラステージ',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '桜丘町1-1他',
      addressLocality: '渋谷区',
      addressRegion: '東京都',
      addressCountry: 'JP',
    },
  },
  offers: {
    '@type': 'Offer',
    price: '4000',
    priceCurrency: 'JPY',
    url: 'https://escape.id/uwasabanashi-org/e-case1/',
    availability: 'https://schema.org/InStock',
  },
  organizer: {
    '@type': 'Organization',
    name: '株式会社ex Labs',
    url: 'https://kabuexlabs.com/',
  },
};

// 公演日程（2026年）。KVに一覧表示する。
const dates = ['9.19', '9.20', '9.26', '9.27', '10.3', '10.4'];

// チケット販売ページ（escape.id）
const ticketUrl = 'https://escape.id/uwasabanashi-org/e-case1/';

const newsItems = [
  'NEWS ／ 2026.07.07 公式サイトを公開しました',
  'NEWS ／ 2026.07.07 チケット情報を公開しました',
];

const faqs = [
  { q: '体験時間はどれくらいですか？', a: '約70分を予定しています。' },
  { q: 'イマーシブ体験が初めてでも楽しめますか？', a: 'はい、初めての方もお楽しみいただけます。知識や事前準備は必要ありません。' },
  { q: 'ホラー要素はありますか？', a: 'ホラー演出はございません。' },
  { q: '謎解きはありますか？', a: '謎解き要素はございます。ただし、いわゆるパズルを解くような謎解きというよりも、集めた証言や手がかりを整理して真相へたどり着く、論理的な思考が求められる内容です。' },
  { q: '一度体験したらもう楽しめませんか？', a: '選択によって展開が変わるため、何度でもお楽しみいただけます。' },
  { q: '友達やグループでの参加はできますか？', a: '複数人でのご参加も歓迎です。体験の途中で一時的に離れ離れになる場合があります。' },
  { q: '遅れた場合、入場できますか？', a: '他のお客様の体験の関係上、途中入場は一律お断りしております。開演5分前には必ずお越しください。' },
  { q: '年齢制限はありますか？', a: '本公演は15歳以上の方のみご参加いただけます。未就学児・乳幼児のご入場は保護者同伴の場合でもご遠慮いただいております。' },
];
---

<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="website">
<meta property="og:url" content={canonical}>
<meta property="og:image" content={ogImage}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:site_name" content="ウワサバナシ調査委員会">
<meta property="og:locale" content="ja_JP">
<meta name="twitter:card" content="summary_large_image">
<script type="application/ld+json" set:html={JSON.stringify(eventLd)} />
<link rel="icon" href="/favicon.ico" sizes="48x48">
<link rel="icon" type="image/png" href="/favicon-ex.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@500;600;700;800&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet">
</head>
<body>

<header class="hdr">
<a href="#story">ストーリー</a>
<a href="#about">ABOUT</a>
<a href="#cast">キャスト</a>
<a href="#kv" class="hbrand"><img class="hlogo" src="/assets/uwasabanashi/logo-white.png" alt="ウワサバナシ調査委員会"></a>
<a href="#ticket">チケット</a>
<a href="#access">アクセス</a>
<a href="#faq">FAQ</a>
</header>

<a class="cta" href={ticketUrl} target="_blank" rel="noopener">チケットを予約</a>

<main>

<section class="kv" id="kv">
<div class="kvbg"></div>
<div class="kvnoise"></div>
<div class="kvin">
<img class="kvlogo" src="/assets/uwasabanashi/logo-white.png" alt="ウワサバナシ調査委員会">
<p class="kvcatch mincho">ねぇ、知ってる？<br>現実を変えることができるノートがあるって</p>
<div class="kvmeta">
<span class="kvdate">
<span class="kvd">2026.{dates[0]}<span class="kvsep">／</span>{dates[1]}<span class="kvsep">／</span>{dates[2]}</span><br class="sponly"><span class="kvsep pconly">／</span><span class="kvd">{dates[3]}<span class="kvsep">／</span>{dates[4]}<span class="kvsep">／</span>{dates[5]}</span>
</span>
<span class="kvvenue">渋谷サクラステージ</span>
</div>
</div>
</section>

<div class="news" aria-label="お知らせ">
<div class="newsin">
{[...newsItems, ...newsItems, ...newsItems].map((item) => (
  <span class="newsitem">{item}</span>
))}
</div>
</div>

<section class="sec" id="story">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">STORY</h2><p class="sechead-ja">ストーリー</p><div class="rule"></div></div>
<p class="storyp">2026年9月。<br>渋谷サクラステージで、<br>複数件の不審な出来事が発生した。</p>
<p class="storyp">現場から発見されたのは、<br>未来を書き換えるという「現実改変ノート」。</p>
<img class="simg" src="/assets/uwasabanashi/story-night.webp" alt="夜の渋谷サクラステージ" loading="lazy" width="1200" height="900">
<p class="storyp">囁かれるウワサバナシの真相を調査するため、<br>あなたは「ウワサバナシ調査委員会」の<br>新人調査員として、現地へ派遣された。</p>
<p class="storyp">施設内を巡り、<br>関係者への聞き込みを重ねながら、<br>現実改変ノートに隠されたルールと<br>不審な出来事の真相を解き明かしていく。</p>
<img class="simg" src="/assets/uwasabanashi/story-shop.webp" alt="調査の舞台となる店舗フロア" loading="lazy" width="1200" height="900">
<p class="storyp storylead">現実を改変した犯人は、一体誰なのか。<br>ウワサバナシの真相を暴け。</p>
<p class="fiction-note">※本公演の内容はフィクションです。<br>実在の事件・人物とは一切関係ありません。</p>
</div>
</section>

<section class="sec sec-alt" id="about">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">ABOUT</h2><p class="sechead-ja">本公演の楽しみ方</p><div class="rule"></div></div>
<div class="aboutgrid">
<div class="abcard"><p class="abnum">01</p><h3 class="abh">舞台は、<br>渋谷サクラステージ。</h3><p class="abp">物語の現場は、実在する渋谷の複合施設。<br>普段は入れない場所や、実在する店舗を巡り、<br>物語を進めていきます。</p></div>
<div class="abcard"><p class="abnum">02</p><h3 class="abh">あなた自身が<br>“調査員”になる。</h3><p class="abp">本公演は、あなたが物語の登場人物として噂の調査に巻き込まれていくイマーシブ（没入型）体験。集めた証言や、あなたの「選択」そのものが物語を動かします。</p></div>
<div class="abcard"><p class="abnum">03</p><h3 class="abh">あなた自身が<br>都市伝説の謎に挑む</h3><p class="abp">これは映画でも、演劇でも、いわゆる謎解きでもありません。それら全ての要素を複合させた、疑い、迷い、選ぶ——噂と向き合う行為そのものを楽しむ体験です。</p></div>
</div>
</div>
</section>

<section class="sec" id="cast">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">CAST</h2><p class="sechead-ja">キャスト</p><div class="rule"></div></div>
<div class="castgrid">
{cast.map((c, i) => (
  <button class="castcard" type="button" data-cast={i}>
    <img class="castimg" src={`/assets/uwasabanashi/cast-${c.id}.webp`} alt={c.name} loading="lazy" width="480" height="640">
    <span class="castname mincho">{c.name}</span>
    <span class="castx">@{c.x}</span>
  </button>
))}
</div>
<p class="casthint dim">※ 写真をタップするとプロフィールをご覧いただけます</p>
</div>
</section>

<dialog class="castdlg" id="castdlg">
<button class="dlgclose" type="button" aria-label="閉じる">×</button>
<div class="dlgbody">
<img class="dlgimg" id="dlgimg" src="" alt="">
<div class="dlginfo">
<p class="dlgname mincho" id="dlgname"></p>
<p class="dlgbio" id="dlgbio"></p>
<a class="dlgx" id="dlgx" href="#" target="_blank" rel="noopener">Xプロフィールを見る →</a>
</div>
</div>
</dialog>

<section class="sec sec-alt" id="ticket">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">TICKET</h2><p class="sechead-ja">チケット情報</p><div class="rule"></div></div>
<div class="price">
<div class="pricebox"><p class="pricelabel">全日程共通</p><p class="priceval">¥4,000<span class="dim priceunit">（税込）</span></p></div>
</div>
<div class="center">
<a class="buy" href={ticketUrl} target="_blank" rel="noopener">チケットを購入する</a>
<p class="pricenote">日時指定チケット制／表示価格のほか別途手数料がかかります</p>
</div>
</div>
</section>

<section class="sec" id="team">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">TEAM</h2><div class="rule"></div></div>
<div class="teamgrid">
<img class="teamimg" src="/assets/uwasabanashi/tonton.jpg" alt="とんとんのプロフィールアイコン" loading="lazy" width="400" height="400">
<div>
<p class="teamrole">脚本／制作</p>
<p class="teamname mincho">とんとん</p>
<p class="teamp">体験型コンテンツクリエイター。<br>公演型マーダーミステリーや<br>ストーリープレイングを中心に、<br>数多くの物語体験を提供している。</p>
<p class="teamp">近年はイマーシブコンテンツの脚本制作など、<br>没入型エンターテインメントの分野へも<br>活動の幅を広げている。</p>
<p class="teamp">代表作<br>『天使は花明かりの下で』<br>『白いウサギは歌わない』『BOOROOM』など</p>
</div>
</div>
</div>
</section>

<section class="sec sec-alt" id="notes">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">NOTES</h2><p class="sechead-ja">注意事項 ─ ご購入前に必ずご確認ください</p><div class="rule"></div></div>
<div class="notes">
<h3 class="noteh">チケット・ご予約について</h3>
<ul>
<li>体験時間は約70分を予定しております。</li>
<li>日時指定制です。ご希望の回をご予約ください。</li>
<li>チケット1枚につき、1名様のみご参加いただけます。</li>
<li>決済完了後の日時変更・キャンセル・返金は承っておりません。</li>
<li>複数名で体験されたい場合は、代表者様がまとめてご購入ください。</li>
</ul>
<h3 class="noteh">ご来場・受付について</h3>
<ul>
<li>開演時刻を過ぎますとご入場いただけません。5分前を目安にご来場ください。</li>
<li>受付にて有効なチケットをご提示いただけない場合、ご参加をお断りすることがございます。</li>
</ul>
<h3 class="noteh">ご参加いただけない方</h3>
<ul>
<li>15歳未満の方（保護者同伴の場合を含む）</li>
<li>心臓疾患・血圧の異常がある方、医療補助器具をご使用の方</li>
<li>パニック障害や発作の既往がある方、妊娠中の方</li>
<li>飲酒・酩酊状態の方</li>
<li>日本語での誘導に従うことが困難な方</li>
</ul>
<h3 class="noteh">演出・場内でのお願い</h3>
<ul>
<li>出演者・スタッフの指示には必ずお従いください。</li>
<li>館内での飲食・喫煙、許可のない撮影・録音は固くお断りいたします。</li>
<li>SNS投稿の際は、ネタバレへのご配慮をお願いいたします。</li>
</ul>
</div>
</div>
</section>

<section class="sec" id="access">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">ACCESS</h2><p class="sechead-ja">アクセス</p><div class="rule"></div></div>
<div class="acgrid">
<div>
<h3 class="acname">渋谷サクラステージ</h3>
<p class="acp">東京都渋谷区桜丘町1-1他</p>
<p class="acp">JR「渋谷駅」新南改札より直結</p>
<p class="acmeet"><span class="acmeet-label">集合場所</span>渋谷サクラステージ SHIBUYA SIDE 3階<br>「TO POP-UP」様前（エスカレーター前）</p>
<p class="aclink"><a href="https://www.google.com/maps/search/?api=1&query=渋谷サクラステージ" target="_blank" rel="noopener">Google Mapはこちら →</a></p>
</div>
<iframe class="map" src="https://maps.google.com/maps?q=%E6%B8%8B%E8%B0%B7%E3%82%B5%E3%82%AF%E3%83%A9%E3%82%B9%E3%83%86%E3%83%BC%E3%82%B8&t=&z=16&ie=UTF8&iwloc=B&output=embed" loading="lazy" title="渋谷サクラステージの地図"></iframe>
</div>
</div>
</section>

<section class="sec sec-alt" id="faq">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">FAQ</h2><p class="sechead-ja">よくある質問</p><div class="rule"></div></div>
<div class="faqlist">
{faqs.map(({ q, a }) => (
  <details class="faq">
    <summary><span class="qm">Q</span>{q}</summary>
    <p>{a}</p>
  </details>
))}
</div>
</div>
</section>

<section class="sec" id="contact">
<div class="wrap rv">
<div class="sechead"><h2 class="sechead-en">CONTACT</h2><p class="sechead-ja">お問い合わせ</p><div class="rule"></div></div>
<div class="center"><a class="buy" href="/#contact">お問い合わせページへ</a></div>
</div>
</section>

</main>

<footer class="ftr">
<div class="rv">
<img class="ftrlogo" src="/assets/uwasabanashi/logo-white.png" alt="ウワサバナシ調査委員会">
<div class="snsrow"><a class="sns" href="https://x.com/uwasatyousa" target="_blank" rel="noopener">X（旧Twitter）</a></div>
<p class="staff">主催・企画：株式会社ex Labs<br>脚本／制作：とんとん<br>会場：渋谷サクラステージ<br>運営会社：<a href="https://kabuexlabs.com/" target="_blank" rel="noopener">株式会社ex Labs</a></p>
<p class="fiction-note ftr-note">※本公演の内容はフィクションです。<br>実在の事件・人物とは一切関係ありません。</p>
<p class="copy">© 株式会社ex Labs All Rights Reserved.</p>
</div>
</footer>

<style is:global>
:root{--accent:#5fc9dc;--bg:#0a0d10;--bg2:#10151a;--ink:#d9e2e6;--dim:#8a979e}
html{scroll-behavior:smooth}
body{margin:0;background:var(--bg);color:var(--ink);font-family:'Zen Kaku Gothic New',sans-serif;line-height:1.9}
a{color:var(--accent);text-decoration:none}
a:hover{color:#fff}
.mincho{font-family:'Shippori Mincho',serif}
.accent{color:var(--accent)}
.dim{color:var(--dim)}
.center{text-align:center}
.wrap{max-width:1080px;margin:0 auto;padding:0 24px}
.sec{padding:110px 0}
.sec-alt{background:var(--bg2)}
.sechead{display:flex;flex-direction:column;align-items:center;gap:6px;margin-bottom:64px}
.sechead-en{font-family:'Shippori Mincho',serif;font-size:34px;font-weight:600;letter-spacing:.35em;color:#fff;margin:0}
.sechead-ja{font-size:13px;letter-spacing:.3em;color:var(--accent);margin:0}
.rule{width:36px;height:1px;background:var(--accent);margin-top:10px}

/* 固定ヘッダー */
.hdr{position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;justify-content:center;gap:36px;padding:14px 20px;background:rgba(10,13,16,.82);backdrop-filter:blur(8px);border-bottom:1px solid rgba(255,255,255,.06)}
.hdr a{color:var(--ink);font-size:13px;letter-spacing:.14em}
.hdr a:hover{color:var(--accent)}
/* ロゴは支給JPG（白地×黒文字）から生成した白抜き透過PNGを使用 */
.hlogo{height:44px;display:block}

/* 固定CTA */
.cta{position:fixed;right:22px;bottom:22px;z-index:60;background:var(--accent);color:#06141a;font-weight:700;letter-spacing:.14em;padding:19px 34px;border-radius:999px;box-shadow:0 8px 28px rgba(0,0,0,.55);font-size:15px;animation:ctapulse 2.4s ease-out infinite}
.cta:hover{color:#000;filter:brightness(1.12);animation-play-state:paused}
@keyframes ctapulse{0%{box-shadow:0 8px 28px rgba(0,0,0,.55),0 0 0 0 color-mix(in srgb,var(--accent) 55%,transparent)}75%{box-shadow:0 8px 28px rgba(0,0,0,.55),0 0 0 20px color-mix(in srgb,var(--accent) 0%,transparent)}100%{box-shadow:0 8px 28px rgba(0,0,0,.55),0 0 0 0 color-mix(in srgb,var(--accent) 0%,transparent)}}

/* スクロールリビール */
.rv{opacity:0;transform:translateY(28px);transition:opacity .9s ease,transform .9s ease}
.rv.vis{opacity:1;transform:none}

/* KV */
@keyframes rise{from{opacity:0;transform:translateY(26px)}to{opacity:1;transform:none}}
.kv{position:relative;min-height:100svh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:34px;text-align:center;overflow:hidden;padding:120px 24px 80px;box-sizing:border-box}
.kvbg{position:absolute;inset:0;background:radial-gradient(ellipse 90% 70% at 50% 30%,#15222b 0%,var(--bg) 70%);z-index:0}
.kvnoise{position:absolute;inset:0;opacity:.5;background:repeating-linear-gradient(0deg,transparent 0 3px,rgba(255,255,255,.012) 3px 4px);z-index:0}
.kvin{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:30px}
.kvlogo{width:min(560px,82vw);animation:rise 1.3s ease .1s both}
.kvcatch{font-size:clamp(15px,2vw,19px);letter-spacing:.22em;color:var(--ink);margin:0;animation:rise 1.3s ease .5s both}
.kvmeta{display:flex;flex-wrap:wrap;justify-content:center;gap:14px 40px;font-family:'Shippori Mincho',serif;animation:rise 1.3s ease .9s both}
.kvdate{font-size:clamp(18px,2.6vw,28px);letter-spacing:.12em;color:#fff}
/* 日付は9月分・10月分の2グループ。PCは1行（pconlyの区切りで連結）、
   スマホはグループ間で改行（sponly）し、行末に区切りが残らないようにする */
.kvd{white-space:nowrap}
.kvsep{color:var(--accent);font-size:.75em;padding:0 .35em}
.sponly{display:none}
.kvvenue{font-size:14px;letter-spacing:.24em;color:var(--dim);align-self:center}

/* NEWSティッカー */
.news{background:var(--accent);color:#06141a;overflow:hidden;white-space:nowrap;padding:10px 0;font-size:13px;font-weight:700;letter-spacing:.08em}
.newsin{display:inline-block;animation:tick 30s linear infinite}
@keyframes tick{from{transform:translateX(0)}to{transform:translateX(-50%)}}
.newsitem{display:inline-block;padding:0 34px}

/* STORY */
.storyp{font-family:'Shippori Mincho',serif;font-size:clamp(15px,1.7vw,18px);letter-spacing:.1em;line-height:2.6;margin:0 0 44px;text-align:center}
.fiction-note{font-size:12px;letter-spacing:.1em;color:var(--dim);text-align:center;margin:56px 0 0}
.ftr-note{margin:0 0 18px}
.storylead{font-size:clamp(19px,2.4vw,26px);color:#fff;letter-spacing:.16em}
.simg{width:min(720px,100%);height:340px;margin:56px auto;display:block;object-fit:cover}

/* ABOUT */
.aboutgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:28px}
.abcard{background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07);padding:38px 24px;box-sizing:border-box}
.abnum{font-family:'Shippori Mincho',serif;font-size:15px;letter-spacing:.3em;color:var(--accent);margin:0 0 16px}
.abh{font-family:'Shippori Mincho',serif;font-size:20px;font-weight:600;line-height:1.8;letter-spacing:.06em;color:#fff;margin:0 0 16px}
.abp{font-size:13px;color:var(--dim);margin:0}

/* CAST — 全員が常に見える均等グリッド。タップで詳細ダイアログ。
   動き: 表示順は読み込みごとにシャッフル（公平性の担保）、
   出現は1人ずつのステップフェード、待機中は位相をずらした浮遊 */
/* flex+中央寄せ: 人数が6の倍数でなくても最終行が中央に揃う */
.castgrid{display:flex;flex-wrap:wrap;justify-content:center;gap:22px 20px}
.castcard{width:calc((100% - 100px)/6)}
.castdlg{max-height:calc(100vh - 48px);overflow:auto}
.castcard{display:flex;flex-direction:column;gap:8px;background:none;border:0;padding:0;cursor:pointer;text-align:left;font-family:inherit;opacity:0;transition:opacity .8s ease;animation:castfloat 6s ease-in-out infinite}
.rv.vis .castcard{opacity:1}
.castcard:hover{animation-play-state:paused}
@keyframes castfloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-7px)}}
.castcard:nth-child(1){transition-delay:.05s;animation-delay:-0s}
.castcard:nth-child(2){transition-delay:.15s;animation-delay:-1s}
.castcard:nth-child(3){transition-delay:.25s;animation-delay:-2s}
.castcard:nth-child(4){transition-delay:.35s;animation-delay:-3s}
.castcard:nth-child(5){transition-delay:.45s;animation-delay:-4s}
.castcard:nth-child(6){transition-delay:.55s;animation-delay:-5s}
.castcard:nth-child(7){transition-delay:.65s;animation-delay:-.5s}
.castcard:nth-child(8){transition-delay:.75s;animation-delay:-2.5s}
.castcard:nth-child(9){transition-delay:.85s;animation-delay:-4.5s}
.castcard:nth-child(10){transition-delay:.95s;animation-delay:-1.5s}
.castimg{width:100%;height:auto;aspect-ratio:3/4;object-fit:cover;display:block;border:1px solid rgba(255,255,255,.08);filter:saturate(.9);transition:filter .3s ease}
.castcard:hover .castimg{filter:saturate(1.05) brightness(1.06)}
.castname{font-size:14px;letter-spacing:.06em;color:#fff;line-height:1.5}
.castx{font-size:11px;letter-spacing:.06em;color:var(--accent);word-break:break-all}
.casthint{font-size:11px;letter-spacing:.14em;text-align:center;margin:30px 0 0}
.castdlg{background:var(--bg2);color:var(--ink);border:1px solid rgba(255,255,255,.12);padding:0;max-width:min(760px,calc(100vw - 40px));width:100%}
.castdlg::backdrop{background:rgba(5,8,10,.82);backdrop-filter:blur(3px)}
.dlgbody{display:grid;grid-template-columns:280px 1fr;gap:0}
.dlgimg{width:100%;height:100%;min-height:280px;object-fit:cover;display:block}
.dlginfo{padding:34px 30px;display:flex;flex-direction:column;align-items:flex-start;gap:14px}
.dlgname{font-size:22px;font-weight:600;letter-spacing:.08em;color:#fff;margin:0}
.dlgbio{font-size:13.5px;line-height:2;color:var(--dim);margin:0}
.dlgx{font-size:13px;letter-spacing:.1em;margin-top:auto;padding-top:10px}
.dlgclose{position:absolute;top:10px;right:12px;background:none;border:0;color:var(--dim);font-size:26px;line-height:1;cursor:pointer;z-index:1}
.dlgclose:hover{color:#fff}

/* TICKET */
.price{display:flex;flex-wrap:wrap;justify-content:center;gap:22px;margin:0 0 40px}
.pricebox{background:var(--bg2);border:1px solid rgba(255,255,255,.08);padding:30px 46px;text-align:center;min-width:200px;box-sizing:border-box}
.pricelabel{font-size:13px;letter-spacing:.2em;color:var(--accent);margin:0 0 8px}
.priceval{font-family:'Shippori Mincho',serif;font-size:30px;color:#fff;margin:0}
.priceunit{font-size:13px}
.pricenote{font-size:12px;color:var(--dim);text-align:center;margin:18px 0 0}
.buy{display:inline-block;background:var(--accent);color:#06141a;font-weight:700;letter-spacing:.14em;padding:18px 60px;font-size:15px}
.buy:hover{color:#000;filter:brightness(1.12)}

/* TEAM */
.teamgrid{display:grid;grid-template-columns:280px 1fr;gap:44px;align-items:start}
.teamimg{width:280px;height:280px;object-fit:cover;display:block}
.teamp{font-size:14px;color:var(--dim);margin:0 0 14px}
.teamrole{font-size:13px;letter-spacing:.2em;color:var(--accent);margin:0 0 8px}
.teamname{font-size:24px;font-weight:600;letter-spacing:.08em;color:#fff;margin:0 0 18px}

/* 注意事項 */
.notes{max-width:820px;margin:0 auto}
.noteh{font-family:'Shippori Mincho',serif;font-size:17px;font-weight:600;letter-spacing:.1em;color:var(--accent);border-bottom:1px solid rgba(255,255,255,.1);padding-bottom:10px;margin:44px 0 16px}
.notes ul{margin:0;padding-left:22px}
.notes li{font-size:13px;color:var(--dim);margin-bottom:8px}

/* ACCESS */
.acgrid{display:grid;grid-template-columns:1fr 1fr;gap:44px;align-items:start}
.acname{font-family:'Shippori Mincho',serif;font-size:24px;font-weight:600;color:#fff;letter-spacing:.08em;margin:0 0 10px}
.acp{font-size:14px;color:var(--dim);margin:0 0 8px}
.acmeet{font-size:14px;color:var(--ink);margin:18px 0 0;line-height:1.9}
.acmeet-label{display:block;font-size:12px;letter-spacing:.2em;color:var(--accent);margin-bottom:4px}
.aclink{margin-top:16px}
.map{width:100%;height:320px;border:0;filter:grayscale(1) invert(.92) contrast(.9)}

/* FAQ */
.faqlist{max-width:820px;margin:0 auto}
.faq{border-bottom:1px solid rgba(255,255,255,.08)}
.faq summary{cursor:pointer;list-style:none;display:flex;gap:16px;align-items:baseline;padding:22px 8px;font-family:'Shippori Mincho',serif;font-size:16px;color:#fff;letter-spacing:.04em}
.faq summary::-webkit-details-marker{display:none}
.faq summary:hover{color:var(--accent)}
.qm{color:var(--accent);font-size:18px;flex-shrink:0}
.faq p{margin:0;padding:0 8px 24px 42px;font-size:14px;color:var(--dim)}

/* フッター */
.ftr{background:#05080a;padding:70px 0 40px;text-align:center}
.ftrlogo{height:70px;margin-bottom:30px}
.snsrow{display:flex;justify-content:center;flex-wrap:wrap;gap:14px;margin:0 0 34px}
.sns{display:inline-flex;align-items:center;justify-content:center;height:44px;padding:0 24px;border:1px solid rgba(255,255,255,.18);border-radius:999px;color:var(--ink);font-size:13px;letter-spacing:.12em}
.sns:hover{border-color:var(--accent);color:var(--accent)}
.staff{font-size:12px;color:var(--dim);letter-spacing:.1em;line-height:2.2;margin:0 0 34px}
.copy{font-size:11px;color:#4a565c;letter-spacing:.08em;margin:0}

@media (max-width:760px){
.hdr{gap:8px 14px;flex-wrap:wrap;padding:10px 12px}
.hdr a{font-size:11px;letter-spacing:.08em}
.hlogo{height:30px}
.hbrand{order:-1;flex-basis:100%;display:flex;justify-content:center}
.teamgrid,.acgrid{grid-template-columns:1fr}
/* アイコン画像は正方形のまま中央寄せ（横長トリミングすると耳が切れる） */
.teamimg{width:min(240px,100%);height:auto;aspect-ratio:1;margin:0 auto}
.sec{padding:76px 0}
.kv{padding:130px 20px 70px}
.kvcatch{letter-spacing:.1em}
.sponly{display:inline}
.pconly{display:none}
/* 指定の改行位置がそのまま収まるよう、字間とサイズを詰める */
.storyp{font-size:14px;letter-spacing:.06em}
.storyp.storylead{font-size:16px;letter-spacing:.1em}
.faq summary{word-break:auto-phrase}
.simg{height:220px}
.castgrid{gap:16px 10px}
.castcard{width:calc((100% - 20px)/3)}
.castname{font-size:11.5px}
.castx{font-size:10px}
.dlgbody{grid-template-columns:1fr}
.dlgimg{min-height:0;height:320px}
.dlginfo{padding:24px 22px 30px}
.price{gap:14px}
.pricebox{flex:1 1 140px;padding:24px 20px;min-width:0}
.buy{display:block;padding:17px 20px}
.cta{right:14px;bottom:14px;padding:16px 24px;font-size:14px}
.map{height:260px}
}

@media (prefers-reduced-motion: reduce){
html{scroll-behavior:auto}
.kvlogo,.kvcatch,.kvmeta,.cta{animation:none}
.newsin{animation:none}
.castcard{animation:none;opacity:1;transition:none}
.rv{opacity:1;transform:none;transition:none}
}
</style>

<script is:inline>
(function () {
  var els = document.querySelectorAll('.rv');
  if (!els.length) return;
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches || !('IntersectionObserver' in window)) {
    els.forEach(function (el) { el.classList.add('vis'); });
    return;
  }
  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('vis');
        io.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  els.forEach(function (el) { io.observe(el); });
})();
</script>

<script is:inline define:vars={{ cast }}>
(function () {
  var dlg = document.getElementById('castdlg');
  if (!dlg || typeof dlg.showModal !== 'function') return;
  var img = document.getElementById('dlgimg');
  var name = document.getElementById('dlgname');
  var bio = document.getElementById('dlgbio');
  var x = document.getElementById('dlgx');
  document.querySelectorAll('.castcard').forEach(function (btn) {
    btn.addEventListener('click', function () {
      var c = cast[Number(btn.dataset.cast)];
      if (!c) return;
      img.src = '/assets/uwasabanashi/cast-' + c.id + '.webp';
      img.alt = c.name;
      name.textContent = c.name;
      bio.textContent = c.bio;
      x.href = 'https://x.com/' + c.x;
      dlg.showModal();
    });
  });
  dlg.querySelector('.dlgclose').addEventListener('click', function () { dlg.close(); });
  dlg.addEventListener('click', function (e) { if (e.target === dlg) dlg.close(); });
})();
</script>

</body>
</html>
