---
// ANATOR のお問い合わせフォーム (/anator/ の CONTACT セクション用)。
//
// 送信先は本体サイト (kabuexlabs.com) のお問い合わせと同じ Formspree フォーム。
// このエンドポイントは認証済みで、確実に info@kabuexlabs.com へ届く
// (smystery / toudaimurder / taikenbizyutu のフォームと同じ)。
// 送信は fetch (AJAX) で行い、完了後は当サイトのサンクスページへ遷移する。
// JS 無効時は通常 POST にフォールバックする (Formspree の完了画面経由)。
const FORM_ENDPOINT = 'https://formspree.io/f/xykqblal';
const thanksPath = '/anator/contact/thanks/';
---

<form class="anator-form" action={FORM_ENDPOINT} method="POST" data-thanks={thanksPath}>
  <input type="hidden" name="_subject" value="【ANATOR】サイトからのお問い合わせ">
  <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off">

  <label class="field">
    <span class="flabel">お名前</span>
    <input name="お名前" type="text" required autocomplete="name" placeholder="山田 花子">
  </label>
  <label class="field">
    <span class="flabel">メールアドレス</span>
    <input name="email" type="email" required autocomplete="email" placeholder="mail@example.com">
  </label>
  <label class="field">
    <span class="flabel">お問い合わせ内容</span>
    <textarea name="お問い合わせ内容" rows="5" required placeholder="ご用件をご記入ください"></textarea>
  </label>

  <p class="form-err" hidden>送信に失敗しました。お手数ですが時間をおいて再度お試しいただくか、<a href="mailto:info@kabuexlabs.com">info@kabuexlabs.com</a> まで直接ご連絡ください。</p>
  <div class="form-submit"><button class="sendbtn" type="submit">送信する</button></div>
</form>

<script>
// AJAX送信 → 自サイトのサンクスページへ。失敗時はエラー表示して再送可能にする。
for (const form of document.querySelectorAll<HTMLFormElement>('.anator-form')) {
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector<HTMLButtonElement>('.sendbtn')!;
    const err = form.querySelector<HTMLElement>('.form-err')!;
    err.hidden = true;
    btn.disabled = true;
    const original = btn.textContent;
    btn.textContent = '送信中…';
    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });
      if (!res.ok) throw new Error(`formspree ${res.status}`);
      window.location.href = form.dataset.thanks!;
    } catch {
      err.hidden = false;
      btn.disabled = false;
      btn.textContent = original;
    }
  });
}
</script>

<style>
.anator-form{margin-top:64px;display:flex;flex-direction:column;gap:34px;text-align:left}
.field{display:flex;flex-direction:column;gap:12px}
.flabel{font-size:12px;letter-spacing:.3em;color:#8d897f}
.field input,.field textarea{background:transparent;color:#e8e5df;font-size:15px;letter-spacing:.08em;outline:none;box-sizing:border-box}
.field input{border:0;border-bottom:1px solid #2c2c30;padding:10px 2px;transition:border-color .3s}
.field input:focus{border-bottom-color:var(--accent)}
.field textarea{border:1px solid #2c2c30;padding:14px;line-height:2;resize:vertical;transition:border-color .3s}
.field textarea:focus{border-color:var(--accent)}
.form-err{color:#d9b0b0;border:1px solid #5a3a3a;padding:12px 16px;margin:0;font-size:13px;letter-spacing:.04em;text-align:center;line-height:1.9}
.form-err a{color:#d9b0b0;text-decoration:underline}
.form-submit{margin-top:10px;text-align:center}
.sendbtn{align-self:center;background:transparent;border:1px solid var(--accent);color:var(--accent);font-family:'Shippori Mincho',serif;font-size:14px;letter-spacing:.4em;text-indent:.4em;padding:16px 64px;cursor:pointer;transition:background .3s,color .3s}
.sendbtn:hover{background:var(--accent);color:#0a0a0b}
.sendbtn:disabled{opacity:.5;cursor:wait}
</style>
