---
// 東大マーダーミステリーサークルのお問い合わせフォーム。
// /toudaimurder/contact/ とトップページの CONTACT セクションで共用。
//
// 送信先は本体サイト (kabuexlabs.com) のお問い合わせと同じ Formspree フォーム。
// 本体フォームと同一の「通常 POST」で送信し、Formspree の _next で当サイトの
// サンクスページへ戻す。AJAX(fetch)は「200 を返すが実際は未配信」の状態を
// success として隠してしまうため使わず、本体の実績ある送信経路に揃える。
// ハニーポット (_gotcha) は意図的に付けない — 本体フォームは付けておらず、
// このフィールドが自動入力等で埋まると Formspree は "success" 表示のまま
// メールを配信しない。本体との唯一の構造差だったため、実害を避けて撤去した。
import { tmWorks } from '../data/toudaimurderWorks';

const FORM_ENDPOINT = 'https://formspree.io/f/xykqblal';
// _next は絶対 URL である必要がある (Formspree 仕様)。
const NEXT_URL = 'https://kabuexlabs.com/toudaimurder/contact/thanks/';
---

<form class="cform" action={FORM_ENDPOINT} method="POST">
  <input type="hidden" name="_subject" value="【東大マーダーミステリーサークル】サイトからのお問い合わせ">
  <input type="hidden" name="_next" value={NEXT_URL}>

  <label class="fl"><span class="flt">お名前 <span class="req">必須</span></span>
    <input class="fi" type="text" name="お名前" required autocomplete="name" placeholder="山田 太郎">
  </label>

  <label class="fl"><span class="flt">メールアドレス <span class="req">必須</span></span>
    <input class="fi" type="email" name="email" required autocomplete="email" placeholder="example@email.com">
  </label>

  <label class="fl"><span class="flt">お問い合わせ種別</span>
    <select class="fi" name="お問い合わせ種別">
      <option>公演の予約</option>
      <option>貸切公演の相談</option>
      <option>取材・コラボのご相談</option>
      <option>その他</option>
    </select>
  </label>

  <label class="fl"><span class="flt">ご希望の作品（任意）</span>
    <select class="fi" name="ご希望の作品">
      <option value="">選択しない</option>
      {tmWorks.map((w) => <option>{w.title}</option>)}
    </select>
  </label>

  <label class="fl"><span class="flt">お問い合わせ内容 <span class="req">必須</span></span>
    <textarea class="fi ft" name="お問い合わせ内容" required rows="7" placeholder="ご希望の日時・人数などがあればあわせてご記入ください。"></textarea>
  </label>

  <button class="send" type="submit">送信する</button>
  <p class="privacy dim">ご入力いただいた情報は、お問い合わせへの回答のみに使用いたします。うまく送信できない場合は <a href="mailto:info@kabuexlabs.com">info@kabuexlabs.com</a> まで直接ご連絡ください。</p>
</form>

<style>
.cform{border:1px solid var(--ln);background:#0e0c0f;padding:44px 40px;display:flex;flex-direction:column;gap:22px}
.fl{display:flex;flex-direction:column;gap:8px;font-size:13px;font-weight:700;letter-spacing:.06em}
.flt{display:block}
.req{display:inline-block;border:1px solid var(--acc);color:var(--acc);font-size:10px;font-weight:600;padding:1px 8px;margin-left:8px;letter-spacing:.14em;vertical-align:middle}
.fi{background:#0b0a0c;border:1px solid var(--ln);color:#eae5e1;font-size:14px;font-family:'Noto Sans JP',sans-serif;padding:13px 16px;border-radius:2px;transition:border-color .2s}
.fi:focus{outline:none;border-color:var(--acc)}
.ft{resize:vertical;min-height:140px}
select.fi{appearance:none;background-image:linear-gradient(45deg,transparent 50%,var(--dim) 50%),linear-gradient(135deg,var(--dim) 50%,transparent 50%);background-position:calc(100% - 21px) 50%,calc(100% - 16px) 50%;background-size:5px 5px;background-repeat:no-repeat}
.send{display:inline-flex;align-items:center;justify-content:center;gap:14px;background:var(--acc);color:#fff;border:none;border-radius:999px;padding:16px 48px;font-size:14px;letter-spacing:.18em;font-weight:700;cursor:pointer;font-family:'Noto Sans JP',sans-serif;transition:background .2s;margin-top:6px}
.send::after{content:"→"}
.send:hover{background:#b2132c}
.privacy{font-size:11px;margin:0}
.privacy a{color:var(--dim);text-decoration:underline}
@media (max-width:900px){.cform{padding:32px 24px}}
</style>
