---
// ANATOR (/anator/) 専用レイアウト。
// 少人数密室型イマーシブ空間「ANATOR」のマイクロサイト。
// 本体サイトとは別ブランドなので BaseLayout は使わず、フォント・配色・
// ヘッダー/フッターをここで完結させる (smystery / toudaimurder と同じ方式)。
// Claude Design のハンドオフ (ANATOR.dc.html) を Astro に移植したもの。
import { jsonLd } from '../lib/microcms';

export interface Props {
  title?: string;
  description?: string;
  /** OGP 画像 (public/ 配下のパス) */
  ogImage?: string;
  /** テーマのアクセントカラー (雰囲気に合わせて差し替え可) */
  accent?: string;
}

const {
  title = 'ANATOR｜少人数密室型イマーシブ空間',
  description =
    'ANATOR（アナター）は、閉ざされた小さな空間でキャストと言葉を交わす、少人数密室型のイマーシブ劇場。濃密な物語体験のための空間として、公演・スペースレンタルを行っています。東京・神田司町。',
  ogImage = '/assets/anator/exterior.jpg',
  accent = '#b5a67f',
} = Astro.props;

const site = Astro.site ?? new URL('https://kabuexlabs.com');
// Canonical always uses the trailing-slash form so /path と /path/ が
// 別ページ扱いにならないようにする。
const canonical = new URL(Astro.url.pathname.replace(/([^/])$/, '$1/'), site);
const ogImageAbs = new URL(ogImage, site);

const base = '/anator';
const nav = [
  { href: `${base}/#concept`, label: '概念' },
  { href: `${base}/#works`, label: '公演実績' },
  { href: `${base}/#rental`, label: 'レンタル' },
  { href: `${base}/#access`, label: 'アクセス' },
];

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'TheaterGroup',
  name: 'ANATOR',
  alternateName: 'アナター',
  url: new URL(`${base}/`, site).toString(),
  logo: new URL('/assets/anator/mark-w.png', site).toString(),
  image: ogImageAbs.toString(),
  description:
    '閉ざされた小さな空間でキャストと言葉を交わす、少人数密室型のイマーシブ劇場。濃密な物語体験のための空間。',
  address: {
    '@type': 'PostalAddress',
    postalCode: '101-0048',
    addressRegion: '東京都',
    addressLocality: '千代田区',
    streetAddress: '神田司町2丁目15−11 HARVEY神田司町 4F',
    addressCountry: 'JP',
  },
  parentOrganization: {
    '@type': 'Organization',
    name: '株式会社ex Labs',
    url: 'https://kabuexlabs.com/',
  },
};
---

<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{title}</title>
<meta name="description" content={description}>
<link rel="canonical" href={canonical}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content="website">
<meta property="og:url" content={canonical}>
<meta property="og:image" content={ogImageAbs}>
<meta property="og:site_name" content="ANATOR">
<meta property="og:locale" content="ja_JP">
<meta name="twitter:card" content="summary_large_image">
<link rel="icon" href="/favicon.ico" sizes="48x48">
<link rel="icon" type="image/png" href="/favicon-ex.png">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Shippori+Mincho:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,400&display=swap" rel="stylesheet">
<script type="application/ld+json" set:html={jsonLd(orgLd)} />
<noscript><style>.rv{opacity:1 !important;transform:none !important}</style></noscript>
<slot name="head" />
</head>
<body style={`--accent:${accent}`}>

<nav id="sitenav" class="sitenav">
  <a class="brand" href={`${base}/#top`} aria-label="ANATOR トップ">
    <img src="/assets/anator/mark-w.png" alt="ANATORロゴマーク" width="30" height="30">
    <span class="brand-name">ANATOR</span>
  </a>
  <div class="nl">
    {nav.map((item) => <a href={item.href}>{item.label}</a>)}
    <a class="nav-contact" href={`${base}/#contact`}>Contact</a>
  </div>
</nav>

<slot />

<footer class="site-footer">
  <img src="/assets/anator/mark-w.png" alt="ANATORロゴマーク" width="44" height="44" loading="lazy">
  <div class="foot-links">
    <a href="https://kabuexlabs.com/" target="_blank" rel="noopener">運営会社：株式会社 ex Labs ↗</a>
  </div>
  <p class="copy">© 2026 ex Labs Inc.</p>
</footer>

<style is:global>
html{scroll-behavior:smooth;scroll-padding-top:80px}
body{margin:0;background:#0a0a0b;color:#e8e5df;font-family:'Shippori Mincho',serif;-webkit-font-smoothing:antialiased;overflow-x:hidden}
a{color:#e8e5df;text-decoration:none;transition:color .3s}
a:hover{color:var(--accent)}
img{max-width:100%;display:block}
input,textarea{font-family:'Shippori Mincho',serif}
input::placeholder,textarea::placeholder{color:#55524c}
p,h1,h2,h3{word-break:keep-all;overflow-wrap:anywhere}
::selection{background:#2a2820;color:#f5f2ec}
@keyframes fadeUp{from{opacity:0;transform:translateY(28px)}to{opacity:1;transform:none}}
@keyframes slowGlow{0%,100%{opacity:.35}50%{opacity:.7}}
.rv{opacity:0;transform:translateY(28px);transition:opacity 1.1s cubic-bezier(.22,.61,.36,1),transform 1.1s cubic-bezier(.22,.61,.36,1)}
.rv.on{opacity:1;transform:none}
/* nav */
.sitenav{position:fixed;top:0;left:0;right:0;z-index:50;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:10px;padding:22px 44px;box-sizing:border-box;background:linear-gradient(rgba(10,10,11,.85),rgba(10,10,11,0));backdrop-filter:blur(2px)}
.sitenav .brand{display:flex;align-items:center;gap:12px}
.sitenav .brand img{height:30px;width:auto;display:block}
.sitenav .brand-name{font-family:'Cormorant Garamond',serif;font-size:20px;letter-spacing:.42em;font-weight:500}
.sitenav .nl{display:flex;align-items:center;flex-wrap:wrap;gap:28px;font-size:13px;letter-spacing:.22em}
.sitenav .nav-contact{border:1px solid #3a382f;padding:6px 18px;letter-spacing:.22em;transition:border-color .3s,color .3s}
.sitenav .nav-contact:hover{border-color:var(--accent)}
/* footer */
.site-footer{padding:70px 24px 56px;border-top:1px solid #1c1c1f;text-align:center}
.site-footer>img{height:44px;width:auto;margin:0 auto}
.site-footer .foot-links{margin-top:30px;display:flex;justify-content:center;gap:32px;font-size:12px;letter-spacing:.18em;color:#8d897f}
.site-footer .foot-links a{color:#8d897f}
.site-footer .foot-links a:hover{color:var(--accent)}
.site-footer .copy{margin:34px 0 0;font-size:11px;letter-spacing:.2em;color:#55524c}
/* shared section heading helpers */
.eyebrow{font-family:'Cormorant Garamond',serif;font-size:13px;letter-spacing:.5em;color:var(--accent);margin:0}
.sec-h2{font-size:clamp(24px,3.4vw,34px);font-weight:500;letter-spacing:.24em}
@media (max-width:640px){
  .sitenav{padding:16px 18px}
  .sitenav .nl{gap:14px;font-size:11px}
  .sec-h2{letter-spacing:.16em}
}
@media (prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  .rv{opacity:1;transform:none;transition:none}
}
</style>

<script>
// スクロール連動フェードイン (.rv → .on)。動的に追加される .rv も監視する。
const io = new IntersectionObserver(
  (entries) => {
    for (const e of entries) {
      if (e.isIntersecting) { e.target.classList.add('on'); io.unobserve(e.target); }
    }
  },
  { threshold: 0.05 },
);
const seen = new WeakSet<Element>();
const scan = () => {
  document.querySelectorAll('.rv').forEach((el) => {
    if (!seen.has(el)) { seen.add(el); io.observe(el); }
  });
};
scan();

// 初期ビューポート内で交差イベントが発火しないケースの保険。
window.setTimeout(() => {
  document.querySelectorAll('.rv:not(.on)').forEach((el) => {
    const r = el.getBoundingClientRect();
    if (r.top < window.innerHeight && r.bottom > 0) el.classList.add('on');
  });
}, 2500);
</script>
</body>
</html>
