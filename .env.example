MICROCMS_SERVICE_DOMAIN=your-service-domain
MICROCMS_API_KEY=your-api-key

# --- 日程調整（/yoyaku）関連。設定手順は docs/yoyaku-setup.md 参照 ---

# 予約ページのURLトークン（推測できない長いランダム文字列にする）
# 例: openssl rand -hex 16 で生成
BOOKING_PAGE_TOKEN=

# 管理ページ（/yoyaku/admin/）の合言葉
YOYAKU_ADMIN_KEY=

# Upstash Redis（Vercel Marketplace 経由なら自動で注入される）
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Resend（メール送信・無料枠 月3,000通）。未設定でも予約は動き、メールだけ送られない
RESEND_API_KEY=
# 送信元（Resend でドメイン認証したアドレスにする）
MAIL_FROM="ex Labs 予約窓口 <yoyaku@kabuexlabs.com>"
# 予約通知・リマインドの控えを受け取るアドレス
YOYAKU_ADMIN_EMAIL=info@kabuexlabs.com

# Cron エンドポイント保護用（Vercel が自動でヘッダに付与する）
CRON_SECRET=
